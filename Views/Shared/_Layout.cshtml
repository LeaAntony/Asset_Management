        $('body').on("click", function (e) {
            $(this).removeClass('sidebar-open');
        });

        function number_to_k(n, precision = 2) {
            let n_format = 0;
            n_format = (n / 1000).toFixed(precision) + 'K';
            return n_format;
        }

        $(document).ready(function () {
            const $body = $('body');
            const $sidebar = $('.main-sidebar');
            const $img = $('#sidebar-brand-img');

            const imgOpen = '@Url.Content("~/images/logo/amt_white.png")';
            const imgClosed = '@Url.Content("~/images/logo/aml_white.png")';

            function updateSidebarLogo() {
                if ($body.hasClass('sidebar-collapse') && !$body.hasClass('sidebar-open')) {
                    $img.attr('src', imgClosed);
                } else {
                    $img.attr('src', imgOpen);
                }
            }

            updateSidebarLogo();

            $(document).on('click', '[data-widget="pushmenu"]', function () {
                setTimeout(updateSidebarLogo, 200);
            });

            $sidebar.on('mouseenter', function () {
                $img.attr('src', imgOpen);
            });

            $sidebar.on('mouseleave', function () {
                if ($body.hasClass('sidebar-collapse') && !$body.hasClass('sidebar-open')) {
                    $img.attr('src', imgClosed);
                }
            });
        });
    </script>
    @RenderSection("Scripts", required: false)
