@using Microsoft.AspNetCore.Http;
@using Asset_Management.Function;
@{
    string role = ViewBag.role;
    string sesa_id = ViewBag.sesa_id;
}

<style>
    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
    }

        .hero .hero-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }

        .hero .hero-body {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        .hero .hero-title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

    .inner {
        height: 70px;
        position: relative;
    }

    .hero .inner {
        background: rgba(0,0,0,0.7);
    }

    .professional-table {
        font-size: 12px;
        border-collapse: separate;
        border-spacing: 0;
        clip-path: inset(0 round 8px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

        .professional-table thead th {
            background: var(--primary-blue);
            color: white;
            font-weight: 600;
            text-align: center;
            vertical-align: middle;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .professional-table tbody td {
            border: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .professional-table tbody tr:hover {
            background-color: var(--background-gray);
        }

        .professional-table th,
        .professional-table td {
            box-sizing: border-box;
            white-space: nowrap;
        }

    .modal {
        overflow: auto !important;
    }

    #loadingSpinner {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.5);
    }

        #loadingSpinner img {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    .box_form_input {
        background-color: #fcfcfc;
        border-radius: 5px;
        box-shadow: 1px 2px 8px 2px rgba(152,152,152,0.7);
    }

    .smaller-input {
        height: 20px;
        padding: 5px;
        font-size: 10px;
        line-height: 1;
    }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 10pt;
    }

    .dataTables_filter {
        display: none;
    }

    table#table_shipping_nonasset_open tr > td {
        padding: 5px;
    }

    table#table_shipping_nonasset_closed tr > td {
        padding: 5px;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .half-underline {
        flex-grow: 1;
        text-align: center;
        margin-left: 15rem;
    }

    .form-inline {
        display: flex;
        align-items: center;
    }

    .table-container {
        display: none;
    }

        .table-container.active {
            display: block;
        }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/bg-am.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">

        <div>
        </div>

        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-ship text-success"></i>
                <b>Non-Asset Shipping List</b>
            </h3>
        </div>

        <div class="ms-auto">
        </div>

    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-3">
                <div class="list-card card fade-in">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12">
                                <div class="row table-container active" id="openTableContainer">
                                    <div class="col-12">
                                        <table class="table professional-table align-center nowrap" id="table_shipping_nonasset_open" style="font-size:8pt; width:100%">
                                            <thead class="align-middle text-center" style="background: var(--primary-blue); color: white; font-weight: 600;">
                                                <tr>
                                                    <th>Request ID</th>
                                                    <th>Category</th>
                                                    <th>Request By</th>
                                                    <th>Request Date</th>
                                                    <th>Return Date</th>
                                                    <th>Vendor Name</th>
                                                    <th>Status</th>
                                                    <th>Status Remark</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="row table-container" id="closedTableContainer">
                                    <div class="col-12">
                                        <table class="table professional-table align-center nowrap" id="table_shipping_nonasset_closed" style="font-size:8pt; width:100%">
                                            <thead class="align-middle text-center" style="background: var(--primary-blue); color: white; font-weight: 600;">
                                                <tr>
                                                    <th>Request ID</th>
                                                    <th>Proforma No</th>
                                                    <th>Category</th>
                                                    <th>Request By</th>
                                                    <th>Request Date</th>
                                                    <th>Return Date</th>
                                                    <th>Vendor Name</th>
                                                    <th>Status</th>
                                                    <th>Status Remark</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div id="loadingSpinner" style="display: none;">
                <span class="spinner-border spinner-border" role="status" aria-hidden="true"></span>
            </div>
        </div>
    </div>
</div>

<select class="form-select" name="status" id="statusSelect" style="width: auto; display: none;">
    <option value="OPEN">SHIPPING OPEN</option>
    <option value="CLOSE">SHIPPING CLOSED</option>
</select>

