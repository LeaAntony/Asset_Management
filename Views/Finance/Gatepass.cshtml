                                            <th class="align-middle" rowspan="2">Approval</th>
                                        </tr>
                                        <tr>
                                            @for (int i = 0; i < 10; i++)
                                            {
                                                <th><input type="text" class="form-control smaller-input filter_table" target="@i" /></th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div id="loadingSpinner" style="display: none;">
                <span class="spinner-border spinner-border" role="status" aria-hidden="true"></span>
            </div>
        </div>
    </div>
</div>

