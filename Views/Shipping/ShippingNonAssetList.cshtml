                                </thead>
                                <tbody id="itemTableBodyNonAsset">
                                </tbody>
                            </table>
                        </div>
                        <button type="button" class="btn btn-primary mt-2" id="createBoxBtnNonAsset" disabled>
                            <i class="fas fa-plus mr-2"></i>Create Box
                        </button>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-12">
                        <h6><i class="fas fa-archive mr-2"></i>Shipping Boxes</h6>
                        <div class="table-responsive">
                            <table class="table professional-table" id="boxTableNonAsset">
