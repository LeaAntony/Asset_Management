@section Scripts {
    <script>
        var preselect_assets = "@assets";
        var table;
        var selected_assets = [];
        var suggested_assets = [];
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        const lotFamilyGroup = @Html.Raw(lotFamilyGroupJson);
        const lotMachineGroup = @Html.Raw(lotMachineGroupJson);
        let isFromDisposal = false;
        var preselectedVendor = '@ViewBag.SelectedVendorCode';
        if (preselectedVendor) {
            var vendorText = '@ViewBag.SelectedVendorCode' + ' - ' + '@ViewBag.SelectedVendorName';
            var newOption = new Option(vendorText, preselectedVendor, true, true);
            $('#vendor_code').append(newOption).trigger('change');
        }

        function openPDF(filename) {
            var pdfURL = "../WI/" + filename;
            $("#pdf-popup-modal").modal("show");
            var iframe = document.getElementById("pdf-iframe");
            iframe.src = pdfURL;
        }

        function closePDF() {
            $("#pdf-popup-modal").modal("hide");
            var iframe = document.getElementById("pdf-iframe");
            iframe.src = "";
        }

        function loadingComplete() {
            $(".container-fluid").removeClass("hidden");
        }

        function checkProforma() {
            let category = $("select[name=category]").val();
            let vendor_batam = $("#vendor_batam").val();
            let gross_val = $("input[name=gross_val]").val().replace(",", "");

            const isFaSalesVendor = category === "FA SALES - WITHOUT DISMANTLING" && $("select[name=type]").val() === "VENDOR";
            const isNonBatamCategory = ["TRANSFER TO VENDOR", "REPAIR TO VENDOR"].includes(category);

            if (vendor_batam === "Non Batam" && (isNonBatamCategory || isFaSalesVendor)) {
                $("div#prof_form").removeClass("hidden");
                $("div#prof_address, div#prof_ship").find("input").attr("required", "required");

                if (isNonBatamCategory || isFaSalesVendor) {
                    $("#security_hide").prop("hidden", true);
                    $("#security_guard").removeAttr("required");
                    $("#shipping_plant_hide").prop("hidden", false);
                    $("#shipping_plant").attr("required", "required");
                } else {
                    $("#security_hide").prop("hidden", false);
                    $("#security_guard").attr("required", "required");
                    $("#shipping_plant_hide").prop("hidden", true);
                    $("#shipping_plant").removeAttr("required");
                }

                if (parseFloat(gross_val) > 2500) {
                    $("div#prof_attach").removeClass("hidden");
                    $("input[name=file_attach]").attr("required", "required");
                } else {
                    $("div#prof_attach").addClass("hidden");
                    $("input[name=file_attach]").removeAttr("required");
                }
            } else {
                $("div#prof_form").addClass("hidden");
                $("div#prof_address, div#prof_ship").find("input").removeAttr("required");
                $("div#prof_attach").addClass("hidden");
                $("input[name=file_attach]").removeAttr("required");

                if (["TRANSFER TO VENDOR", "TRANSFER PLANT TO PLANT", "REPAIR TO VENDOR", "FA SALES - WITHOUT DISMANTLING"].includes(category)) {
                    $("#security_hide").prop("hidden", false);
                    $("#security_guard").attr("required", "required");
                } else {
                    $("#security_hide").prop("hidden", true);
                    $("#security_guard").removeAttr("required");
                }

                $("#shipping_plant_hide").prop("hidden", true);
                $("#shipping_plant").removeAttr("required");
            }
        }

        $(document).ready(function () {
            $('[data-bs-toggle="tooltip"]').tooltip();

            show_selected_assets()

            $('#category').change(function () {
                var return_date = $('#return_date');
                var location = $('#location');
                var vcode_hide = $('#vcode_hide');
                var vphone_hide = $('#vphone_hide');
                var vaddr_hide = $('#vaddr_hide');
                var vemail_hide = $('#vemail_hide');
                var security_hide = $('#security_hide');
                var vehicle_hide = $('#vehicle_hide');
                var driver_hide = $('#driver_hide');
                var pic_hide = $('#pic_hide');
                var loc_hide = $('#loc_hide');
                var date_hide = $('#date_hide');
                var new_pic = $('#new_pic');
                var table_form_plant = $('#table_form_plant');
                var naming_hide = $('#naming_hide');
                var type_hide = $('#type_hide');
                var type = $('#select_type');
                var employee_hide = $('#employee_hide');
                var csr_hide = $('#csr_hide');

                function setProperties(readonly, hidden, required) {
                    return_date.prop('readonly', readonly);
                    vcode_hide.prop('hidden', hidden.vcode);
                    vphone_hide.prop('hidden', hidden.vphone);
                    vaddr_hide.prop('hidden', hidden.vaddr);
                    vemail_hide.prop('hidden', hidden.vemail);
                    security_hide.prop('hidden', hidden.security);
                    vehicle_hide.prop('hidden', hidden.vehicle);
                    driver_hide.prop('hidden', hidden.driver);
                    date_hide.prop('hidden', hidden.date);
                    pic_hide.prop('hidden', hidden.pic);
                    loc_hide.prop('hidden', hidden.loc);
                    table_form_plant.prop('hidden', hidden.table_form_plant);
                    naming_hide.prop('hidden', hidden.naming);
                    $('#vendor_code').prop('required', required.vendor_code);
                    new_pic.prop('required', required.new_pic);
                    location.prop('required', required.location);
                    $('#security_guard').prop('required', required.security_guard);
                    $('#select_type').prop('required', required.type);
                    $('#vendor_email').prop('required', required.vendor_email);
                    type_hide.prop('hidden', hidden.type_hide);
                    employee_hide.prop('hidden', hidden.employee_hide);
                    csr_hide.prop('hidden', hidden.csr_hide);
                }

                var category = $(this).val();
                if (category === 'TRANSFER TO VENDOR') {
                    setProperties(true, {
                        vcode: false, vphone: false, vaddr: false, vemail: false, security: false,
                        vehicle: false, driver: false, date: false, pic: true, loc: true,
                        table_form_plant: true, naming: true, type_hide: true, employee_hide: true, csr_hide: true
                    }, { vendor_code: true, new_pic: false, location: false, security_guard: true, type: false, vendor_email: true });
                    return_date.val('');
                    new_pic.val('');
                    type.val('');
                } else if (category === 'TRANSFER PLANT TO PLANT') {
                    setProperties(true, {
                        vcode: true, vphone: true, vaddr: true, vemail: true, security: false,
                        vehicle: false, driver: false, date: true, pic: false, loc: false,
                        table_form_plant: false, naming: false, type_hide: true, employee_hide: true, csr_hide: true
                    }, { vendor_code: false, new_pic: true, location: true, security_guard: true, type: false, vendor_email: false });
                    return_date.val('');
                    type.val('');
                } else if (category === 'TRANSFER INSIDE PLANT') {
                    setProperties(true, {
                        vcode: true, vphone: true, vaddr: true, vemail: true, security: true,
                        vehicle: true, driver: true, date: true, pic: false, loc: true,
                        table_form_plant: false, naming: false, type_hide: true, employee_hide: true, csr_hide: true
                    }, { vendor_code: false, new_pic: true, location: false, security_guard: false, type: false, vendor_email: false });
                    return_date.val('');
                    type.val('');
                } else if (category === 'REPAIR TO VENDOR') {
                    setProperties(false, {
                        vcode: false, vphone: false, vaddr: false, vemail: false, security: false,
                        vehicle: false, driver: false, date: false, pic: true, loc: true,
                        table_form_plant: true, naming: true, type_hide: true, employee_hide: true, csr_hide: true
                    }, { vendor_code: true, new_pic: false, location: false, security_guard: true, type: false, vendor_email: true });
                    return_date.val('');
                    new_pic.val('');
                    type.val('');
                } else if (category === 'FA SALES - WITHOUT DISMANTLING') {
                    setProperties(false, {
                        vcode: false, vphone: false, vaddr: false, vemail: false, security: false,
                        vehicle: false, driver: false, date: true, pic: true, loc: true,
                        table_form_plant: true, naming: true, type_hide: false
                    }, { vendor_code: false, new_pic: false, location: false, security_guard: true, type: true, vendor_email: false });
                    return_date.val('');
                    new_pic.val('');
                    type.val('');
                } else {
                    setProperties(true, {
                        vcode: false, vphone: false, vaddr: false, vemail: false, security: false,
                        vehicle: false, driver: false, date: false, pic: true, loc: true,
                        table_form_plant: true, naming: true, type_hide: true, employee_hide: true, csr_hide: true
                    }, { vendor_code: false, new_pic: false, location: false, security_guard: false, type: false, vendor_email: false });
                    return_date.val('');
                    new_pic.val('');
                    type.val('');
                }

                var showHS = (category === 'TRANSFER TO VENDOR' || category === 'REPAIR TO VENDOR');
                $('#th_hs_code').toggle(showHS);
                show_selected_assets();
                checkProforma();
            });

            var initialCategory = $('#category').val();
            var initialShowHS = (initialCategory === 'TRANSFER TO VENDOR' || initialCategory === 'REPAIR TO VENDOR');
            $('#th_hs_code').toggle(initialShowHS);

            $('#select_type').change(function () {
                var employee_hide = $('#employee_hide');
                var return_date = $('#return_date');
                var location = $('#location');
                var vcode_hide = $('#vcode_hide');
                var vphone_hide = $('#vphone_hide');
                var vaddr_hide = $('#vaddr_hide');
                var vemail_hide = $('#vemail_hide');
                var security_hide = $('#security_hide');
                var security_guard = $('#security_guard');
                var vehicle_hide = $('#vehicle_hide');
                var driver_hide = $('#driver_hide');
                var csr_hide = $('#csr_hide');
                var supporting_docs_hide = $('#supporting_docs_hide');

                function setProperties(readonly, hidden, required) {
                    vcode_hide.prop('hidden', hidden.vcode);
                    vphone_hide.prop('hidden', hidden.vphone);
                    vaddr_hide.prop('hidden', hidden.vaddr);
                    vemail_hide.prop('hidden', hidden.vemail);
                    security_hide.prop('hidden', hidden.security);
                    vehicle_hide.prop('hidden', hidden.vehicle);
                    driver_hide.prop('hidden', hidden.driver);
                    employee_hide.prop('hidden', hidden.employee_hide);
                    csr_hide.prop('hidden', hidden.csr_hide);
                    supporting_docs_hide.prop('hidden', hidden.supporting_docs_hide);
                    $('#vendor_code').prop('required', required.vendor_code);
                    $('#vendor_email').prop('required', required.vendor_email);
                    $('#employee').prop('required', required.employee);
                    $('#csr').prop('required', required.csr);
                    $('#supporting_documents').prop('required', required.supporting_documents);
                }

                var type = $(this).val();
                if (type === 'VENDOR') {
                    setProperties(true, {
                        employee_hide: true, vcode: false, vphone: false, vaddr: false, vemail: false, security: false, vehicle: false, driver: false, csr_hide: true, supporting_docs_hide: false
                    }, { vendor_code: true, vendor_email: true, employee: false, csr: false, supporting_documents: true });
                } else if (type === 'EMPLOYEE') {
                    setProperties(true, {
                        vcode: true, vphone: true, vaddr: true, vemail: true, security: false,
                        vehicle: true, driver: true, employee_hide: false, csr_hide: true, supporting_docs_hide: true
                    }, { vendor_code: false, vendor_email: false, employee: true, csr: false, supporting_documents: false });
                } else if (type === 'CSR') {
                    setProperties(true, {
                        vcode: true, vphone: true, vaddr: true, vemail: true, security: false,
                        vehicle: false, driver: false, employee_hide: true, csr_hide: false, supporting_docs_hide: false
                    }, { vendor_code: false, vendor_email: false, employee: false, csr: true, supporting_documents: true });
                } else {
                    setProperties(true, {
                        employee_hide: true, csr_hide: true, supporting_docs_hide: true
                    }, { vendor_code: false, vendor_email: false, employee: false, csr: false, supporting_documents: false });
                }
            });

            $('#security_guard').select2({
                placeholder: "-- SELECT SECURITY GUARD --",
                allowClear: true
            });

            $('#shipping_plant').select2({
                placeholder: "-- SELECT SHIPPING PLANT --",
                allowClear: true
            });

            $('#select_type').select2({
                placeholder: "-- SELECT TYPE --"
            });

            $('#new_pic').select2({
                placeholder: "-- SELECT NEW PIC --",
                allowClear: true
            });

            $('#vendor_code').select2({
                placeholder: "Type to search vendor...",
                allowClear: true,
                minimumInputLength: 3,
                ajax: {
                    url: '@Url.Action("SearchVendor", "Requestor")',
                    dataType: 'json',
                    delay: 100,
                    data: function (params) {
                        return {
                            search: params.term,
                            page: params.page || 1
                        };
                    },
                    processResults: function (data, params) {
                        params.page = params.page || 1;
                        return {
                            results: data.items.map(function(item) {
                                return {
                                    id: item.vendorCode,
                                    text: item.vendorCode + ' - ' + item.vendorName
                                };
                            }),
                            pagination: {
                                more: (params.page * 30) < data.total_count
                            }
                        };
                    },
                    cache: true
                }
            });

            $('#location').select2({
                placeholder: "-- SELECT NEW LOCATION --",
                allowClear: false
            });

            $('#category').select2({
                placeholder: "-- SELECT CATEGORY --",
                allowClear: false
            });

            $('#employee').select2({
                placeholder: "-- SELECT EMPLOYEE --",
                allowClear: false
            });

            $("#vendor_code").change(function () {
                var vendor_code = $(this).val();
                if (vendor_code) {
                    $.ajax({
                        type: "GET",
                        url: "@Url.Action("GET_VENDOR_DATA_GATEPASS", "Requestor")",
                        data: { vendor_code: vendor_code },
                        success: function (data) {
                            if (data !== null) {
                                $("#vendor_name").val(data.vendor_name);
                                $("#vendor_address").val(data.vendor_address);
                                $("#vendor_phone").val(data.vendor_phone);
                                $("#vendor_email").val(data.vendor_email);
                                $("#vendor_batam").val(data.vendor_batam);

                                checkProforma();
                            }
                        }
                    });
                } else {
                    $("#vendor_name").val("");
                    $("#vendor_address").val("");
                    $("#vendor_phone").val("");
                    $("#vendor_email").val("");
                    $("#vendor_batam").val("");
                    checkProforma();
                }
            });

            $("input[name=charged_by]").change(function () {
                let charged_by = $("input[name=charged_by]:checked").val();

                if (charged_by == "JHO") {
                    $("select[name=courier_name]").val("").prop("disabled", true).removeAttr("required");
                    $("input[name=courier_acc_no]").val("JHO").attr("readonly","readonly").removeAttr("required");
                } else if (charged_by == "Receiver") {
                    $("select[name=courier_name]").val("").prop("disabled", false).attr("required","required");
                    $("input[name=courier_acc_no]").val("").removeAttr("readonly").attr("required","required");
                } else {
                    $("select[name=courier_name]").val("").prop("disabled", true).removeAttr("required");
                    $("input[name=courier_acc_no]").val("").attr("readonly","readonly").removeAttr("required");
                }
            })

            $("input[name=freight_charges]").change(function () {
                let freight_charges = $("input[name=freight_charges]:checked").val();

                $("#incoterms_collect_options, #incoterms_prepaid_options").hide();
                $("#incoterms_section").show();
                $("input[name=incoterms]").prop('checked', false).removeAttr('required');

                if (freight_charges == "Freight Collect") {
                    $("#incoterms_section").removeClass("hidden");
                    $("#incoterms_collect_options").show();
                    $("#incoterms_collect_options input[type=radio]").attr('required', 'required');
                } else if (freight_charges == "Freight Prepaid") {
                    $("#incoterms_section").removeClass("hidden");
                    $("#incoterms_prepaid_options").show();
                    $("#incoterms_prepaid_options input[type=radio]").attr('required', 'required');
                }
            });

            let gatepassData = localStorage.getItem('gatepassData');
            if (gatepassData) {
                try {
                    let data = JSON.parse(gatepassData);
                    isFromDisposal = true;

                    if (data.id_order) {
                        $('#id_order').val(data.id_order);
                    }

                    $('#category').val(data.category).trigger('change');
                    $('#category').prop('disabled', true);

                    $('#select_type').val(data.type).trigger('change');
                    $('#select_type').prop('disabled', true);

                    $('input[name=find_asset]').prop('disabled', true);
                    $('input[name=find_asset]').attr('placeholder', 'Assets auto-loaded from disposal');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'category',
                        value: data.category
                    }).appendTo('form#form_gatepass');

                    $('<input>').attr({
                        type: 'hidden',
                        name: 'type',
                        value: data.type
                    }).appendTo('form#form_gatepass');

                    if (data.assets && data.assets.length > 0) {
                        let addPromises = data.assets.map(function(asset) {
                            return new Promise(function(resolve, reject) {
                                $.ajax({
                                    type: "POST",
                                    url: "@Url.Action("ADD_TEMP_GATEPASS_DISPOSAL")",
                                    data: {
                                        asset_no: asset.asset_no,
                                        asset_subnumber: asset.asset_subnumber,
                                        naming_output: "-"
                                    }
                                }).done(function(res) {
                                    if (res === "success") {
                                        resolve();
                                    } else {
                                        reject(res);
                                    }
                                }).fail(function(err) {
                                    reject(err);
                                });
                            });
                        });

                        Promise.all(addPromises).then(function() {
                            show_selected_assets();
                            localStorage.removeItem('gatepassData');

                            Swal.fire({
                                icon: 'info',
                                title: 'Auto-filled from Disposal',
                                html: 'Category, Type, and Assets have been automatically filled from disposal request.<br><br><strong>Please upload Gate Pass images for each asset before submitting.</strong>',
                                timer: 5000,
                                showConfirmButton: true
                            });
                        }).catch(function(error) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'Failed to add some assets: ' + error
                            });
                            localStorage.removeItem('gatepassData');
                        });
                    }
                } catch (e) {
                    console.error('Error parsing gatepass data:', e);
                    localStorage.removeItem('gatepassData');
                }
            }
        });

        $(document).ready(function () {
            $(document).on('click', function (e) {
                if (!isFromDisposal) {
                    if ($(e.target).closest('input[name=find_asset]').length) {
                        $("div.asset_suggestion").toggle();
                    }
                    else if (!$(e.target).closest('.asset_suggestion').length) {
                        $("div.asset_suggestion").hide();
                    }
                }
            });

            $("input[name=find_asset]").keyup(function () {
                if (!isFromDisposal) {
                    let asset_no = $(this).val();

                    if (asset_no.length < 1) {
                        $("table#table_asset_suggestion tbody").html(
                            "<tr><td class='text-center' colspan='4'>No Data</td></tr>"
                        );
                        $("div.asset_suggestion").hide();
                        return;
                    }

                    $.ajax({
                        type: "GET",
                        url: "@Url.Action("SearchAssetGatepass")",
                        data: {
                            asset_no: asset_no
                        }
                    }).done(function (res) {
                        $("table#table_asset_suggestion tbody").html("");
                        suggested_assets = res.items;
                        let asset_list = [];
                        if (suggested_assets.length > 0) {
                            suggested_assets.forEach((item, i) => {
                                asset_list.push(
                                    "<tr>" +
                                    "<td><a class='btn btn-sm btn-success' onclick='select_cat_modal(`" + i + "`)'><i class='fa fa-plus'></i></a></td>" +
                                    "<td>" + item.asset_no + "</td>" +
                                    "<td>" + item.asset_subnumber + "</td>" +
                                    "<td>" + item.asset_desc + "</td>" +
                                    "</tr>"
                                );
                            });
                        }
                        else {
                            asset_list.push(
                                "<tr>" +
                                "<td class='text-center' colspan='4'>No Data</td>" +
                                "</tr>"
                            );
                        }
                        $("table#table_asset_suggestion tbody").html(asset_list.join(""));
                    })
                }
            })

            if (preselect_assets != "") {
                $("input[name=find_asset]").val(preselect_assets);
                $("input[name=find_asset]").click();
                $('input[name=find_asset]').trigger($.Event('keyup', { keyCode: 65 }));
                setTimeout(function () {
                    select_cat_modal('0');
                }, 1000)
            }

            $('#file_imgs').on('change', function () {
                var files = $(this)[0].files;
                var valid = true;

                for (var i = 0; i < files.length; i++) {
                    var file = files[i];

                    if (!file.type.startsWith('image/')) {
                        valid = false;
                        break;
                    }
                }

                if (!valid) {
                    swal.fire("Error!", "One or more files are not images. Please upload only image files.", "error");
                    $(this).val('');
                }
            });

            $("button[name=btn_select_cat]").click(function () {
                let index_asset = $("input[name=index_asset]").val();
                let naming_output = $("input[name=naming_output]").val();
                let asset_imgs = $("#asset_imgs")[0].files[0];

                if (!asset_imgs) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops...',
                        text: 'You must upload an image!'
                    });
                    return;
                }

                let validExtensions = ['image/png', 'image/jpeg', 'image/jpg'];
                if (!validExtensions.includes(asset_imgs.type)) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid file type',
                        text: 'Only .png, .jpg, and .jpeg files are allowed!'
                    });
                    return;
                }

                let $btn = $(this);
                $btn.prop('disabled', true).html("<i class='fas fa-spinner fa-spin'></i> Processing...");

                add_to_list(index_asset, naming_output, asset_imgs, $btn);
            });

            $('#file_support').on('change', function () {
                const fileCount = this.files.length;
                if (fileCount > 2) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Upload Limit Exceeded',
                        text: 'You can only upload a maximum of 2 PDF files.',
                    });

                    $(this).val('');
                }
            });

            $('#upload_asset_img').on('change', function () {
                var files = $(this)[0].files;
                var valid = true;

                for (var i = 0; i < files.length; i++) {
                    var file = files[i];

                    if (!file.type.startsWith('image/')) {
                        valid = false;
                        break;
                    }
                }

                if (!valid) {
                    Swal.fire("Error!", "Please upload only image files (png/jpg/jpeg).", "error");
                    $(this).val('');
                }
            });

            $('#supporting_documents').on('change', function () {
                const fileCount = this.files.length;
                if (fileCount < 1) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Minimum Files Required',
                        text: 'You must upload at least 1 supporting document.',
                    });
                    $(this).val('');
                } else if (fileCount > 3) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Upload Limit Exceeded',
                        text: 'You can only upload a maximum of 3 files.',
                    });
                    $(this).val('');
                }
            });
        });

        $(document).on('input', '.hs-code-input', function() {
            this.value = this.value.replace(/[^0-9]/g, '').substring(0, 10);
            let asset_no = $(this).data('asset');
            let asset_subnumber = $(this).data('subnumber');
            let hs_code = $(this).val();

            $.ajax({
                type: "POST",
                url: "@Url.Action("UPDATE_HS_CODE_TEMP")",
                data: {
                    asset_no: asset_no,
                    asset_subnumber: asset_subnumber,
                    hs_code: hs_code
                }
            });
        });

        $("form#form_gatepass").submit(function (e) {
            e.preventDefault();

            if (selected_assets.length === 0) {
                Swal.fire("Failed!", "No Asset Selected!!", "error");
                return;
            }

            let assetsWithoutImage = selected_assets.filter(asset => !asset.gp_before || asset.gp_before === "");

            if (assetsWithoutImage.length > 0) {
                let assetList = assetsWithoutImage.map(a => a.asset_no + ";" + a.asset_subnumber).join(", ");
                Swal.fire({
                    icon: 'warning',
                    title: 'Missing Images',
                    html: 'Please upload images for the following assets before submitting:<br><br><strong>' + assetList + '</strong>',
                    confirmButtonText: 'OK'
                });
                return;
            }

            let formData = new FormData(this);

            let id_order = $('#id_order').val();
            if (id_order && id_order.trim() !== '') {
                formData.append('id_order', id_order);
            }
            let needProforma = false;
            let category = $("select[name=category]").val();
            let vendor_batam = $("#vendor_batam").val();

            if (vendor_batam === "Non Batam") {
                if (category === "TRANSFER TO VENDOR" || category === "REPAIR TO VENDOR") {
                    needProforma = true;
                } else if (category === "FA SALES - WITHOUT DISMANTLING" && $("select[name=type]").val() === "VENDOR") {
                    needProforma = true;
                }
            }

            let actionUrl = needProforma ?
                "@Url.Action("ADD_NEW_GATEPASS_WITH_PROFORMA")" :
                "@Url.Action("ADD_NEW_GATEPASS")";

            Swal.fire({
                title: 'Confirm',
                text: "Are you sure?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                confirmButtonText: 'Yes!',
                cancelButtonText: 'No!',
                showLoaderOnConfirm: true,
                preConfirm: function () {
                    return new Promise(function (resolve, reject) {
                        $.ajax({
                            url: actionUrl,
                            type: 'POST',
                            data: formData,
                            cache: false,
                            contentType: false,
                            processData: false
                        }).done(function (res) {
                            let arr = res.split(";");
                            if (arr[0] == "success") {
                                let email_remark = "";
                                if (arr[1] != "success") {
                                    email_remark = "Failed to Send Email Approval: " + arr[1];
                                }
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Done!!',
                                    html: arr[2] + "<br>" + email_remark
                                }).then(function () {
                                    window.location = "@Url.Action("GatePassList")";
                                })
                            }
                            else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!!',
                                    html: res,
                                    width: 800
                                }).then(function () {

                                })
                            }
                        }).fail(function (err) {
                            swal.fire("Error", "Upload Failed -> " + err, "error");
                        })
                    })
                },
                allowOutsideClick: () => !Swal.isLoading()
            });
        });

        function resetSelectModal() {
            $("#lot").val('').trigger('change');
        }

        function select_cat_modal(i) {
            if (isFromDisposal) {
                return;
            }

            for (let j = 0; j < selected_assets.length; j++) {
                if (selected_assets[j].asset_no === suggested_assets[i].asset_no && selected_assets[j].asset_subnumber === suggested_assets[i].asset_subnumber) {
                    swal.fire("Failed!", "Asset already selected!!", "warning");
                    return;
                }
            }
            const status_gatepass = suggested_assets[i].status_gatepass;
            const gatepass_process = ['OPEN', 'TRANSFER', 'REPAIR', 'APPROVED', 'Waiting Confirmation by FIN SS'];
            if (gatepass_process.some(process => status_gatepass.includes(process))) {
                swal.fire("Failed!", "Asset already in gatepass process!!", "warning");
                return;
            }

            refresh_naming_table();
            resetSelectModal();
            $("input[name=index_asset]").val(i);
            $("p#text_asset_no").html(suggested_assets[i].asset_no);
            $("p#text_asset_subnumber").html(suggested_assets[i].asset_subnumber);
            $("p#text_asset_desc").html(suggested_assets[i].asset_desc);
            $("input[name=asset_imgs]").val('');
            create_naming();
            $("div#select_cat_modal").modal("show");
            $("div.asset_suggestion").hide();
        }

        $(document).ready(function () {
            $('#lot').select2({
                placeholder: "",
                dropdownParent: $('#select_cat_modal')
            });

            $('#level').select2({
                placeholder: "",
                dropdownParent: $('#select_cat_modal'),
                templateSelection: function (data) {
                    return data.text.length > 20 ? data.text.substr(0, 20) + '...' : data.text;
                }
            });

            $("select#lot").on("change", function () {
                const selectedLot = $(this).val();

                $("select#level").empty().append('<option value=""></option>');
                if (lotFamilyGroup[selectedLot]) {
                    lotFamilyGroup[selectedLot].forEach(function (name) {
                        $("select#level").append(`<option value="${name}">${name}</option>`);
                    });
                }
            });
        });

        $("table#table_form_plant").on("change keyup", "select, input", function () {
            const update = $(this);
            create_naming();
        })

        $("input[name=ship_mode]").change(function(){
            let ship_mode = $("input[name=ship_mode]:checked").val();

            $("input[name=freight_charges]").prop('checked', false);
            $("input[name=incoterms]").prop('checked', false).removeAttr('required');
            $("#incoterms_section, #incoterms_collect_options, #incoterms_prepaid_options").hide();

            if (ship_mode == "Courier") {
                $("input[name=charged_by]").prop('checked', false).removeAttr("disabled").attr("required","required");
                $("#courier_charges").removeAttr("hidden","hidden");
                $("#freight_charges").removeAttr("hidden","hidden");
                $("input[name=invoice_payment]").prop('checked', false);
                $("#foc").removeAttr("disabled","disabled");
            }
            else if (ship_mode == "Others") {
                $("#courier_charges").attr("hidden","hidden");
                $("#freight_charges").attr("hidden","hidden");
                $("#incoterms_section").attr("hidden","hidden");
                $("input[name=freight_charges]").prop('checked', false);
                $("#foc").prop('checked', true);
            }
            else {
                $("input[name=charged_by]").prop('checked', false).attr("disabled", "disabled").removeAttr("required");
                $("#courier_charges").attr("hidden","hidden");
                $("#freight_charges").removeAttr("hidden");
                $("#incoterms_section").removeAttr("hidden");
                $("input[name=invoice_payment]").prop('checked', false);
                $("#foc").removeAttr("disabled","disabled");
            }
            $("input[name=charged_by]").change();
        })

        function refresh_naming_table() {
            $('#table_form_plant tr').each(function () {
                create_naming();
            });
        }

        function create_naming() {
            let lot = document.getElementById('lot').value;
            let floor = document.getElementById('plant').value;
            let family_station_area = document.getElementById('level').value;
            let asset_desc = document.getElementById('new_location').value;
            let category = document.getElementById('category').value;

            let naming;
            if (category === "TRANSFER PLANT TO PLANT" || category === "TRANSFER INSIDE PLANT") {
                naming = `${lot}/${floor}/${family_station_area}/${asset_desc}`;
            } else {
                naming = "-";
            }

            document.getElementById('naming_output').value = naming;
        }

        function add_to_list(i, naming_output, asset_imgs, $btn) {
            let formData = new FormData();
            formData.append("asset_no", suggested_assets[i].asset_no);
            formData.append("asset_subnumber", suggested_assets[i].asset_subnumber);
            formData.append("naming_output", naming_output);
            formData.append("asset_imgs", asset_imgs);

            $.ajax({
                type: "POST",
                url: "@Url.Action("ADD_TEMP_GATEPASS")",
                data: formData,
                processData: false,
                contentType: false,
            }).done(function (res) {
                if (res == "success") {
                    show_selected_assets();
                    $("div.asset_suggestion").hide();
                    $("div#select_cat_modal").modal("hide");
                } else {
                    swal.fire("Error", res, "error");
                }
            }).fail(function () {
                swal.fire("Error", "Request failed. Please try again.", "error");
            }).always(function () {
                if ($btn) {
                    $btn.prop('disabled', false).html("<i class='fas fa-check'></i> Select");
                }
            });
        }

        function show_selected_assets() {
            $.ajax({
                type: "GET",
                url: "@Url.Action("GET_TEMP_GATEPASS")",
            }).done(function (res) {
                selected_assets = res;
                let asset_list = [];
                let book_val = 0;
                let gross_val = 0;
                let no = 0;
                $("table#table_asset_selected tbody").html("");

                let category = $("select[name=category]").val();
                let showHS = (category === 'TRANSFER TO VENDOR' || category === 'REPAIR TO VENDOR');
                let colCount = showHS ? 8 : 7;

                if (selected_assets.length > 0) {
                    selected_assets.forEach((item, i) => {
                        no++;
                        book_val = book_val + item.curr_bk_val;
                        gross_val = gross_val + item.current_apc;

                        let hsCell = "";
                        if (showHS) {
                            hsCell = "<td class='text-center align-middle'><input type='text' class='form-control hs-code-input' data-asset='" + item.asset_no + "' data-subnumber='" + item.asset_subnumber + "' maxlength='10' pattern='[0-9]*' placeholder='HS Code' value='" + (item.hs_code || '') + "' /></td>";
                        }

                        let imgCell = "";
                        if (item.gp_before && item.gp_before !== "") {
                            imgCell = "<td class='text-center align-middle'>" +
                                      "<div style='display: flex; gap: 5px; justify-content: center;'>" +
                                      "<a title='View Image' href='../Upload/GatePass/" + item.gp_before + "' target='_blank' class='btn btn-sm btn-success'>" +
                                      "<i class='fa fa-image'></i></a>" +
                                      "<button title='Reupload Image' type='button' class='btn btn-sm btn-warning' onclick='upload_image_modal(" + item.id_temp + ", \"" + item.asset_no + "\", \"" + item.asset_subnumber + "\")'>" +
                                      "<i class='fa fa-upload'></i></button>" +
                                      "</div>" +
                                      "</td>";
                        } else {
                            imgCell = "<td class='text-center align-middle'>" +
                                      "<button type='button' class='btn btn-sm btn-primary' onclick='upload_image_modal(" + item.id_temp + ", \"" + item.asset_no + "\", \"" + item.asset_subnumber + "\")'>" +
                                      "<i class='fa fa-upload'></i> Upload Image</button>" +
                                      "</td>";
                        }

                        asset_list.push(
                            "<tr>" +
                            "<td class='text-center align-middle'>" + no + "</td>" +
                            "<td class='text-center align-middle'>" + item.asset_no + "</td>" +
                            "<td class='text-center align-middle'>" + item.asset_subnumber + "</td>" +
                            "<td class='text-center align-middle'>" + item.asset_desc + "</td>" +
                            hsCell +
                            "<td class='text-center align-middle'>" + item.naming_output + "</td>" +
                            imgCell +
                            "<td class='text-center align-middle'><button type='button' class='btn btn-sm btn-danger' onclick='remove_from_list(`" + item.id_temp + "`)'><i class='fa fa-minus'></i></button></td>" +
                            "</tr>"
                        );
                    });
                }
                else {
                    asset_list.push(
                        "<tr>" +
                        "<td class='text-center' colspan='" + colCount + "'>No Data</td>" +
                        "</tr>"
                    );
                }
                $("table#table_asset_selected tbody").html(asset_list.join(""));
                $("input[name=book_val]").val(book_val.toLocaleString());
                $("input[name=gross_val]").val(gross_val.toLocaleString());

                checkProforma();
                loadingComplete();
            })
        }

        function upload_image_modal(id_temp, asset_no, asset_subnumber) {
            $("input[name=upload_id_temp]").val(id_temp);
            $("input[name=upload_asset_no]").val(asset_no);
            $("input[name=upload_asset_subnumber]").val(asset_subnumber);
            $("span#upload_display_asset_no").text(asset_no);
            $("span#upload_display_subnumber").text(asset_subnumber);
            $("input#upload_asset_img").val('');
            $("#upload_image_modal").modal("show");
        }

        $(document).on('submit', 'form#form_upload_image', function(e) {
            e.preventDefault();

            let id_temp = $("input[name=upload_id_temp]").val();
            let asset_no = $("input[name=upload_asset_no]").val();
            let asset_subnumber = $("input[name=upload_asset_subnumber]").val();
            let fileInput = document.getElementById('upload_asset_img');
            let asset_img = fileInput.files[0];

            if (!asset_img) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Please select an image file!'
                });
                return;
            }

            let formData = new FormData();
            formData.append('id_temp', id_temp);
            formData.append('asset_no', asset_no);
            formData.append('asset_subnumber', asset_subnumber);
            formData.append('asset_img', asset_img);

            $.ajax({
                type: "POST",
                url: "@Url.Action("UPLOAD_TEMP_GATEPASS_IMAGE")",
                data: formData,
                processData: false,
                contentType: false,
            }).done(function (res) {
                if (res === "success") {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: 'Image uploaded successfully!',
                        timer: 2000
                    });
                    $("#upload_image_modal").modal("hide");
                    show_selected_assets();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: res.replace('error;', '')
                    });
                }
            }).fail(function(err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Upload failed: ' + err.responseText
                });
            });
        });

        function remove_from_list(id_temp) {
            $.ajax({
                type: "POST",
                url: "@Url.Action("DELETE_TEMP_GATEPASS", "Requestor")",
                data: {
                    id_temp: id_temp
                }
            }).done(function (res) {
                if (res == "success") {
                    show_selected_assets();
                }
                else {
                    swal.fire("Error", res, "error");
                }
            })
        }
    </script>
}