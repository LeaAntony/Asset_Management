@using Asset_Management.Function
@using Microsoft.AspNetCore.Http;
@using System.Security.Claims;
@inject IHttpContextAccessor HttpContextAccessor
@{
    string url = ViewContext.HttpContext.Request.Path;
    string lastSegment = url.Split('/').Last();

    string sesa_id = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    string user_level = User.FindFirst("asset_management_level")?.Value;
    string user_role = User.FindFirst("asset_management_role")?.Value;
    string name = User.FindFirst("asset_management_name")?.Value;
    string user_role_manage_user = User.FindFirst("asset_management_role_manage_user")?.Value;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Asset Management</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico">

    <link href="~/lib/adminlte/plugins/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/fontawesome-free/css/fontawesome.min.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/fontawesome-free/css/solid.min.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />
    <link href="~/lib/select2/css/select2.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/DataTables-1.11.3/css/dataTables.bootstrap4.min.css" />
    <link rel="stylesheet" href="~/lib/datepicker/datepicker3.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-select/dist/css/bootstrap-select.css" />
    <link href="~/lib/adminlte/dist/css/adminlte.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/sweetalert2/sweetalert2.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/chart.js/Chart.min.css" rel="stylesheet" />
    <link href="~/lib/adminlte/plugins/overlayScrollbars/css/OverlayScrollbars.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/custom-fonts.css?v=1.1" />
</head>
<body class="sidebar-mini layout-fixed layout-navbar-fixed sidebar-collapse" style="padding: 0 !important; margin: 0 !important; ">
    <div class="wrapper">
        <nav class="main-header navbar navbar-expand border-bottom navbar-light bg-light fh-fixedHeader">
            <ul class="navbar-nav align-items-center">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#">
                        <i class="fa fa-bars" aria-hidden="true"></i>
                    </a>
                </li>
                <li class="nav-item mx-auto">
                    <img src="~/images/logo/amt_black.png" alt="Logo" class="nav-logo" style="height: 35px !important;">
                </li>
            </ul>

            <div class="ml-auto d-flex align-items-center">
                <div class="dropdown">
                    <div class="d-flex align-items-center" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer;">
                        <div class="d-flex flex-column me-2">
                            <h8 class="text-gray" style="line-height: 1 !important;">@name</h8>
                            <h8 class="text-gray text-right" style="line-height: 1 !important;"><small>@sesa_id</small></h8>
                        </div>
                        <div class="image">
                            <img src="~/assets/header.png"
                                 class="img-circle bg-white"
                                 alt="User Image"
                                 style="width:40px; height:40px; object-fit:cover;">
                        </div>
                    </div>

                    <ul class="dropdown-menu dropdown-menu-end mt-2">
                        <li class="dropdown-item disabled">
                            <small><strong>Level:</strong> @char.ToUpper(user_level?[0] ?? ' ')@user_level?.Substring(1).ToLower()</small>
                        </li>
                        <li class="dropdown-item disabled">
                            <small><strong>Role:</strong> @char.ToUpper(user_role?[0] ?? ' ')@user_role?.Substring(1).ToLower()</small>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a href="@Url.Action("Logout", "Home")" class="dropdown-item d-flex align-items-center">
                                <i class="nav-icon fas fa-sign-out-alt me-2"></i>
                                Log Out
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <aside class="main-sidebar sidebar-dark-success elevation-5">
            <a href="#" class="brand-link text-center">
                <img id="sidebar-brand-img"
                                 src="@Url.Content("~/images/logo/aml_white.png")"
                     alt="Asset Management Logo"
                     style="opacity: .8; transition: opacity 0.3s ease; max-height: 29px;">
            </a>
            <div class="sidebar">
                <nav class="mt-3">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" data-accordion="true" role="menu">
                        <li class="nav-item">
                            <a href="@Url.Action("Dashboard", "Home")" class="nav-link @Html.IsActive("Home", "Dashboard")">
                                <i class="nav-icon fas fa-chart-bar"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("DashboardNonAsset", "Home")" class="nav-link @Html.IsActive("Home", "DashboardNonAsset")">
                                <i class="nav-icon fas fa-chart-bar"></i>
                                <p>Dashboard Non-Asset</p>
                            </a>
                        </li>

                        @if (user_level == "requestor")
                        {
                            string checkMenuReqAssets = Html.IsMenuopen("Requestor", "AssetStandardName") + Html.IsMenuopen("Requestor", "AssetList") + Html.IsMenuopen("Requestor", "AssetAUC") + Html.IsMenuopen("Requestor", "SummaryCount");
                            string checkActiveReqAssets = Html.IsActive("Requestor", "AssetStandardName") + Html.IsActive("Requestor", "AssetList") + Html.IsActive("Requestor", "AssetAUC") + Html.IsActive("Requestor", "SummaryCount");

                            string checkMenuReqDisposal = Html.IsMenuopen("Requestor", "FormDisposal") + Html.IsMenuopen("Requestor", "DisposalList");
                            string checkActiveReqDisposal = Html.IsActive("Requestor", "FormDisposal") + Html.IsActive("Requestor", "DisposalList");

                            string checkMenuReqTransfer = Html.IsMenuopen("Requestor", "GatePassNew") + Html.IsMenuopen("Requestor", "GatePassList") + Html.IsMenuopen("NewPic", "PicConfirm") + Html.IsMenuopen("Shipping", "ShippingList");
                            string checkActiveReqTransfer = Html.IsActive("Requestor", "GatePassNew") + Html.IsActive("Requestor", "GatePassList") + Html.IsActive("NewPic", "PicConfirm") + Html.IsActive("Shipping", "ShippingList");

                            string checkMenuReqTransferNA = Html.IsMenuopen("Requestor", "GatePassNonAsset") + Html.IsMenuopen("Requestor", "GatePassNonAssetList") + Html.IsMenuopen("Shipping", "ShippingNonAssetList");
                            string checkActiveReqTransferNA = Html.IsActive("Requestor", "GatePassNonAsset") + Html.IsActive("Requestor", "GatePassNonAssetList") + Html.IsActive("Shipping", "ShippingNonAssetList");

                            <li class="nav-header">Assets</li>
                            <li class="nav-item has-treeview @checkMenuReqAssets">
                                <a href="#" class="nav-link @checkActiveReqAssets">
                                    <i class="nav-icon fas fa-boxes"></i>
                                    <p>Assets<i class="fas fa-angle-left right"></i></p>
                                    <span id="assetsTotalBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a href="@Url.Action("AssetList", "Requestor")" class="nav-link @Html.IsActive("Requestor", "AssetList")">
                                            <i class="ml-2 nav-icon fas fa-table"></i>
                                            <p>Asset List</p>
                                            <span id="assetListRequestorBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-header">Transfer</li>
                            <li class="nav-item has-treeview @checkMenuReqTransfer">
                                <a href="#" class="nav-link @checkActiveReqTransfer">
                                    <i class="nav-icon fas fa-truck"></i>
                                    <p>Asset Transfer<i class="fas fa-angle-left right"></i></p>
                                    <span id="transferTotalBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassNew", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassNew")">
                                            <i class="ml-2 nav-icon fas fa-file-alt"></i>
                                            <p>Form Asset Transfer</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassList", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassList")">
                                            <i class="ml-2 nav-icon fas fa-list"></i>
                                            <p>My Transfer List</p>
                                            <span id="gatepassListRequestorBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                    @if (user_role == "shipping")
                                    {
                                        <li class="nav-item">
                                            <a href="@Url.Action("ShippingList", "Shipping")" class="nav-link @Html.IsActive("Shipping", "ShippingList")">
                                                <i class="ml-2 nav-icon fas fa-ship"></i>
                                                <p>Shipping List</p>
                                                <span id="shippingListRequestorBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>

                            <li class="nav-item has-treeview @checkMenuReqTransferNA">
                                <a href="#" class="nav-link @checkActiveReqTransferNA">
                                    <i class="nav-icon fas fa-truck"></i>
                                    <p>Non-Asset Transfer<i class="fas fa-angle-left right"></i></p>
                                    <span id="nonAssetTransferTotalBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassNonAsset", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassNonAsset")">
                                            <i class="ml-2 nav-icon fas fa-file-alt"></i>
                                            <p>Form Non-Asset Transfer</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassNonAssetList", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassNonAssetList")">
                                            <i class="ml-2 nav-icon fas fa-list"></i>
                                            <p>My Transfer List</p>
                                            <span id="gatepassNonAssetListRequestorBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                    @if (user_role == "shipping")
                                    {
                                        <li class="nav-item">
                                            <a href="@Url.Action("ShippingNonAssetList", "Shipping")" class="nav-link @Html.IsActive("Shipping", "ShippingNonAssetList")">
                                                <i class="ml-2 nav-icon fas fa-ship"></i>
                                                <p>Shipping List</p>
                                                <span id="shippingNonAssetListRequestorBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        @if (user_level == "approver")
                        {

                            string checkMenuApprDisposal = Html.IsMenuopen("Requestor", "FormDisposal") + Html.IsMenuopen("Requestor", "DisposalList") + Html.IsMenuopen("Approver", "DisposalList");
                            string checkActiveApprDisposal = Html.IsActive("Requestor", "FormDisposal") + Html.IsActive("Requestor", "DisposalList") + Html.IsActive("Approver", "DisposalList");

                            string checkMenuApprTransfer = Html.IsMenuopen("Requestor", "GatePassNew") + Html.IsMenuopen("Requestor", "GatePassList") + Html.IsMenuopen("Approver", "GatePassList") + Html.IsMenuopen("NewPic", "PicConfirm");
                            string checkActiveApprTransfer = Html.IsActive("Requestor", "GatePassNew") + Html.IsActive("Requestor", "GatePassList") + Html.IsActive("Approver", "GatePassList") + Html.IsActive("NewPic", "PicConfirm");

                            string checkMenuApprTransferNA = Html.IsMenuopen("Requestor", "GatePassNonAsset") + Html.IsMenuopen("Requestor", "GatePassNonAssetList") + Html.IsMenuopen("Approver", "GatePassNonAssetList");
                            string checkActiveApprTransferNA = Html.IsActive("Requestor", "GatePassNonAsset") + Html.IsActive("Requestor", "GatePassNonAssetList") + Html.IsActive("Approver", "GatePassNonAssetList");

                            string checkMenuApprAssets = (user_role == "fbp")
                            ? Html.IsMenuopen("Finance", "AssetList") + Html.IsMenuopen("Approver", "AssetAUC") + Html.IsMenuopen("Finance", "SummaryCount")
                            : Html.IsMenuopen("Requestor", "AssetList") + Html.IsMenuopen("Requestor", "AssetAUC") + Html.IsMenuopen("Requestor", "SummaryCount");
                            string checkActiveApprAssets = (user_role == "fbp")
                            ? Html.IsActive("Finance", "AssetList") + Html.IsActive("Approver", "AssetAUC") + Html.IsActive("Finance", "SummaryCount")
                            : Html.IsActive("Requestor", "AssetList") + Html.IsActive("Requestor", "AssetAUC") + Html.IsActive("Requestor", "SummaryCount");

                            string checkMenuApprFinance = (user_role == "fbp")
                            ? Html.IsMenuopen("Finance", "ReconList") + Html.IsMenuopen("Finance", "RateEuroList")
                            : "";
                            string checkActiveApprFinance = (user_role == "fbp")
                            ? Html.IsActive("Finance", "ReconList") + Html.IsActive("Finance", "RateEuroList")
                            : "";


                            <li class="nav-header">Assets</li>
                            <li class="nav-item has-treeview @checkMenuApprAssets">
                                <a href="#" class="nav-link @checkActiveApprAssets">
                                    <i class="nav-icon fas fa-boxes"></i>
                                    <p>Assets<i class="fas fa-angle-left right"></i></p>
                                </a>
                                <ul class="nav nav-treeview">
                                    @if (user_role == "fbp")
                                    {
                                        <li class="nav-item">
                                            <a href="@Url.Action("AssetList", "Finance")" class="nav-link @Html.IsActive("Finance", "AssetList")">
                                                <i class="ml-2 nav-icon fas fa-table"></i>
                                                <p>Asset List</p>
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="nav-item">
                                            <a href="@Url.Action("AssetList", "Requestor")" class="nav-link @Html.IsActive("Requestor", "AssetList")">
                                                <i class="ml-2 nav-icon fas fa-table"></i>
                                                <p>Asset List</p>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>

                            <li class="nav-header">Transfer</li>
                            <li class="nav-item has-treeview @checkMenuApprTransfer">
                                <a href="#" class="nav-link @checkActiveApprTransfer">
                                    <i class="nav-icon fas fa-truck"></i>
                                    <p>Asset Transfer<i class="fas fa-angle-left right"></i></p>
                                    <span id="transferTotalApproverBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassNew", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassNew")">
                                            <i class="ml-2 nav-icon fas fa-file-alt"></i>
                                            <p>Form Asset Transfer</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassList", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassList")">
                                            <i class="ml-2 nav-icon fas fa-list"></i>
                                            <p>Transfer List</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassList", "Approver")" class="nav-link @Html.IsActive("Approver", "GatePassList")">
                                            <i class="ml-2 nav-icon fas fa-check-double"></i>
                                            <p>Transfer Approval List</p>
                                            <span id="gatepassApprovalApproverBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-item has-treeview @checkMenuApprTransferNA">
                                <a href="#" class="nav-link @checkActiveApprTransferNA">
                                    <i class="nav-icon fas fa-truck"></i>
                                    <p>Non-Asset Transfer<i class="fas fa-angle-left right"></i></p>
                                    <span id="nonAssetTransferTotalApproverBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassNonAsset", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassNonAsset")">
                                            <i class="ml-2 nav-icon fas fa-file-alt"></i>
                                            <p>Form Non-Asset Transfer</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassNonAssetList", "Requestor")" class="nav-link @Html.IsActive("Requestor", "GatePassNonAssetList")">
                                            <i class="ml-2 nav-icon fas fa-list"></i>
                                            <p>My Transfer List</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatePassNonAssetList", "Approver")" class="nav-link @Html.IsActive("Approver", "GatePassNonAssetList")">
                                            <i class="ml-2 nav-icon fas fa-check-double"></i>
                                            <p>Transfer Approval List</p>
                                            <span id="gatepassNonAssetApprovalApproverBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                        }

                        @if (user_level == "finance")
                        {
                            string checkMenuFinAssets = Html.IsMenuopen("Finance", "AssetList") + Html.IsMenuopen("Finance", "AssetAUC") + Html.IsMenuopen("Finance", "SummaryCount") + Html.IsMenuopen("Requestor", "AssetStandardName");
                            string checkActiveFinAssets = Html.IsActive("Finance", "AssetList") + Html.IsActive("Finance", "AssetAUC") + Html.IsActive("Finance", "SummaryCount") + Html.IsActive("Requestor", "AssetStandardName");

                            string checkMenuFinInvoice = Html.IsMenuopen("Finance", "CreateInvoice") + Html.IsMenuopen("Finance", "InvoiceList") + Html.IsMenuopen("Finance", "InvoiceApprovalList");
                            string checkActiveFinInvoice = Html.IsActive("Finance", "CreateInvoice") + Html.IsActive("Finance", "InvoiceList") + Html.IsActive("Finance", "InvoiceApprovalList");

                            string checkMenuFinOps = Html.IsMenuopen("Finance", "Gatepass") + checkMenuFinInvoice + Html.IsMenuopen("Finance", "GatepassNonAsset") + Html.IsMenuopen("Finance", "DisposalList") + Html.IsMenuopen("Finance", "ReconList") + Html.IsMenuopen("Finance", "RateEuroList");
                            string checkActiveFinOps = Html.IsActive("Finance", "Gatepass") + checkActiveFinInvoice + Html.IsActive("Finance", "GatepassNonAsset") + Html.IsActive("Finance", "DisposalList") + Html.IsActive("Finance", "ReconList") + Html.IsActive("Finance", "RateEuroList");

                            string checkMenuMasterData = Html.IsMenuopen("Finance", "MstData_Location") + Html.IsMenuopen("Finance", "MstData_Machine") + Html.IsMenuopen("Finance", "MstData_Vendor") + Html.IsMenuopen("Finance", "MstData_VendorGatepass") + Html.IsMenuopen("Finance", "MstData_ProductFamily");
                            string checkActiveMasterData = Html.IsActive("Finance", "MstData_Location") + Html.IsActive("Finance", "MstData_Machine") + Html.IsActive("Finance", "MstData_Vendor") + Html.IsActive("Finance", "MstData_VendorGatepass") + Html.IsActive("Finance", "MstData_ProductFamily");

                            <li class="nav-header">Assets</li>
                            <li class="nav-item has-treeview @checkMenuFinAssets">
                                <a href="#" class="nav-link @checkActiveFinAssets">
                                    <i class="nav-icon fas fa-boxes"></i>
                                    <p>Assets<i class="fas fa-angle-left right"></i></p>
                                    <span id="assetsTotalFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a href="@Url.Action("AssetList", "Finance")" class="nav-link @Html.IsActive("Finance", "AssetList")">
                                            <i class="ml-2 nav-icon fas fa-table"></i>
                                            <p>Asset List</p>
                                            <span id="assetListFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-header">Operations</li>
                            <li class="nav-item has-treeview @checkMenuFinOps">
                                <a href="#" class="nav-link @checkActiveFinOps">
                                    <i class="nav-icon fas fa-industry"></i>
                                    <p>Operations<i class="fas fa-angle-left right"></i></p>
                                    <span id="operationsTotalFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                </a>
                                <ul class="nav nav-treeview">
                                    <li class="nav-item">
                                        <a href="@Url.Action("Gatepass", "Finance")" class="nav-link @Html.IsActive("Finance", "Gatepass")">
                                            <i class="ml-2 nav-icon fas fa-truck"></i>
                                            <p>Asset Transfer List</p>
                                            <span id="gatepassListFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                    <li class="nav-item has-treeview @checkMenuFinInvoice">
                                        <a href="#" class="nav-link @checkActiveFinInvoice">
                                            <i class="ml-2 nav-icon fas fa-file"></i>
                                            <p>Invoices<i class="fas fa-angle-left right"></i></p>
                                            <span id="invoicesTotalBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                        <ul class="nav nav-treeview">
                                            <li class="nav-item">
                                                <a href="@Url.Action("CreateInvoice", "Finance")" class="nav-link @Html.IsActive("Finance", "CreateInvoice")">
                                                    <i class="ml-3 nav-icon fas fa-file-invoice-dollar"></i>
                                                    <p>Create Invoice</p>
                                                    <span id="createInvoiceFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a href="@Url.Action("InvoiceList", "Finance")" class="nav-link @Html.IsActive("Finance", "InvoiceList")">
                                                    <i class="ml-3 nav-icon fas fa-file-invoice"></i>
                                                    <p>Invoice List</p>
                                                    <span id="invoiceListFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a href="@Url.Action("InvoiceApprovalList", "Finance")" class="nav-link @Html.IsActive("Finance", "InvoiceApprovalList")">
                                                    <i class="ml-3 nav-icon fas fa-clipboard-check"></i>
                                                    <p>Invoice Approval</p>
                                                    <span id="invoiceApprovalFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                                </a>
                                            </li>
                                        </ul>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("GatepassNonAsset", "Finance")" class="nav-link @Html.IsActive("Finance", "GatepassNonAsset")">
                                            <i class="ml-2 nav-icon fas fa-truck"></i>
                                            <p>Non-Asset Transfer List</p>
                                            <span id="gatepassNonAssetListFinanceBadge" class="badge bg-danger small-badge" style="visibility:hidden;"></span>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-header">Master Data</li>
                            <li class="nav-item has-treeview @checkMenuMasterData">
                                <a href="#" class="nav-link @checkActiveMasterData">
                                    <i class="nav-icon fas fa-table"></i>
                                    <p>Master Data<i class="fas fa-angle-left right"></i></p>
                                </a>
