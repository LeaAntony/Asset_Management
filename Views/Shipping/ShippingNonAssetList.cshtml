        function updateHSCodeNonAsset(inputElement) {
            let hsCode = inputElement.val();
            let itemId = inputElement.data('item-id');
            let poItem = inputElement.data('po-item');

            $.ajax({
                url: '@Url.Action("UpdateNonAssetHSCode")',
                type: 'POST',
                data: {
                    id_detail: itemId,
                    po_or_asset_no: poItem,
                    hs_code: hsCode
                },
                success: function(response) {
                    if (!response.success) {
                        Swal.fire('Error!', response.message || 'Failed to update HS Code', 'error');
                        inputElement.focus();
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error updating HS Code:', error);
                    Swal.fire('Error!', 'Failed to update HS Code', 'error');
                }
            });
        }

        function saveShippingNonAsset() {
            if (!$('#plantSelectNonAsset').val()) {
                Swal.fire('Warning!', 'Please select a plant', 'warning');
                return;
            }

            if (!$('#shipmentDateNonAsset').val()) {
                Swal.fire('Warning!', 'Please select a shipment date', 'warning');
                return;
            }

            let shippingData = {
                id_gatepass: parseInt($('#currentIdGatepassNonAsset').val()),
                plant: $('#plantSelectNonAsset').val(),
                shipment_date: $('#shipmentDateNonAsset').val(),
                shipment_type: $('#shipmentTypeInputNonAsset').val(),
                dhl_awb: $('#dhlAwbInputNonAsset').val()
            };

            $.ajax({
                url: '@Url.Action("SaveNonAssetShipping")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(shippingData),
                success: function(response) {
                    if (response.success) {
                        Swal.fire('Success!', `Non-asset shipping data saved successfully. Proforma No: ${response.proforma_no}`, 'success');

                        $('#shipmentTypeContainerNonAsset').show();
                        $('#dhlAwbContainerNonAsset').show();

                        loadShippingDataNonAsset($('#currentIdGatepassNonAsset').val());

                    } else if (response.requireConfirmation && response.type === 'plant_changed') {
                        Swal.fire({
                            title: 'Plant Changed!',
                            text: response.message + '\n\nExisting shipping boxes will be deleted. Do you want to continue?',
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            confirmButtonText: 'Yes, delete and save!',
                            cancelButtonText: 'Cancel'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                saveShippingForceNonAsset(shippingData, true);
                            }
                        });
                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error saving non-asset shipping:', error);
                    Swal.fire('Error!', 'Failed to save shipping data', 'error');
                }
            });
        }

        function saveShippingForceNonAsset(shippingData, forceDelete) {
            $.ajax({
                url: '@Url.Action("SaveNonAssetShippingForce")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    Model: shippingData,
                    ForceDelete: forceDelete
                }),
                success: function(response) {
                    if (response.success) {
                        Swal.fire('Success!', `Non-asset shipping data saved successfully. Proforma No: ${response.proforma_no}`, 'success');

                        $('#shipmentTypeContainerNonAsset').show();
                        $('#dhlAwbContainerNonAsset').show();

                        loadShippingDataNonAsset($('#currentIdGatepassNonAsset').val());

                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error force saving non-asset shipping:', error);
                    Swal.fire('Error!', 'Failed to save shipping data', 'error');
                }
            });
        }

        function submitShippingNonAsset() {
            Swal.fire({
                title: 'Are you sure?',
                text: 'This will finalize the shipping and change the gatepass status to Closed',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                confirmButtonText: 'Yes, submit it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("SubmitNonAssetShipping")',
                        type: 'POST',
                        data: { id_gatepass: $('#currentIdGatepassNonAsset').val() },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Success!', 'Non-asset shipping submitted successfully', 'success').then(() => {
                                    $('#shippingNonAssetModal').modal('hide');
                                    var currentStatus = $("select[name=status]").val();
                                    if (currentStatus === "OPEN" && openTableNonAsset) {
                                        openTableNonAsset.ajax.reload();
                                    } else if (currentStatus === "CLOSE" && closedTableNonAsset) {
                                        closedTableNonAsset.ajax.reload();
                                    }
                                });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error submitting non-asset shipping:', error);
                            Swal.fire('Error!', 'Failed to submit shipping', 'error');
                        }
                    });
                }
            });
        }

        function exportShippingExcelNonAsset() {
            let id_gatepass = $('#currentIdGatepassNonAsset').val();
            let gatepass_no = $('#modalGatepassNonAssetNo').text();

            Swal.fire({
                title: 'Export Non-Asset Shipping Data',
                text: `Are you sure you want to export shipping data for ${gatepass_no}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#007bff',
                confirmButtonText: 'Yes, Export',
                cancelButtonText: 'Cancel',
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return new Promise((resolve) => {
                        window.location.href = '@Url.Action("ExportNonAssetShippingData", "Shipping")' + '?id_gatepass=' + id_gatepass;

                        setTimeout(() => {
                            resolve();
                        }, 100);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Export Started',
                        text: 'Your Excel file should download shortly.',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });
        }

        function exportShippingDataNonAsset(id_gatepass, gatepass_no) {
            Swal.fire({
                title: 'Export Non-Asset Shipping Data',
                text: `Are you sure you want to export shipping data for ${gatepass_no}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#007bff',
                confirmButtonText: 'Yes, Export',
                cancelButtonText: 'Cancel',
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return new Promise((resolve) => {
                        window.location.href = '@Url.Action("ExportNonAssetShippingData", "Shipping")' + '?id_gatepass=' + id_gatepass;

                        setTimeout(() => {
                            resolve();
                        }, 100);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Export Started',
                        text: 'Your Excel file should download shortly.',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });
        }

        function checkAllItemsAssignedNonAsset() {
            let totalItems = $('#itemTableNonAsset tbody tr').length;
            let assignedItems = $('#itemTableNonAsset tbody input[type="checkbox"]:disabled').length;
            let hasSavedBoxes = $('#boxTableBodyNonAsset .badge-success').length > 0;
            let hasTempBoxes = $('#boxTableBodyNonAsset .badge-info').length > 0;

            if (totalItems > 0 && assignedItems === totalItems && hasSavedBoxes && !hasTempBoxes) {
                $('#exportExcelBtnNonAsset').show();

                if (window.isDataCompleteInDbNonAsset === true) {
                    $('#submitShippingBtnNonAsset').show();
                } else {
                    $('#submitShippingBtnNonAsset').hide();
                }
            } else {
                $('#submitShippingBtnNonAsset').hide();
                $('#exportExcelBtnNonAsset').hide();
            }
        }
    </script>
}