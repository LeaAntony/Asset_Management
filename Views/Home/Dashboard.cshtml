        function ensureLoader($container) {
            let $overlay = $container.children('.card-loading-overlay');
            if ($overlay.length === 0) {
                $overlay = $('<div class="card-loading-overlay"><i class="fas fa-spinner fa-spin"></i></div>');
                $container.append($overlay);
            }
            return $overlay;
        }

        function showCardLoader(containerId) {
            const $container = $('#' + containerId);
            if (!$container.length) return;
            ensureLoader($container).css('display', 'flex');
        }

        function hideCardLoader(containerId) {
            $('#' + containerId + ' > .card-loading-overlay').hide();
        }

        function showTabLoaders(tabSelector) {
            const $tab = $(tabSelector);
            $tab.find('.chart-container-standard, .chart-container-wide').each(function () {
                ensureLoader($(this)).css('display', 'flex');
            });
        }

        function setChartInstance(containerId, chartInstance) {
            $('#' + containerId).data('hcChart', chartInstance);
        }

        function destroyChart(containerId) {
            const $c = $('#' + containerId);
            const chart = $c.data('hcChart');
            if (chart && typeof chart.destroy === 'function') {
                chart.destroy();
            }
            $c.removeData('hcChart');
        }

        function unloadCharts(tabSelector) {
            const $tab = $(tabSelector);
            $tab.find('.chart-container-standard, .chart-container-wide').each(function () {
                const $container = $(this);
                ensureLoader($container).css('display', 'flex');
                const existing = $container.data('hcChart');
                if (existing && typeof existing.destroy === 'function') {
                    existing.destroy();
                    $container.removeData('hcChart');
                }
                $container.children(':not(.card-loading-overlay)').remove();
            });
        }

        $(document).ready(function () {
            $('.chart-container-standard, .chart-container-wide').each(function () {
                ensureLoader($(this));
            });

            $('.slide-up').each(function (index) {
                $(this).css('animation-delay', (index * 0.1) + 's');
            });

            showTabLoaders('#asset-tagging');
            get_chart();

            $('#dashboardTabs button[data-bs-toggle="tab"]').on('show.bs.tab', function (e) {
                const prevTab = $(e.relatedTarget).attr('data-bs-target');
                const target = $(e.target).attr('data-bs-target');

                if (prevTab) {
                    unloadCharts(prevTab);
                }
                showTabLoaders(target);
            });

            $('#dashboardTabs button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                const target = $(e.target).attr('data-bs-target');
                setTimeout(function () {
                    switch (target) {
                        case '#asset-tagging':
                            get_chart();
                            break;
                        case '#gatepass-overview':
                            get_gatepass_overview_charts();
                            break;
                        case '#gatepass-analysis':
                            get_gatepass_analysis_charts();
                            break;
                    }
                }, 50);
            });
        });

        function updateKPIs(totalTagging, totalNoTagging) {
            const total = totalTagging + totalNoTagging;
            const progress = total > 0 ? ((totalTagging / total) * 100).toFixed(1) : '0.0';

            $('#total-assets').text(total.toLocaleString());
            $('#tagged-assets').text(totalTagging.toLocaleString());
            $('#untagged-assets').text(totalNoTagging.toLocaleString());
            $('#tagging-progress').text(progress + '%');
        }

