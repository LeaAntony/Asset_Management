    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5><i class="fa fa-image mr-2"></i><span id="gatepass_no_na_return"></span></h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center my-3">
                <div class="container-fluid" style="margin-top:-10px">
                    <table class="table professional-table" id="image_table_nonasset_return">
                        <thead class="bg-info">
                            <tr>
                                <th>PO/Asset No</th>
                                <th>Description</th>
                                <th>Before Transfer</th>
                                <th>After Return</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal_image_nonasset_transfer" tabindex="-1" role="dialog" aria-labelledby="imageModalLabelNATransfer" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5><i class="fa fa-image mr-2"></i><span id="gatepass_no_na_transfer"></span></h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center my-3">
                <div class="container-fluid" style="margin-top:-10px">
                    <table class="table professional-table" id="image_table_nonasset_transfer">
                        <thead class="bg-info">
                            <tr>
                                <th>PO/Asset No</th>
                                <th>Description</th>
                                <th>Before Transfer</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal_layer" tabindex="-1" role="dialog" aria-labelledby="filelabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-center" id="content_name"><i class="fas fa-list mr-2"></i></h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-12" id="table_details">
                        <table id="tbl_history" class="table professional-table">
                            <thead>
                                <tr style="font-size: 10pt;">
                                    <th class="align-middle text-center" colspan="2">Detail</th>
                                </tr>
                            </thead>
                            <tbody style="font-size: 10pt;">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="gatepass_detail_modal" class="modal fade">
    <div class="modal-dialog" role="document" style="min-width:80%">
        <div class="modal-content" id="gatepass_detail_body">
        </div>
    </div>
</div>

<div id="modal_edit_gatepass_nonasset" class="modal fade">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Non-Asset Gatepass</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="id_gatepass" />
                <div class="form-group">
                    <label>Return Date :</label>
                    <input type="date" class="form-control" name="return_date" />
                </div>
            </div>
            <div class="modal-footer text-end">
                <button class="btn btn-success" name="btn_save_edit_nonasset"><i class="fas fa-save"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal_list_nonasset" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="chart_title_nonasset"><i class="fas fa-upload"></i> Upload Non-Asset Gate Pass After Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="body_update_cert_nonasset">
                <form id="form_update_cert_nonasset" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-12" id="FilteredTableNonAsset">
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="pdf-popup-modal" class="modal fade" tabindex="-1" aria-labelledby="filelabel" aria-hidden="true">
    <div id="pdf-popup-content" class="modal-dialog modal-xl">
        <div class="modal-content" style="height:100%">
            <div class="modal-body">
                <iframe id="pdf-iframe" src="" style="width: 100%; height: 80vh;"></iframe>
                <button class="align-middle btn btn-sm btn-secondary" id="close_pdf_popup_btn" style="width:50%; position:relative; left:25%" onclick="closePDF()">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var table;
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        var sesa_id = "@user.sesa_id".toUpperCase();
        const initial_gatepass_no = "@ViewBag.gatepass_no";
        var basePath = '@Url.Content("~/")'

        function copyApprovalLinkNonAsset(gatepass_no) {
            const baseUrl = window.location.origin + basePath;
            const approvalLink = `${baseUrl}Redirect/GatePassNonAssetList?gatepass_no=${encodeURIComponent(gatepass_no)}`;

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(approvalLink).then(() => {
                    Swal.fire({ title:'Link Copied!', text:'Redirect link has been copied to clipboard', icon:'success', timer:2000, showConfirmButton:false, toast:true, position:'top-end' });
                }).catch(err => {
                    console.error('Failed to copy: ', err);
                    fallbackCopyTextToClipboard(approvalLink);
                });
            } else {
                fallbackCopyTextToClipboard(approvalLink);
            }
        }

        function fallbackCopyTextToClipboard(text) {
            const textArea = document.createElement("textarea");
            textArea.value = text;
            textArea.style.top = "0"; textArea.style.left = "0"; textArea.style.position = "fixed";
            document.body.appendChild(textArea); textArea.focus(); textArea.select();
            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    Swal.fire({ title:'Link Copied!', text:'Redirect link has been copied to clipboard', icon:'success', timer:2000, showConfirmButton:false, toast:true, position:'top-end' });
                } else {
                    showLinkModal(text);
                }
            } catch (err) {
                console.error('Fallback: Oops, unable to copy', err);
                showLinkModal(text);
            }
            document.body.removeChild(textArea);
        }

        function showLinkModal(link) {
            Swal.fire({
                title: 'Copy Link',
                html: `<div class="form-group">
                        <label>Approval Link:</label>
                        <textarea class="form-control" rows="3" readonly style="font-size: 12px;">${link}</textarea>
                      </div>
                      <small class="text-muted">Please copy the link manually</small>`,
                icon: 'info',
                confirmButtonText: 'Close',
                width: '600px'
            });
        }

        function printNonAssetGatepass(id_gatepass) {
            const url = `@Url.Action("PRINT_GATEPASS_NON_ASSET_PDF", "Export")?id_gatepass=${id_gatepass}`;
            window.open(url, '_blank');
        }

        function openPDF(filename) {
            var pdfURL = "../WI/" + filename;
            var iframe = document.getElementById("pdf-iframe");
            if (iframe) {
                $("#pdf-popup-modal").modal("show");
                iframe.src = pdfURL;
            } else {
                console.error("iframe element not found");
            }
        }

        function closePDF() {
            $("#pdf-popup-modal").modal("hide");
            var iframe = document.getElementById("pdf-iframe");
            iframe.src = "";
        }

        $(document).ready(function () {
            var table = $("#table_nonasset").DataTable({
                orderCellsTop: true,
                processing: true,
                serverSide: true,
                filter: true,
                scrollX: true,
                scrollCollapse: true,
                autoWidth: false,
                order: [[1, 'desc']],
                ajax: {
                    url: "@Url.Action("GET_GATEPASS_NONASSET_LIST", "Requestor")",
                    type: "POST",
                    datatype: "json",
                    data: function (d) {
                        d.status = $("select[name=status]").val();
                    }
                },
                columns: [
                    { data: "id_gatepass", className: "align-middle", visible: false },
                    { data: "gatepass_no", className: "align-middle" },
                    {
                        data: "proforma_no",
                        className: "align-middle",
                        render: function (data) { return data ? data : '<div class="text-center">-</div>'; }
                    },
                    { data: "category", className: "align-middle" },
                    { data: "return_date", className: "align-middle text-center" },
                    {
                        data: "vendor_code",
                        className: "align-middle text-center",
                        render: function (data, type, row) {
                            return (data || 'N/A') + " <a href='#' onclick='show_detail_nonasset(`" + row['id_gatepass'] + "`)'><i class='text-secondary fas fa-info-circle'></i></a>";
                        }
                    },
                    {
                        data: "vendor_name",
                        className: "align-middle",
                        render: function (data) { return data || '<div class="text-center">N/A</div>'; }
                    },
                    { data: "create_date", className: "align-middle text-center" },
                    {
                        "data": "status_gatepass",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            var badgeClass;
                            if (data === 'OPEN') {
                                badgeClass = 'bg-lime';
                            } else if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            } else if (data.includes('REJECT')) {
                                badgeClass = 'bg-danger';
                            } else if (data === 'TRANSFER') {
                                badgeClass = 'bg-cyan';
                            } else if (data === 'RETURN APPROVED') {
                                badgeClass = 'bg-secondary';
                            } else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            } else {
                                badgeClass = 'bg-dark';
                            }
                            return '<span class="badge ' + badgeClass + '">' + data + '</span>';
                        }
                    },
                    {
                        "data": "status_remark",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            if (!data) return '<span class="badge bg-secondary">-</span>';

                            var badgeClass;
                            var text = data;

                            if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            }
                            else if (data.includes('Rejected By')) {
                                badgeClass = 'bg-danger';
                            }
                            else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            }
                            else {
                                badgeClass = 'bg-dark';
                            }

                            return '<span class="badge ' + badgeClass + '" style="white-space: normal; word-wrap: break-word; max-width: 200px; display: inline-block;">' + text + '</span>';
                        }
                    },
                    {
                        data: "id_gatepass",
                        className: "align-middle text-center",
                        render: function (data, type, row) {
                            if (row.category === "EQUIPMENT NON-FIXED ASSET RETURN") {
                                return '<button class="btn btn-sm text-center align-middle btn-secondary mr-2" onclick="nonasset_return_img(\'' + data + '\')"><i class="fas fa-image"></i></button>';
                            } else {
                                return '<button class="btn btn-sm text-center align-middle btn-secondary mr-2" onclick="nonasset_transfer_img(\'' + data + '\')"><i class="fas fa-image"></i></button>';
                            }
                        }
                    },
                    {
                        data: "id_gatepass",
                        className: "align-middle text-center",
                        render: function (data, type, row) {
                            let buttons = `<div class="btn-group" role="group" aria-label="Action buttons">`;
                            buttons += `<button class="btn btn-sm detail-btn text-center align-middle btn-info me-1" data-id="${data}" title="View Details"><i class="fas fa-info-circle"></i></button>`;
                            buttons += `<button class="btn btn-sm text-center align-middle btn-secondary me-1" onclick="copyApprovalLinkNonAsset('${row.gatepass_no}')" title="Copy Redirect Link"><i class="fas fa-link"></i></button>`;

                            if (row.category == "EQUIPMENT NON-FIXED ASSET RETURN" && row.status_gatepass.toUpperCase() != "COMPLETED" && row.status_gatepass != "Waiting Confirmation by FIN SS" && row.status_gatepass != "Waiting Confirmation by HOD") {
                                buttons += `<button class="btn btn-sm text-center align-middle btn-secondary me-1" onclick="edit_gatepass_nonasset('${data}','${row.category}')" title="Edit Gatepass"><i class="fas fa-edit"></i></button>`;
                            }

                            if (row.gp_after == null && row.status_gatepass === "TRANSFER") {
                                let text_confirm = (row.category == "EQUIPMENT NON-FIXED ASSET RETURN") ? "Return" : "Complete"
                                buttons += `<button class="btn btn-sm edit-btn text-center align-middle btn-primary me-1" onclick='update_gp_img_nonasset("${data}", "${row['gatepass_no']}")' title="Confirm (${text_confirm})"><i class="fas fa-upload"></i></button>`;
                            }

                            buttons += `<button class="btn btn-sm print-btn text-center align-middle btn-primary me-1" onclick='printNonAssetGatepass(${data})' title="Print Gatepass"><i class="fas fa-print"></i></button>`;

                            if (row.status_gatepass === "OPEN") {
                                buttons += `<button title="Cancel Gatepass" class="btn btn-sm text-center align-middle btn-danger me-1" onclick="cancelGatepassNonAsset('${data}', '${row.gatepass_no}')"><i class="fas fa-times-circle"></i></button>`;
                            }

                            buttons += `</div>`;
                            return buttons;
                        }
                    }
                ],
                initComplete: function (settings, json) {
                    var wrapper = $('#table_nonasset').closest('.dataTables_wrapper');
                    wrapper.css('position', 'relative');
                    $('#statusSelect').appendTo(wrapper).css('display', 'block');

                    $('#statusSelect').select2({
                        width: '150px',
                        minimumResultsForSearch: Infinity
                    });

                    $('#statusSelect').next('.select2-container').css({
                        'position': 'absolute',
                        'top': '0px',
                        'right': '0px'
                    }).attr('id', 'statusSelect2');

                    if (initial_gatepass_no && initial_gatepass_no.trim() !== '') {
                        table.column(1).search(initial_gatepass_no).draw();
                        $('input.filter_table[target="1"]').val(initial_gatepass_no);
                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                    }
                }
            });

            $('#statusSelect').change(function () {
                table.ajax.reload();
            });

            $('input.filter_table', this).on('keyup change', function () {
                let trgt = $(this).attr('target');
                if (table.column(trgt).search() !== this.value) {
                    table.column(trgt).search(this.value).draw();
                }
            });

            $(document).on('click', '.detail-btn', function () {
                var id_gatepass = $(this).data('id');
                $("div#gatepass_detail_body").html("");
                $.ajax({
                    type: "GET",
                    url: "@Url.Action("GET_GATEPASS_NONASSET_DETAIL")",
                    data: {
                        id_gatepass: id_gatepass
                    }
                }).done(function (res) {
                    $("div#gatepass_detail_body").html(res);
                    $("div#gatepass_detail_modal").modal("show");
                }).fail(function (err) {
                    swal.fire("Error!", err, "error");
                })
            });

            $("button[name=btn_save_edit_nonasset]").click(function(){
                let $modal = $("div#modal_edit_gatepass_nonasset");
                let id_gatepass = $modal.find("input[name=id_gatepass]").val();
                let return_date = $modal.find("input[name=return_date]").val();
                if(return_date==""){
                    swal.fire("Error!","Please input return date!!","error");
                }
                else{
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("EditGatepassNonAsset")",
                        data: {
                            id_gatepass: id_gatepass,
                            return_date: return_date
                        }
                    }).done(function(res){
                        let arr = res.split(";");
                        if(arr[0]=="success"){
                            swal.fire("Success","Non-Asset Gatepass Updated!!","success").then(function(){
                                $("#table_nonasset").DataTable().ajax.reload(null, false);
                                $modal.modal("hide");
                            })
                        }
                        else{
                            swal.fire("Error!",res,"error");
                        }
                    }).fail(function(err){
                        swal.fire("Error!",err,"error");
                    })
                }
            })
        });

        function nonasset_return_img(id_gatepass) {
            $.ajax({
                url: "@Url.Action("GET_IMG_GATEPASS_NONASSET", "Requestor")",
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function (data) {
                    var tableContent = '';
                    if (data && data.length > 0) {
                        $('#gatepass_no_na_return').text(data[0].gatepass_no);
                        data.forEach(function (item) {
                            tableContent += '<tr>';
                            tableContent += '<td class="align-middle text-center" style="width:15%">' + (item.po_or_asset_no || '-') + '</td>';
                            tableContent += '<td class="align-middle text-center" style="width:30%">' + (item.description || '-') + '</td>';
                            tableContent += '<td class="align-middle text-center"><img src="../Upload/GatePass_Non_Asset/' + encodeURIComponent(item.gp_before) + '" class="img-fluid" style="max-width: 50%; max-height:50%"></td>';
                            tableContent += '<td class="align-middle text-center"><img src="../Upload/GatePass_Non_Asset/' + encodeURIComponent(item.gp_after) + '" class="img-fluid" style="max-width: 50%; max-height:50%"></td>';
                            tableContent += '</tr>';
