            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                buttonHtml += `<button title="Gate Pass Image" class="btn btn-secondary btn-sm me-1" onclick="gatepass_img('${data}')">
                    <i class="fa fa-image"></i>
                </button>`;
            } else if (row.category === "REPAIR TO VENDOR") {
                buttonHtml += `<button title="Gate Pass Image" class="btn btn-secondary btn-sm me-1" onclick="repair_img('${data}')">
                    <i class="fa fa-image"></i>
                </button>`;
            } else {
                buttonHtml += `<button title="Gate Pass Image" class="btn btn-secondary btn-sm me-1" onclick="show_img('${data}')">
                    <i class="fa fa-image"></i>
                </button>`;
            }

            if (status === "OPEN") {
                buttonHtml += `<button title="Create Shipping Data" class="btn btn-primary btn-sm me-1" onclick='createShippingData("${data}", "${row['gatepass_no']}")'>
                    <i class='fa fa-plus'></i>
