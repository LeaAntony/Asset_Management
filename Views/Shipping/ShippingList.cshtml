                buttonHtml += `<button title="Export Data" class="btn btn-primary btn-sm me-1" onclick='exportShippingData("${data}", "${row['gatepass_no']}")'>
                    <i class='fa fa-file-excel'></i>
                </button>`;
            }

            buttonHtml += '</div>';
            return buttonHtml;
        }

