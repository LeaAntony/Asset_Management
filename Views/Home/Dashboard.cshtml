        }

        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
        });

        $(document).on('hidden.bs.modal', '#modal_image, #repair_image, #fa_sales_img, #modal_asset, #modal_dept_gp, #modal_gp_progress, #modal_gp_detail_total, #modal_gp_return, #modal_gp_detail_aging, #gatepass_detail_modal', function () {
            setTimeout(function () {
                if ($('.modal.show').length) {
                    $('body').addClass('modal-open');
                }
            }, 10);
        });
    </script>
}