@using Microsoft.AspNetCore.Mvc.Rendering;
@using Microsoft.AspNetCore.Http;
@using Asset_Management.Function;

@{
    string role = ViewBag.role;
    string sesa_id = ViewBag.sesa_id;
    string invoice_no = ViewBag.invoice_no;
}

<style>
    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
    }

        .hero .hero-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }

        .hero .hero-body {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        .hero .hero-title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

    .inner {
        height: 70px;
        position: relative;
    }

    .hero .inner {
        background: rgba(0,0,0,0.7);
    }

    .professional-table {
        font-size: 12px;
        border-collapse: separate;
        border-spacing: 0;
        clip-path: inset(0 round 8px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

        .professional-table thead th {
            background: var(--primary-blue);
            color: white;
            font-weight: 600;
            text-align: center;
            vertical-align: middle;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .professional-table tbody td {
            border: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .professional-table tbody tr:hover {
            background-color: var(--background-gray);
        }

        .professional-table th,
        .professional-table td {
            box-sizing: border-box;
            white-space: nowrap;
        }

    #loadingSpinner {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.5);
    }

        #loadingSpinner img {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 10pt;
    }

    table#table_invoice_approval tr > td {
        padding: 5px;
    }

    .btn-group-xs > .btn, .btn-xs {
        padding: .25rem .4rem;
        font-size: .875rem;
        line-height: .5;
        border-radius: .2rem;
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/bg-am.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">

        <div>
        </div>

        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-clipboard-check text-success"></i>
                <b>Invoice Approval List</b>
            </h3>
        </div>

        <div class="ms-auto">
        </div>

    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-3">
                <div class="list-card card fade-in">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12">
                                <table class="table professional-table align-center nowrap" id="table_invoice_approval" style="font-size:8pt; width:100%">
                                    <thead class="align-middle text-center" style="background: var(--primary-blue); color: white; font-weight: 600;">
                                        <tr>
                                            <th hidden>ID</th>
                                            <th>Invoice No</th>
                                            <th>Gate Pass No</th>
                                            <th>Vendor Name</th>
                                            <th>Invoice Date</th>
                                            <th>Created By</th>
                                            <th>Action</th>
                                            <th>Approval</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div id="loadingSpinner" style="display: none;">
                <span class="spinner-border spinner-border" role="status" aria-hidden="true"></span>
            </div>
        </div>
    </div>
</div>

<div id="gatepass_detail_modal" class="modal fade">
    <div class="modal-dialog" role="document" style="min-width:80%">
        <div class="modal-content" id="gatepass_detail_body">
        </div>
    </div>
</div>

<div id="invoice_detail_modal" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-file-invoice-dollar"></i> Invoice Detail - <span id="modal_invoice_no"></span>
                </h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="invoice_files_section" class="mb-3" style="display: none;">
                    <h6 class="mb-2"><i class="fas fa-file"></i> Invoice Files:</h6>
                    <div class="row">
                        <div class="col-md-4" id="main_file_container" style="display: none;">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-gray">Main Invoice File</h6>
                                    <p class="mb-2" style="word-break: break-all;">
                                        <i class="fas fa-file-alt text-primary"></i>
                                        <span id="main_file_name" class="fw-bold"></span>
                                    </p>
                                    <a id="main_file_link" href="#" target="_blank" class="btn btn-sm btn-primary">
                                        <i class="fas fa-download"></i> View/Download
                                    </a>
                                    <a id="main_file_download_only" href="#" download class="btn btn-sm btn-warning" style="display: none;">
                                        <i class="fas fa-download"></i> Download (.msg)
                                    </a>
                                    <small class="d-block mt-2 text-muted" id="main_file_msg_note" style="display: none;">
                                        <i class="fas fa-info-circle"></i> Email files (.msg) must be opened in Outlook
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4" id="secondary_file_container" style="display: none;">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-gray">Secondary Invoice File</h6>
                                    <p class="mb-2" style="word-break: break-all;">
                                        <i class="fas fa-file-alt text-primary"></i>
                                        <span id="secondary_file_name" class="fw-bold"></span>
                                    </p>
                                    <a id="secondary_file_link" href="#" target="_blank" class="btn btn-sm btn-primary">
                                        <i class="fas fa-download"></i> View/Download
                                    </a>
                                    <a id="secondary_file_download_only" href="#" download class="btn btn-sm btn-warning" style="display: none;">
                                        <i class="fas fa-download"></i> Download (.msg)
                                    </a>
                                    <small class="d-block mt-2 text-muted" id="secondary_file_msg_note" style="display: none;">
                                        <i class="fas fa-info-circle"></i> Email files (.msg) must be opened in Outlook
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4" id="payment_file_container" style="display: none;">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-gray">Payment Proof File</h6>
                                    <p class="mb-2" style="word-break: break-all;">
                                        <i class="fas fa-file-invoice-dollar text-success"></i>
                                        <span id="payment_file_name" class="fw-bold"></span>
                                    </p>
                                    <a id="payment_file_link" href="#" target="_blank" class="btn btn-sm btn-success">
                                        <i class="fas fa-download"></i> View/Download
                                    </a>
                                    <a id="payment_file_download_only" href="#" download class="btn btn-sm btn-warning" style="display: none;">
                                        <i class="fas fa-download"></i> Download (.msg)
                                    </a>
                                    <small class="d-block mt-2 text-muted" id="payment_file_msg_note" style="display: none;">
                                        <i class="fas fa-info-circle"></i> Email files (.msg) must be opened in Outlook
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr />
                </div>

                <div class="table-responsive">
                    <table class="table professional-table" id="table_invoice_detail">
                        <thead>
                            <tr>
                                <th>Asset No</th>
                                <th>Subnumber</th>
                                <th>Description</th>
                                <th>Asset Class</th>
                                <th>Cost Center</th>
                                <th>Capitalized On</th>
                                <th style="width: 150px;">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="invoice_detail_body">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var table;
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        const user_role = "@role";
        const user_sesa_id = "@sesa_id";
        const initial_invoice_no = "@invoice_no";

        const currencySymbols = {
            'EUR': '€',
            'USD': '$',
            'AUD': 'A$',
            'CNY': '¥',
            'IDR': 'Rp',
            'JPY': '¥',
            'SGD': 'S$',
            'VND': '₫',
            'THB': '฿'
        };

        function getCurrencySymbol(currency) {
            return currency ? currencySymbols[currency] || '' : '';
        }

        $(document).ready(function () {
            table = $("#table_invoice_approval").DataTable({
                "processing": true,
                "serverSide": true,
                "filter": true,
                "scrollX": true,
                "scrollCollapse": true,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("GET_INVOICE_APPROVAL_LIST")",
                    "type": "POST",
                    "datatype": "json",
                    "error": function (xhr, error, thrown) {
                        console.error("Error in AJAX request:", error, thrown);
                    }
                },
                "columns": [
                    { "data": "id_invoice", "className": "align-middle", "visible": false },
                    { "data": "invoice_no", "className": "align-middle" },
                    { "data": "gatepass_no", "className": "align-middle" },
                    { "data": "vendor_name", "className": "align-middle" },
                    { "data": "invoice_date", "className": "align-middle text-center" },
                    { "data": "invoice_by", "className": "align-middle" },
                    {
                        "data": null,
                        "className": "align-middle text-center",
                        render: function (data, type, row) {
                            let buttonHtml = '<div class="btn-group" role="group">';
                            buttonHtml += `<button title="View Gatepass Details" class="btn btn-info btn-sm me-1" onclick="open_detail(\`${row.id_gatepass}\`)">
                                <i class="fa fa-info-circle"></i>
                            </button>`;
                            buttonHtml += `<button title="View Invoice Details" class="btn btn-secondary btn-sm" onclick="openInvoiceDetail(${row.id_invoice}, '${row.invoice_no}')">
                                <i class="fas fa-file-invoice"></i>
                            </button>`;
                            buttonHtml += '</div>';
                            return buttonHtml;
                        }
                    },
                    {
                        "data": "id_invoice",
                        "className": "align-middle text-center",
                        render: function (data, type, row) {
                            let buttonHtml = '<div class="btn-group" role="group">';
                            buttonHtml += `<button title="Approve" class="btn btn-success btn-sm me-1" onclick="update_approval(${data}, 'APPROVED', '${row.invoice_no}')">
                                <i class='fa fa-check'></i>
                            </button>`;
                            buttonHtml += `<button title="Reject" class="btn btn-danger btn-sm" onclick="update_approval(${data}, 'REJECTED', '${row.invoice_no}')">
                                <i class='fa fa-times'></i>
                            </button>`;
                            buttonHtml += '</div>';
                            return buttonHtml;
                        }
                    }
                ],
                "order": [[1, "desc"]],
                "initComplete": function(settings, json) {
                    if (initial_invoice_no && initial_invoice_no.trim() !== '') {
                        this.api().search(initial_invoice_no).draw();
                        $('div.dataTables_filter input').val(initial_invoice_no);

                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                    }
                }
            });
        });

        function open_detail(id_gatepass) {
            $("div#gatepass_detail_body").html("");
            $.ajax({
                type: "GET",
                url: "@Url.Action("GET_GATEPASS_DETAIL", "Requestor")",
                data: {
                    id_gatepass: id_gatepass
                }
            }).done(function (res) {
                $("div#gatepass_detail_body").html(res);
                $("div#gatepass_detail_modal").modal("show");
            }).fail(function (err) {
                Swal.fire("Error!", err, "error");
            });
        }

        function openInvoiceDetail(id_invoice, invoice_no) {
            $('#modal_invoice_no').text(invoice_no);

            $.ajax({
                type: "GET",
                url: "@Url.Action("GET_INVOICE_DETAIL")",
                data: { id_invoice: id_invoice },
                success: function(response) {
                    renderInvoiceDetail(response.assets, response.invoice_currency);
                    displayInvoiceFiles(response.invoice_main_file, response.invoice_secondary_file, response.invoice_payment);
                    $('#invoice_detail_modal').modal('show');
                },
                error: function(xhr, status, error) {
                    Swal.fire("Error!", "Failed to load invoice details: " + error, "error");
                }
            });
        }

        function displayInvoiceFiles(mainFile, secondaryFile, paymentFile) {
            if (mainFile || secondaryFile || paymentFile) {
                $('#invoice_files_section').show();

                if (mainFile) {
                    $('#main_file_container').show();
                    $('#main_file_name').text(mainFile);

                    const mainFileExt = mainFile.toLowerCase().split('.').pop();

                    if (mainFileExt === 'msg') {
                        $('#main_file_link').hide();
                        $('#main_file_download_only').show();
                        $('#main_file_msg_note').show();

                        $('#main_file_download_only').attr('href', '@Url.Action("DOWNLOAD_INVOICE_FILE", "Finance")?fileName=' + encodeURIComponent(mainFile) + '&fileType=invoice');
                        $('#main_file_download_only').removeAttr('download');
                    } else {
                        $('#main_file_link').show();
                        $('#main_file_download_only').hide();
                        $('#main_file_msg_note').hide();
                        $('#main_file_link').attr('href', '@Url.Content("~/Upload/Gatepass_Invoice/")' + mainFile);
                    }
                } else {
                    $('#main_file_container').hide();
                }

                if (secondaryFile) {
                    $('#secondary_file_container').show();
                    $('#secondary_file_name').text(secondaryFile);

                    const secondaryFileExt = secondaryFile.toLowerCase().split('.').pop();

                    if (secondaryFileExt === 'msg') {
                        $('#secondary_file_link').hide();
                        $('#secondary_file_download_only').show();
                        $('#secondary_file_msg_note').show();

                        $('#secondary_file_download_only').attr('href', '@Url.Action("DOWNLOAD_INVOICE_FILE", "Finance")?fileName=' + encodeURIComponent(secondaryFile) + '&fileType=invoice');
                        $('#secondary_file_download_only').removeAttr('download');
                    } else {
                        $('#secondary_file_link').show();
                        $('#secondary_file_download_only').hide();
                        $('#secondary_file_msg_note').hide();
                        $('#secondary_file_link').attr('href', '@Url.Content("~/Upload/Gatepass_Invoice/")' + secondaryFile);
                    }
                } else {
                    $('#secondary_file_container').hide();
                }

                if (paymentFile) {
                    $('#payment_file_container').show();
                    $('#payment_file_name').text(paymentFile);

                    const paymentFileExt = paymentFile.toLowerCase().split('.').pop();

                    if (paymentFileExt === 'msg') {
                        $('#payment_file_link').hide();
                        $('#payment_file_download_only').show();
                        $('#payment_file_msg_note').show();

                        $('#payment_file_download_only').attr('href', '@Url.Action("DOWNLOAD_INVOICE_FILE", "Finance")?fileName=' + encodeURIComponent(paymentFile) + '&fileType=payment');
                        $('#payment_file_download_only').removeAttr('download');
                    } else {
                        $('#payment_file_link').show();
                        $('#payment_file_download_only').hide();
                        $('#payment_file_msg_note').hide();
                        $('#payment_file_link').attr('href', '@Url.Content("~/Upload/Gatepass_Invoice_Payment/")' + paymentFile);
                    }
                } else {
                    $('#payment_file_container').hide();
                }
            } else {
                $('#invoice_files_section').hide();
            }
        }

        function renderInvoiceDetail(invoiceAssets, invoiceCurrency) {
            let tbody = $('#invoice_detail_body');
            tbody.empty();

            if (!invoiceAssets || invoiceAssets.length === 0) {
                tbody.append('<tr><td colspan="7" class="text-center">No assets found</td></tr>');
                return;
            }

            let groupedAssets = {};
            invoiceAssets.forEach(asset => {
                if (asset.id_invoice_detail) {
                    if (!groupedAssets[asset.id_invoice_detail]) {
                        groupedAssets[asset.id_invoice_detail] = [];
                    }
                    groupedAssets[asset.id_invoice_detail].push(asset);
                }
            });

            let processedGroups = new Set();
            let currencySymbol = getCurrencySymbol(invoiceCurrency);

            invoiceAssets.forEach((asset) => {
                if (asset.id_invoice_detail && !processedGroups.has(asset.id_invoice_detail)) {
                    processedGroups.add(asset.id_invoice_detail);

                    let group = groupedAssets[asset.id_invoice_detail];
                    let groupCount = group.length;

                    group.forEach((groupAsset, groupIndex) => {
                        let row = `<tr>`;
                        row += `
                            <td>${groupAsset.asset_no}</td>
                            <td>${groupAsset.asset_subnumber}</td>
                            <td>${groupAsset.asset_desc}</td>
                            <td>${groupAsset.asset_class}</td>
                            <td>${groupAsset.cost_center}</td>
                            <td class="text-center">${groupAsset.capitalized_on}</td>
                        `;

                        if (groupIndex === 0) {
                            let amountDisplay = currencySymbol
                                ? `<span class="currency-symbol">${currencySymbol}</span> <span class="currency-value">${groupAsset.amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`
                                : `<span class="currency-value">${groupAsset.amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`;

                            row += `
                                <td rowspan="${groupCount}" class="text-center align-middle merged-cell">
                                    <div class="currency-container">
                                        ${amountDisplay}
                                    </div>
                                </td>
                            `;
                        }

                        row += `</tr>`;
                        tbody.append(row);
                    });
                }
            });
        }

        function update_approval(id_invoice, approval_status, invoice_no) {
            let text_status = (approval_status == "APPROVED") ? "APPROVE" : "REJECT";

            Swal.fire({
                title: 'Confirmation',
                html: `
                <div>
                    Are you sure you want to ${text_status}?<br><strong>${invoice_no}</strong><br>
                    <textarea class="form-control mt-3" id="approval_remark" rows="3" style="width: 100%; margin-top:1rem" placeholder="Type Remark..."></textarea>
                </div>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes!',
                cancelButtonText: 'No!',
                showLoaderOnConfirm: true,
                preConfirm: function () {
                    let approval_remark = $("#approval_remark").val().trim();

                    if (!approval_remark) {
                        Swal.showValidationMessage('Remark is required! Please provide a remark before proceeding.');
                        return false;
                    }

                    return new Promise(function (resolve, reject) {
                        $.ajax({
                            type: "POST",
                            url: "@Url.Action("UPDATE_APPROVAL_GATEPASS_INVOICE")",
                            data: {
                                id_invoice: id_invoice,
                                approval_status: approval_status,
                                approval_remark: approval_remark
                            }
                        }).done(function (res) {
                            let arr = res.split(";");
                            if (arr[0] == "success") {
                                resolve();
                                Swal.fire("Success", arr[1], "success").then(function () {
                                    table.ajax.reload();
                                });
                            } else {
                                reject(arr[1]);
                                Swal.fire("Error!", arr[1], "error");
                            }
                        }).fail(function (err) {
                            console.error("AJAX error: ", err);
                            reject(err.responseText);
                            Swal.fire("Action Error!", err.responseText, "error");
                        });
                    });
                },
                allowOutsideClick: () => !Swal.isLoading(),
            });
        }
    </script>
}