@using Microsoft.AspNetCore.Mvc.Rendering;
@using Microsoft.AspNetCore.Http;
@using Asset_Management.Function;

@{
    string role = ViewBag.role;
    string sesa_id = ViewBag.sesa_id;
    string gatepass_no = ViewBag.gatepass_no;
}

<style>
    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
    }

        .hero .hero-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }

        .hero .hero-body {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        .hero .hero-title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

    .inner {
        height: 70px;
        position: relative;
    }

    .hero .inner {
        background: rgba(0,0,0,0.7);
    }

    .professional-table {
        font-size: 12px;
        border-collapse: separate;
        border-spacing: 0;
        clip-path: inset(0 round 8px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

        .professional-table thead th {
            background: var(--primary-blue);
            color: white;
            font-weight: 600;
            text-align: center;
            vertical-align: middle;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .professional-table tbody td {
            border: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .professional-table tbody tr:hover {
            background-color: var(--background-gray);
        }

        .professional-table th,
        .professional-table td {
            box-sizing: border-box;
            white-space: nowrap;
        }

    #loadingSpinner {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.5);
    }

        #loadingSpinner img {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 10pt;
    }

    table#table_invoice tr > td {
        padding: 5px;
    }

    .btn-group-xs > .btn, .btn-xs {
        padding: .25rem .4rem;
        font-size: .875rem;
        line-height: .5;
        border-radius: .2rem;
    }

    .merged-row {
        background-color: #f8f9fa !important;
        font-weight: 600;
    }

    .professional-table tbody tr.grouped-asset {
        background-color: #fafbfc;
    }

        .professional-table tbody tr.grouped-asset:hover {
            background-color: #f0f2f5;
        }

    .nested-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1054;
        display: none;
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/bg-am.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">

        <div>
        </div>

        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-file-invoice-dollar text-success"></i>
                <b>Create Invoice</b>
            </h3>
        </div>

        <div class="ms-auto">
        </div>

    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-3">
                <div class="list-card card fade-in">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12">
                                <table class="table professional-table align-center nowrap" id="table_invoice">
                                    <thead class="align-middle text-center">
                                        <tr>
                                            <th hidden>ID</th>
                                            <th>Gate Pass No</th>
                                            <th>Category</th>
                                            <th>Request By</th>
                                            <th>Create Date</th>
                                            <th>Vendor Name</th>
                                            <th>Status</th>
                                            <th>Status Remark</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div id="loadingSpinner" style="display: none;">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            </div>
        </div>
    </div>
</div>

<div id="gatepass_detail_modal" class="modal fade">
    <div class="modal-dialog" role="document" style="min-width:80%">
        <div class="modal-content" id="gatepass_detail_body">
        </div>
    </div>
</div>

<div id="create_invoice_modal" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="nested-backdrop"></div>
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-file-invoice-dollar"></i> Create Invoice - <span id="modal_gatepass_no"></span></h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table professional-table" id="table_invoice_assets">
                        <thead>
                            <tr>
                                <th>Asset No</th>
                                <th>Subnumber</th>
                                <th>Description</th>
                                <th>Asset Class</th>
                                <th>Cost Center</th>
                                <th>Capitalized On</th>
                                <th style="width: 150px;">Amount</th>
                                <th style="width: 120px;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="invoice_assets_body">
                        </tbody>
                    </table>
                </div>
                <div id="add_amount_section" style="display: none;" class="text-center">
                    <button type="button" class="btn btn-success" onclick="openAmountModal()">
                        <i class="fas fa-plus"></i> Add Amount for Selected Assets
                    </button>
                </div>
                <div class="mt-3">
                    <label for="invoice_currency"><b>Invoice Currency: <span class="text-danger">*</span></b></label>
                    <select class="form-control" id="invoice_currency" required>
                        <option value="">Select Currency</option>
                        @* <option value="EUR">EUR - Euro</option> *@
                        <option value="USD">USD - US Dollar</option>
                        @* <option value="AUD">AUD - Australian Dollar</option>
                        <option value="CNY">CNY - Chinese Yuan</option> *@
                        <option value="IDR">IDR - Indonesian Rupiah</option>
                        @* <option value="JPY">JPY - Japanese Yen</option> *@
                        <option value="SGD">SGD - Singapore Dollar</option>
                        @* <option value="VND">VND - Vietnamese Dong</option>
                        <option value="THB">THB - Thai Baht</option> *@
                    </select>
                </div>
                <div class="mt-3">
                    <label for="invoice_date"><b>Invoice Date:</b></label>
                    <input type="date" class="form-control" id="invoice_date" required />
                </div>
                <div class="mt-3">
                    <label for="invoice_main_file"><b>Quotation File: <span class="text-danger">*</span></b></label>
                    <input type="file" class="form-control" id="invoice_main_file" required />
                </div>
                <div class="mt-3">
                    <label for="invoice_secondary_file"><b>Approval From Procurement File:</b></label>
                    <input type="file" class="form-control" id="invoice_secondary_file" />
                </div>
            </div>
            <div class="modal-footer">
                <button id="submitInvoice" type="button" class="btn btn-success" onclick="submitInvoice()">
                    <i class="fas fa-check"></i> Submit Invoice
                </button>
            </div>
        </div>
    </div>
</div>

<div id="amount_modal" class="modal fade" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-dollar-sign"></i> Input Amount</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="amount_input">Amount:</label> 
                    <input type="number" class="form-control" id="amount_input" step="0.01" min="0" required />
                </div>
                <div class="mt-2">
                    <small class="text-muted">This amount will be applied to <span id="selected_count">0</span> selected asset(s)</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" onclick="saveAmount()">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div id="edit_amount_modal" class="modal fade" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Amount</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="edit_amount_input">Amount:</label>
                    <input type="number" class="form-control" id="edit_amount_input" step="0.01" min="0" required />
                </div>
                <input type="hidden" id="edit_invoice_detail_id" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" onclick="updateAmount()">
                    <i class="fas fa-save"></i> Update
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var table;
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        const user_role = "@role";
        const user_sesa_id = "@sesa_id";
        const initial_gatepass_no = "@gatepass_no";
        let currentGatepassId = 0;
        let invoiceAssets = [];
        let selectedCurrency = '';

        const currencySymbols = {
            'EUR': '€',
            'USD': '$',
            'AUD': 'A$',
            'CNY': '¥',
            'IDR': 'Rp',
            'JPY': '¥',
            'SGD': 'S$',
            'VND': '₫',
            'THB': '฿'
        };

        $(document).ready(function () {
            table = $("#table_invoice").DataTable({
                "processing": true,
                "serverSide": true,
                "filter": true,
                "scrollX": true,
                "scrollCollapse": true,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("GET_CREATE_INVOICE")",
                    "type": "POST",
                    "datatype": "json",
                    "error": function (xhr, error, thrown) {
                        console.error("Error in AJAX request:", error, thrown);
                    }
                },
                "columns": [
                    { "data": "id_gatepass", "className": "align-middle", "visible": false },
                    { "data": "gatepass_no", "className": "align-middle" },
                    {
                        "data": "category",
                        "className": "align-middle",
                        render: function (data, type, row) {
                            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                                return `${data} (${row.type})`;
                            } else {
                                return data;
                            }
                        }
                    },
                    { "data": "requestor_name", "className": "align-middle" },
                    { "data": "create_date", "className": "align-middle text-center" },
                    { "data": "vendor_name", "className": "align-middle" },
                    {
                        "data": "status_gatepass",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            var badgeClass;
                            if (data === 'OPEN') {
                                badgeClass = 'bg-lime';
                            } else if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            } else if (data.includes('REJECT')) {
                                badgeClass = 'bg-danger';
                            } else if (data === 'TRANSFER') {
                                badgeClass = 'bg-cyan';
                            } else if (data === 'RETURN APPROVED') {
                                badgeClass = 'bg-secondary';
                            } else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            } else {
                                badgeClass = 'bg-dark';
                            }
                            return '<span class="badge ' + badgeClass + '">' + data + '</span>';
                        }
                    },
                    {
                        "data": "status_remark",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            if (!data) return '<span class="badge bg-secondary">-</span>';

                            var badgeClass;
                            var text = data;

                            if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            }
                            else if (data.includes('Rejected By')) {
                                badgeClass = 'bg-danger';
                            }
                            else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            }
                            else {
                                badgeClass = 'bg-dark';
                            }

                            return '<span class="badge ' + badgeClass + '" style="white-space: normal; word-wrap: break-word; max-width: 200px; display: inline-block;">' + text + '</span>';
                        }
                    },
                    {
                        "data": "id_gatepass",
                        "className": "align-middle text-center",
                        render: function (data, type, row) {
                            let buttonHtml = '<div class="btn-group" role="group">';
                            buttonHtml += `<button title="Open Details" class="btn btn-info btn-sm me-1" onclick="open_detail(\`${data}\`)"><i class="fa fa-info-circle"></i></button>`;
                            buttonHtml += `<button title="Create Invoice" class="btn btn-success btn-sm" onclick="openInvoiceModal(\`${data}\`, \`${row.gatepass_no}\`)"><i class="fas fa-plus"></i></button>`;
                            buttonHtml += '</div>';
                            return buttonHtml;
                        }
                    }
                ],
                "order": [[1, "desc"]],
                "initComplete": function(settings, json) {
                    if (initial_gatepass_no && initial_gatepass_no.trim() !== '') {
                        this.api().search(initial_gatepass_no).draw();
                        $('div.dataTables_filter input').val(initial_gatepass_no);

                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                    }
                }
            });

            $('#invoice_date').val(new Date().toISOString().split('T')[0]);

            $('#invoice_currency').on('change', function() {
                selectedCurrency = $(this).val();
                renderInvoiceAssets();
            });

            $('#amount_modal').on('show.bs.modal', function() {
                $('.nested-backdrop').show();
            });

            $('#amount_modal').on('hide.bs.modal', function() {
                $('.nested-backdrop').hide();
            });

            $('#edit_amount_modal').on('show.bs.modal', function() {
                $('.nested-backdrop').show();
            });

            $('#edit_amount_modal').on('hide.bs.modal', function() {
                $('.nested-backdrop').hide();
            });
        });

        function getCurrencySymbol() {
            return selectedCurrency ? currencySymbols[selectedCurrency] || '' : '';
        }

        function open_detail(id_gatepass) {
            $("div#gatepass_detail_body").html("");
            $.ajax({
                type: "GET",
                url: "@Url.Action("GET_GATEPASS_DETAIL", "Requestor")",
                data: {
                    id_gatepass: id_gatepass
                }
            }).done(function (res) {
                $("div#gatepass_detail_body").html(res);
                $("div#gatepass_detail_modal").modal("show");
            }).fail(function (err) {
                Swal.fire("Error!", err, "error");
            })
        }

        function openInvoiceModal(id_gatepass, gatepass_no) {
            currentGatepassId = id_gatepass;
            $('#modal_gatepass_no').text(gatepass_no);
            $('#invoice_main_file').val('');
            $('#invoice_secondary_file').val('');
            $('#invoice_currency').val('');
            selectedCurrency = '';

            $.ajax({
                type: "GET",
                url: "@Url.Action("GET_GATEPASS_INVOICE_ASSETS")",
                data: { id_gatepass: id_gatepass },
                success: function(data) {
                    invoiceAssets = data;
                    renderInvoiceAssets();
                    updateSubmitButtonState();
                    $('#create_invoice_modal').modal('show');
                },
                error: function(xhr, status, error) {
                    Swal.fire("Error!", "Failed to load assets: " + error, "error");
                }
            });
        }

        function renderInvoiceAssets() {
            let tbody = $('#invoice_assets_body');
            tbody.empty();

            let groupedAssets = {};
            invoiceAssets.forEach(asset => {
                if (asset.id_invoice_detail) {
                    if (!groupedAssets[asset.id_invoice_detail]) {
                        groupedAssets[asset.id_invoice_detail] = [];
                    }
                    groupedAssets[asset.id_invoice_detail].push(asset);
                }
            });

            let processedGroups = new Set();
            let currencySymbol = getCurrencySymbol();

            invoiceAssets.forEach((asset, index) => {
                if (asset.id_invoice_detail) {
                    let group = groupedAssets[asset.id_invoice_detail];
                    let groupCount = group.length;

                    if (!processedGroups.has(asset.id_invoice_detail)) {
                        processedGroups.add(asset.id_invoice_detail);

                        group.forEach((groupAsset, groupIndex) => {
                            let row = `<tr>`;

                            row += `
                                <td>${groupAsset.asset_no}</td>
                                <td>${groupAsset.asset_subnumber}</td>
                                <td>${groupAsset.asset_desc}</td>
                                <td>${groupAsset.asset_class}</td>
                                <td>${groupAsset.cost_center}</td>
                                <td class="text-center">${groupAsset.capitalized_on}</td>
                            `;

                            if (groupIndex === 0) {
                                let amountDisplay = currencySymbol
                                    ? `<span class="currency-symbol">${currencySymbol}</span> <span class="currency-value">${groupAsset.amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`
                                    : `<span class="currency-value">${groupAsset.amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`;

                                row += `
                                    <td rowspan="${groupCount}" class="text-center align-middle merged-cell">
                                        <div class="currency-container">
                                            ${amountDisplay}
                                        </div>
                                    </td>
                                `;

                                row += `
                                    <td rowspan="${groupCount}" class="text-center align-middle merged-cell">
                                        <button class="btn btn-primary btn-xs me-1" onclick="openEditAmountModal(${groupAsset.id_invoice_detail}, ${groupAsset.amount})" title="Edit Amount">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-danger btn-xs" onclick="deleteAmount(${groupAsset.id_invoice_detail})" title="Delete Amount">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                `;
                            }

                            row += `</tr>`;
                            tbody.append(row);
                        });
                    }
                } else {
                    let row = `
                        <tr>
                            <td>${asset.asset_no}</td>
                            <td>${asset.asset_subnumber}</td>
                            <td>${asset.asset_desc}</td>
                            <td>${asset.asset_class}</td>
                            <td>${asset.cost_center}</td>
                            <td class="text-center">${asset.capitalized_on}</td>
                            <td class="text-center">N/A</td>
                            <td class="text-center">
                                <input type="checkbox" class="asset-checkbox"
                                       data-asset="${asset.asset_no},${asset.asset_subnumber}"
                                       style="width: 20px; height: 20px; cursor: pointer;" />
                            </td>
                        </tr>
                    `;
                    tbody.append(row);
                }
            });

            $('.asset-checkbox').on('change', function() {
                updateAddAmountButton();
            });

            updateAddAmountButton();
        }

        function updateAddAmountButton() {
            let checkedCount = $('.asset-checkbox:checked').length;
            if (checkedCount > 0) {
                $('#add_amount_section').show();
            } else {
                $('#add_amount_section').hide();
            }
        }

        function updateSubmitButtonState() {
            let allAssetsHaveAmount = invoiceAssets.every(asset => asset.id_invoice_detail !== null);

            let submitButton = $('#submitInvoice');
            if (allAssetsHaveAmount) {
                submitButton.prop('disabled', false);
                submitButton.removeClass('disabled');
            } else {
                submitButton.prop('disabled', true);
                submitButton.addClass('disabled');
            }
        }

        function openAmountModal() {
            let checkedCount = $('.asset-checkbox:checked').length;
            $('#selected_count').text(checkedCount);
            $('#amount_input').val('');
            $('#amount_modal').modal('show');
        }

        function openEditAmountModal(id_invoice_detail, current_amount) {
            $('#edit_invoice_detail_id').val(id_invoice_detail);
            $('#edit_amount_input').val(current_amount);
            $('#edit_amount_modal').modal('show');
        }

        function saveAmount() {
            let amount = parseFloat($('#amount_input').val());

            if (!amount || amount <= 0) {
                Swal.fire("Error!", "Please enter a valid amount", "error");
                return;
            }

            let selectedAssets = [];
            $('.asset-checkbox:checked').each(function() {
                selectedAssets.push($(this).data('asset'));
            });

            if (selectedAssets.length === 0) {
                Swal.fire("Error!", "No assets selected", "error");
                return;
            }

            $.ajax({
                type: "POST",
                url: "@Url.Action("INSERT_GATEPASS_INVOICE_DETAIL")",
                data: {
                    id_gatepass: currentGatepassId,
                    selected_assets: selectedAssets.join(';'),
                    amount: amount
                },
                success: function(response) {
                    if (response.startsWith('success')) {
                        Swal.fire("Success!", "Amount saved successfully", "success");
                        $('#amount_modal').modal('hide');

                        $.ajax({
                            type: "GET",
                            url: "@Url.Action("GET_GATEPASS_INVOICE_ASSETS")",
                            data: { id_gatepass: currentGatepassId },
                            success: function(data) {
                                invoiceAssets = data;
                                renderInvoiceAssets();
                                updateSubmitButtonState();
                            }
                        });
                    } else {
                        Swal.fire("Error!", response, "error");
                    }
                },
                error: function(xhr, status, error) {
                    Swal.fire("Error!", "Failed to save amount: " + error, "error");
                }
            });
        }

        function updateAmount() {
            let id_invoice_detail = parseInt($('#edit_invoice_detail_id').val());
            let amount = parseFloat($('#edit_amount_input').val());

            if (!amount || amount <= 0) {
                Swal.fire("Error!", "Please enter a valid amount", "error");
                return;
            }

            Swal.fire({
                title: 'Confirmation',
                text: 'Are you sure you want to update this amount?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Update',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("UPDATE_GATEPASS_INVOICE_DETAIL")",
                        data: {
                            id_invoice_detail: id_invoice_detail,
                            amount: amount
                        },
                        success: function(response) {
                            if (response.startsWith('success')) {
                                Swal.fire("Success!", "Amount updated successfully", "success");
                                $('#edit_amount_modal').modal('hide');

                                $.ajax({
                                    type: "GET",
                                    url: "@Url.Action("GET_GATEPASS_INVOICE_ASSETS")",
                                    data: { id_gatepass: currentGatepassId },
                                    success: function(data) {
                                        invoiceAssets = data;
                                        renderInvoiceAssets();
                                        updateSubmitButtonState();
                                    }
                                });
                            } else {
                                Swal.fire("Error!", response, "error");
                            }
                        },
                        error: function(xhr, status, error) {
                            Swal.fire("Error!", "Failed to update amount: " + error, "error");
                        }
                    });
                }
            });
        }

        function deleteAmount(id_invoice_detail) {
            Swal.fire({
                title: 'Confirmation',
                text: 'Are you sure you want to delete this amount? All associated assets will be unlinked.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("DELETE_GATEPASS_INVOICE_DETAIL")",
                        data: {
                            id_invoice_detail: id_invoice_detail
                        },
                        success: function(response) {
                            if (response.startsWith('success')) {
                                Swal.fire("Success!", "Amount deleted successfully", "success");

                                $.ajax({
                                    type: "GET",
                                    url: "@Url.Action("GET_GATEPASS_INVOICE_ASSETS")",
                                    data: { id_gatepass: currentGatepassId },
                                    success: function(data) {
                                        invoiceAssets = data;
                                        renderInvoiceAssets();
                                        updateSubmitButtonState();
                                    }
                                });
                            } else {
                                Swal.fire("Error!", response, "error");
                            }
                        },
                        error: function(xhr, status, error) {
                            Swal.fire("Error!", "Failed to delete amount: " + error, "error");
                        }
                    });
                }
            });
        }

        function submitInvoice() {
            let invoice_currency = $('#invoice_currency').val();
            let invoice_date = $('#invoice_date').val();
            let main_file = $('#invoice_main_file')[0].files[0];
            let secondary_file = $('#invoice_secondary_file')[0].files[0];

            if (!invoice_currency) {
                Swal.fire("Error!", "Please select invoice currency", "error");
                return;
            }

            if (!invoice_date) {
                Swal.fire("Error!", "Please select invoice date", "error");
                return;
            }

            if (!main_file) {
                Swal.fire("Error!", "Please upload the main invoice file", "error");
                return;
            }

            let assetsWithoutAmount = invoiceAssets.filter(a => a.id_invoice_detail === null);
            if (assetsWithoutAmount.length > 0) {
                Swal.fire({
                    title: "Incomplete!",
                    text: `There are ${assetsWithoutAmount.length} asset(s) without amount. Please add amounts to all assets before submitting.`,
                    icon: "error",
                    confirmButtonText: "OK"
                });
                return;
            }

            Swal.fire({
                title: 'Confirmation',
                text: 'Are you sure you want to submit this invoice?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes, Submit',
                cancelButtonText: 'Cancel',
                showLoaderOnConfirm: true,
                allowOutsideClick: () => !Swal.isLoading(),
                preConfirm: function () {
                    return new Promise(function (resolve, reject) {
                        let formData = new FormData();
                        formData.append('id_gatepass', currentGatepassId);
                        formData.append('invoice_currency', invoice_currency);
                        formData.append('invoice_date', invoice_date);
                        formData.append('main_file', main_file);
                        if (secondary_file) {
                            formData.append('secondary_file', secondary_file);
                        }

                        $.ajax({
                            type: "POST",
                            url: "@Url.Action("INSERT_GATEPASS_INVOICE")",
                            data: formData,
                            processData: false,
                            contentType: false
                        }).done(function(response) {
                            let parts = response.split(';');
                            if (parts[0] === 'success') {
                                let invoice_no = parts[1];
                                let email_status = parts.length > 2 ? parts[2] : 'Email sent';

                                Swal.fire({
                                    title: 'Success!',
                                    html: `Invoice created successfully!<br><strong>Invoice No: ${invoice_no}</strong><br><small>${email_status}</small>`,
                                    icon: 'success',
                                    confirmButtonText: 'OK'
                                }).then(() => {
                                    $('#create_invoice_modal').modal('hide');
                                    table.ajax.reload();
                                });
                            } else {
                                Swal.fire("Error!", response, "error");
                            }
                        }).fail(function(err) {
                            console.error("AJAX error: ", err);
                            Swal.fire("Error!", err.responseText || "Failed to submit invoice", "error");
                        });
                    });
                }
            });
        }
    </script>
}