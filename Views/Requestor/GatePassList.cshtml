@model List<UserDetailModel>
@using Microsoft.AspNetCore.Mvc.Rendering;
@using Microsoft.AspNetCore.Http;
@using Asset_Management.Function;
@{
    var user = Model.First();
}

<style>
    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
    }

        .hero .hero-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }

        .hero .hero-body {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        .hero .hero-title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

    .inner {
        height: 70px;
        position: relative;
    }

    .hero .inner {
        background: rgba(0,0,0,0.7);
    }

    .professional-table {
        font-size: 12px;
        border-collapse: separate;
        border-spacing: 0;
        clip-path: inset(0 round 8px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

        .professional-table thead th {
            background: var(--primary-blue);
            color: white;
            font-weight: 600;
            text-align: center;
            vertical-align: middle;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .professional-table tbody td {
            border: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .professional-table tbody tr:hover {
            background-color: var(--background-gray);
        }

        .professional-table th,
        .professional-table td {
            box-sizing: border-box;
            white-space: nowrap;
        }

    .modal {
        overflow: auto !important;
    }

    #loadingSpinner {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.5);
    }

        #loadingSpinner img {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    .box_form_input {
        background-color: #fcfcfc;
        border-radius: 5px;
        box-shadow: 1px 2px 8px 2px rgba(152,152,152,0.7);
    }

    .smaller-input {
        height: 20px;
        padding: 5px;
        font-size: 10px;
        line-height: 1;
    }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 10pt;
    }

    .dataTables_filter {
        display: none;
    }

    table#table_asset tr > td {
        padding: 5px;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .half-underline {
        flex-grow: 1;
        text-align: center;
        margin-left: 15rem;
    }

    .form-inline {
        display: flex;
        align-items: center;
    }

    .bg-purple {
        background-color: #6f42c1;
        color: white;
    }

    .bg-teal {
        background-color: #20c997;
        color: white;
    }

    .bg-orange {
        background-color: #fd7e14;
        color: white;
    }

    .bg-pink {
        background-color: #e83e8c;
        color: white;
    }

    .bg-brown {
        background-color: #795548;
        color: white;
    }

    .bg-lime {
        background-color: #cddc39;
        color: black;
    }

    .bg-indigo {
        background-color: #6610f2;
        color: white;
    }

    .bg-cyan {
        background-color: #17a2b8;
        color: white;
    }

    .bg-amber {
        background-color: #ffc107;
        color: black;
    }

    .bg-olive {
        background-color: #3d9970;
        color: white;
    }
</style>

