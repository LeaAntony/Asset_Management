    .hidden {
        display: none;
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/bg-am.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">

        <div>
        </div>

        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-file-alt text-success"></i>
                <b>Form Asset Transfer</b>
            </h3>
        </div>

        <div class="ms-auto">
        </div>

    </div>
</section>

<div class="content">
    <div class="container-fluid hidden">
        <div class="row">
            <div class="col-lg-12 mt-3">
                <div class="list-card card fade-in">
                    <div class="card-body">
                        <form enctype="multipart/form-data" id="form_gatepass">
                            <div class="row pl-4 pr-4">
                                <input type="hidden" name="id_order" id="id_order" value="" />
                                <div class="col-6" style="display:none;">
                                    <label for="create_by">Requestor<span class="required">*</span> :</label>
                                    <input name="create_by" class="form-control" value="@userDetail.sesa_id (@userDetail.name)" readonly />
                                </div>
                                    <div class="col-6" style="display:none;">
                                    <label for="create_date">Create Date<span class="required">*</span> :</label>
                                    <input name="create_date" class="form-control" value="@todayDate" readonly />
                                </div>
                                <div class="col-6 mt-2">
                                    <label for="type">Category<span class="required">*</span> :</label>
                                    <select name="category" id="category" class="form-select" required>
                                        <option value="">-- SELECT CATEGORY --</option>
                                        <option value="TRANSFER TO VENDOR">TRANSFER TO VENDOR</option>
                                        <option value="REPAIR TO VENDOR">REPAIR TO VENDOR</option>
                                        <option value="FA SALES - WITHOUT DISMANTLING">FA SALES - WITHOUT DISMANTLING</option>
                                    </select>
                                </div>
                                <div class="col-6 mt-2" id="date_hide">
                                    <label for="type">Return Date<span class="required">*</span> :</label>
                                    <input type="date" id="return_date" name="return_date" class="form-control" readonly />
                                </div>
                                <div class="col-6 mt-2" id="pic_hide" hidden="hidden">
                                    <label for="type">New PIC Asset<span class="required">*</span> :</label>
                                    <select type="text" name="new_pic" id="new_pic" class="form-select">
                                        <option value="">-- SELECT NEW PIC --</option>
                                        @foreach (var pic in ViewBag.picList)
                                        {
                                            <option value="@pic.sesa_id">@pic.name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6 mt-2" id="type_hide" hidden>
                                    <label for="type">Type<span class="required">*</span> :</label>
                                    <select type="text" name="type" id="select_type" class="form-select">
                                        <option value="">-- SELECT TYPE --</option>
                                        <option value="VENDOR">VENDOR</option>
                                        <option value="EMPLOYEE">EMPLOYEE</option>
                                        <option value="CSR">CSR</option>
                                    </select>
                                </div>
                                <div class="col-12 mt-2" id="loc_hide" hidden="hidden">
                                    <label for="type">New Location<span class="required">*</span> :</label>
                                    <select type="text" name="location" id="location" class="form-select">
                                        <option value="">-- SELECT NEW LOCATION --</option>
                                        <option value="JHO">JHO</option>
                                        <option value="BMS 1">BMS 1</option>
                                        <option value="BMS 2">BMS 2</option>
                                        <option value="SDH">SDH</option>
                                        <option value="BRC">BRC</option>
                                        <option value="MRO">MRO</option>
                                    </select>
                                </div>
                                <div class="col-12 mt-2" id="employee_hide" hidden="hidden">
                                    <label for="type">Employee<span class="required">*</span> :</label>
                                    <select type="text" name="employee" id="employee" class="form-select">
                                        <option value="">-- SELECT EMPLOYEE --</option>
                                        @foreach (var emp in ViewBag.employeeList)
                                        {
                                            <option value="@emp.sesa_id">@emp.name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12 mt-2" id="csr_hide" hidden="hidden">
                                    <label for="type">Donation To<span class="required">*</span> :</label>
                                    <input type="text" name="csr" id="csr" class="form-control /">
                                </div>
                                <div class="col-12 mt-2">
                                    <label for="search_asset">Find Asset :</label>
                                    <input name="find_asset" class="form-control" autocomplete="off" placeholder="Type AssetNumber;Subnumber" />
                                    <div class="asset_suggestion p-2">
                                        <table class="professional-table table" id="table_asset_suggestion">
                                            <thead>
                                                <tr>
                                                    <th></th>
                                                    <th>Asset No</th>
                                                    <th>Subnumber</th>
                                                    <th>Description</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td class="text-center" colspan="4">No Data</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="col-12 mt-2">
                                    <label for="selected_asset">Selected Asset<span class="required">*</span> :</label>
                                    <div class="asset_selected table-responsive">
                                        <table class="professional-table table" id="table_asset_selected" style="font-size:10pt">
                                            <thead>
                                                <tr>
                                                    <th>No</th>
                                                    <th>Asset No</th>
                                                    <th>Subnumber</th>
                                                    <th>Asset Desc</th>
                                                    <th id="th_hs_code">HS Code <i class="fas fa-info-circle text-xs align-top" data-bs-toggle="tooltip" title="International product code for customs and trade"></i></th>
                                                    <th>New Location</th>
                                                    <th>Gate Pass Img</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                    <tr class="text-center align-middle">
                                                    <td class="text-center" colspan="8">No Data</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="col-6 mt-2" id="vcode_hide">
                                    <label for="vendor_code">Vendor Code & Vendor Name<span class="required">*</span> :</label>
                                    <select name="vendor_code" id="vendor_code" class="form-select">
                                        <option value="">-- SELECT VENDOR CODE & VENDOR NAME --</option>
                                    </select>
                                </div>
                                <div class="col-4 mt-2" hidden>
                                    <label for="type">Vendor Name<span class="required">*</span> :</label>
                                    <input type="text" name="vendor_name" id="vendor_name" class="form-control" readonly />
                                </div>
                                <div class="col-6 mt-2" id="vphone_hide">
                                    <label for="type">Vendor Phone<span class="required">*</span> :</label>
                                    <input type="text" name="vendor_phone" id="vendor_phone" class="form-control" readonly />
                                </div>
                                <div class="col-6 mt-2" id="vaddr_hide">
                                    <label for="type">Vendor Address<span class="required">*</span> :</label>
                                    <input type="text" name="vendor_address" id="vendor_address" class="form-control" readonly />
                                    <input type="hidden" name="vendor_batam" id="vendor_batam" class="form-control" readonly />
                                </div>
                                <div class="col-6 mt-2" id="vemail_hide">
                                    <label for="type">Vendor Email<span class="required">*</span> :</label>
                                    <input type="email" name="vendor_email" id="vendor_email" class="form-control" />
                                </div>
                            </div>
                            <div class="row pl-4 pr-4 mt-4 hidden" id="prof_form">
                                <div class="card" style="background-color:#f8f9fa">
                                    <div class="card-header">
                                        <h4>Form Proforma</h4>
                                    </div>
                                    <div class="card-body">
                                        <div class="row" id="prof_address">
                                            <div class="col-4 mb-2">
                                                <label for="prof_attn_to">Attention to<span class="required">*</span> :</label>
                                                <input type="text" name="prof_attn_to" id="prof_attn_to" class="form-control" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label for="prof_street">Street<span class="required">*</span> :</label>
                                                <input type="text" name="prof_street" id="prof_street" class="form-control" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label for="prof_city">City<span class="required">*</span> :</label>
                                                <input type="text" name="prof_city" id="prof_city" class="form-control" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label for="prof_country">Country<span class="required">*</span> :</label>
                                                <input type="text" name="prof_country" id="prof_country" class="form-control" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label for="prof_postal_code">Postal Code<span class="required">*</span> :</label>
                                                <input type="text" name="prof_postal_code" id="prof_postal_code" class="form-control" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label for="prof_phone">Phone Number<span class="required">*</span> :</label>
                                                <input type="text" name="prof_phone" id="prof_phone" class="form-control" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label for="prof_email">Email<span class="required">*</span> :</label>
                                                <input type="text" name="prof_email" id="prof_email" class="form-control" />
                                            </div>
                                            <div class="col-4 mb-2">
                                                <label for="prof_coo">Country of Origin<span class="required">*</span> :</label>
                                                <input type="text" name="prof_coo" id="prof_coo" class="form-control" />
                                                <small class="font-italic">* COO refers to the country where the item was produced.</small>
                                            </div>
                                        </div>

                                        <div class="row mt-4">
                                            <div class="col-6">
                                                <label for="book_val">Net Book Value (USD) :</label>
                                                <input name="book_val" class="form-control" value="0" readonly />
                                            </div>
                                            <div class="col-6">
                                                <label for="gross_val">Gross Value (USD) :</label>
                                                <input name="gross_val" class="form-control" value="0" readonly />
                                            </div>
                                        </div>

                                        <div class="row mt-2" id="prof_attach">
                                            <div class="col-12">
                                                <span class="text-warning">Total asset above 2500 USD, Need to upload required attachment!!</span><br />
                                            </div>
                                            <div class="col-6">
                                                <label for="file_attach">Justification Letter <span class="required">*</span> :</label><br />
                                                <input type="file" name="file_attach" id="file_attach" accept="pdf/*" required>
                                            </div>
                                            <div class="col-6">
                                                <label for="file_support">Supporting File (Max. 2 Files) :</label><br />
                                                <input type="file" name="file_support" id="file_support" accept="pdf/*" multiple>
                                            </div>
                                            <div class="col-12 mt-2">
                                                <small>
                                                    <a href="@Url.Content("~/Template_Justification_Letter.docx")" class="btn btn-sm btn-primary" download>Download Template</a>
                                                </small>
                                            </div>
                                        </div>

                                        <div class="row mt-4" id="prof_ship">
                                            <div class="col-4">
                                                <label>Mode of Shipment <span class="required">*</span> :</label><br />
                                                <input type="radio" name="ship_mode" id="ship_mode_air" value="AIR" />
                                                <label for="ship_mode_air">AIR</label><br />
                                                <input type="radio" name="ship_mode" id="ship_mode_sea" value="SEA" />
                                                <label for="ship_mode_sea">SEA</label><br />
                                                <input type="radio" name="ship_mode" id="ship_mode_courier" value="Courier" />
                                                <label for="ship_mode_courier">Courier</label><br />
                                                <input type="radio" name="ship_mode" id="ship_mode_others" value="Others" />
                                                <label for="ship_mode_others">Others</label>
                                            </div>
                                            <div class="col-4" id="courier_charges">
                                                <label>Courier Charges <span class="required">*</span> :</label><br />
                                                <input type="radio" name="charged_by" id="charged_by_jho" value="JHO" disabled />
                                                <label for="charged_by_jho">JHO</label><br />
                                                <input type="radio" name="charged_by" id="charged_by_receiver" value="Receiver" disabled />
                                                <label for="charged_by_receiver">Receiver</label><br />
                                                <select class="form-select" name="courier_name" disabled>
                                                    <option value="">-- Select Courier --</option>
                                                    <option value="DHL">DHL</option>
                                                    <option value="Fedex">Fedex</option>
                                                    <option value="Others">Others</option>
                                                </select>
                                                <input type="text" class="form-control mt-2" name="courier_acc_no" placeholder="Account No" readonly />
                                            </div>
                                            <div class="col-4" id="freight_charges">
                                                <label>Freight Charges <span class="required">*</span> :</label><br />
                                                <input type="radio" name="freight_charges" id="freight_collect" value="Freight Collect" />
                                                <label for="freight_collect">Freight Collect</label><br />
                                                <input type="radio" name="freight_charges" id="freight_prepaid" value="Freight Prepaid" />
                                                <label for="freight_prepaid">Freight Prepaid</label>
                                            </div>
                                            <div class="col-4" id="incoterms_section" style="display: none;">
                                                <label>Incoterms <span class="required">*</span> :</label><br />
                                                <div id="incoterms_collect_options" style="display: none;">
                                                    <input type="radio" name="incoterms" id="incoterms_fca_factory" value="FCA Factory" />
                                                    <label for="incoterms_fca_factory">FCA Factory</label>
                                                    <i class="fas fa-info-circle text-info text-xs align-top" data-bs-toggle="tooltip" title="Recipient assumes transport cost and risk from JHO factory/warehouse"></i><br />
                                                    <input type="radio" name="incoterms" id="incoterms_fca_port" value="FCA Port Batam" />
                                                    <label for="incoterms_fca_port">FCA Port Batam</label>
                                                    <i class="fas fa-info-circle text-info text-xs align-top" data-bs-toggle="tooltip" title="Sender delivers goods at Batam Port, and Recipient takes over cost and risk from there"></i>
                                                </div>
                                                <div id="incoterms_prepaid_options" style="display: none;">
                                                    <input type="radio" name="incoterms" id="incoterms_dap" value="DAP Consignee" />
                                                    <label for="incoterms_dap">DAP Consignee</label>
                                                    <i class="fas fa-info-circle text-info text-xs align-top" data-bs-toggle="tooltip" title="Shipper pays delivers good to recipient location, and recipient responsible for import duties (Bea Cukai) & unloading"></i><br />
                                                    <input type="radio" name="incoterms" id="incoterms_cpt" value="CPT Port" />
                                                    <label for="incoterms_cpt">CPT Port</label>
                                                    <i class="fas fa-info-circle text-info text-xs align-top" data-bs-toggle="tooltip" title="Shipper pays to delivery to batam port, Cost freight under shipper, recipient take over risk after goods are handed to the carrier at port of Loading"></i>
                                                </div>
                                            </div>
                                            <div class="col-4 mt-3">
                                                <label>Invoice Payment <span class="required">*</span> :</label><br />
                                                <input type="radio" name="invoice_payment" id="to_invoice" value="To Invoice" />
                                                <label for="to_invoice">To Invoice</label><br />
                                                <input type="radio" name="invoice_payment" id="foc" value="FOC" />
                                                <label for="foc">FOC</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row pl-4 pr-4 asset-form">
                                <div class="col-4 mt-2" id="security_hide">
                                    <label for="security_guard">Security Guard<span class="required">*</span> :</label>
                                    <select type="text" name="security_guard" id="security_guard" class="form-select">
                                        <option value="">-- SELECT SECURITY GUARD --</option>
                                        <option value="JHO">JHO</option>
                                        <option value="BMS 1">BMS 1</option>
                                        <option value="BMS 2">BMS 2</option>
                                        <option value="SDH">SDH</option>
                                        <option value="BRC">BRC</option>
                                        <option value="MRO">MRO</option>
                                    </select>
                                </div>
                                <div class="col-4 mt-2" id="shipping_plant_hide" hidden>
                                    <label for="shipping_plant">Shipping Plant<span class="required">*</span> :</label>
                                    <select type="text" name="shipping_plant" id="shipping_plant" class="form-select">
                                        <option value="">-- SELECT SHIPPING PLANT --</option>
                                        <option value="JHO">JHO</option>
                                        <option value="BMS 1">BMS 1</option>
                                        <option value="BMS 2">BMS 2</option>
                                        <option value="SDH">SDH</option>
                                        <option value="BRC">BRC</option>
                                        <option value="MRO">MRO</option>
                                    </select>
                                </div>
                                <div class="col-4 mt-2" id="vehicle_hide">
                                    <label for="vehicle_no">Vehicle No :</label>
                                    <input type="text" name="vehicle_no" class="form-control" />
                                </div>
                                <div class="col-4 mt-2" id="driver_hide">
                                    <label for="driver_name">Driver Name :</label>
                                    <input type="text" name="driver_name" class="form-control" />
                                </div>
                            </div>
                            <div class="row pl-4 pr-4 asset-form mt-4" id="supporting_docs_hide" hidden="hidden">
                                <label for="supporting_documents">Supporting Documents (Min 1, Max 3)<span class="required">*</span> :</label><br />
                                <input type="file" name="supporting_documents" id="supporting_documents" multiple />
                            </div>
                            <div class="row pl-4 pr-4 asset-form">
                                <div class="col-12 mt-4">
                                    <label for="remark">Remark/Reason<span class="required">*</span> :</label><br />
                                    <textarea class="form-control" name="remark" rows="4" required></textarea>
                                </div>
                            </div>
                            <div class="form-group text-center mt-4">
                                <button name="btn_submit" class="btn btn-success"><i class="fa fa-paper-plane"></i> SUBMIT</button>
                            </div>
                        </form>
                        @if (invalid_msg != "")
                        {
                            <div class="overlay" style="display: flex;">
                                <div class="alert alert-warning" role="alert">
                                    @invalid_msg
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="select_cat_modal" class="modal fade">
