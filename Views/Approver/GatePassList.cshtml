        function update_approval(id_gatepass, approval_level, approval_status, gatepass_no) {
            let text_status = (approval_status == "APPROVED") ? "APPROVE" : "REJECT";

            let table = $("#table_asset").DataTable();
            let rowData = table.rows().data().toArray().find(row => row.id_gatepass == id_gatepass);

            let isDelegated = false;
            let originalApprover = "";

            switch(approval_level) {
                case 'hod':
                    isDelegated = rowData.is_delegated_hod;
                    originalApprover = rowData.original_approver_hod;
                    break;
                case 'fbp':
                    isDelegated = rowData.is_delegated_fbp;
                    originalApprover = rowData.original_approver_fbp;
                    break;
                case 'ph':
                    isDelegated = rowData.is_delegated_ph;
                    originalApprover = rowData.original_approver_ph;
                    break;
            }

            let confirmationMessage = "";
            if (isDelegated) {
                confirmationMessage = `Are you sure you want to ${text_status} on behalf of <strong>${originalApprover}</strong>?<br><b>${gatepass_no}</b><br><small class="text-muted">(Delegated Approval)</small><br>`;
            } else {
                confirmationMessage = `Are you sure you want to ${text_status}?<br><b>${gatepass_no}</b><br>`;
            }

            Swal.fire({
                title: 'Confirmation',
                html: `
                    ${confirmationMessage}
                    <textarea class="form-control mt-3" id="approval_remark" rows="3" style="width: 100%;" placeholder="Type Remark..."></textarea>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes!',
                cancelButtonText: 'No!',
                showLoaderOnConfirm: true,
                preConfirm: function () {
                    let approval_remark = $("#approval_remark").val().trim();

                    if (!approval_remark) {
                        Swal.showValidationMessage('Remark is required! Please provide a remark before proceeding.');
                        return false;
                    }

                    return new Promise(function (resolve, reject) {
                        $.ajax({
                            type: "POST",
                            url: "@Url.Action("UPDATE_APPROVAL_GATEPASS")",
                            data: {
                                id_gatepass: id_gatepass,
                                approval_level: approval_level,
                                approval_status: approval_status,
                                approval_remark: approval_remark
                            }
                        }).done(function (res) {
                            let arr = res.split(";");
                            if (arr[0] == "success") {
                                let email_remark = "";
                                if (arr[1] != "success") {
                                    email_remark = "<br>Failed to Send Email Approval Update: " + arr[1];
                                }
                                resolve();
                                Swal.fire("Success", "Approval updated!!" + email_remark, "success").then(function () {
                                    location.reload();
                                });
                            } else {
                                reject(res);
                                Swal.fire("Error!", res, "error");
                            }
                        }).fail(function (err) {
                            console.error("AJAX error: ", err);
                            reject(err.responseText);
                            Swal.fire("Action Error!", err.responseText, "error");
                        });
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            });
        }

        function confirm(id_gatepass, approval_level, approval_status, gatepass_no) {
            let text_status = (approval_status == "APPROVED") ? "CONFIRM" : "REJECT";

            let table = $("#table_asset").DataTable();
            let rowData = table.rows().data().toArray().find(row => row.id_gatepass == id_gatepass);

            let isDelegated = rowData.is_delegated_confirm_hod;
            let originalApprover = rowData.original_approver_confirm_hod;

            let confirmationMessage = "";
            if (isDelegated) {
                confirmationMessage = `Are you sure you want to ${text_status} on behalf of <strong>${originalApprover}</strong>?<br><b>${gatepass_no}</b><br><small class="text-muted">(Delegated Confirmation)</small><br>`;
            } else {
