        function resetShippingForm() {
            $('#plantSelect').val('');
            $('#shipmentDate').val('');
            $('#shipmentTypeInput').val('');
            $('#dhlAwbInput').val('');
            $('#assetTableBody').empty();
            $('#boxTableBody').empty();
            $('#selectAllAssets').prop('checked', false);
            $('#createBoxBtn').prop('disabled', true).show();
            $('#saveShippingBtn').show();
            $('#exportExcelBtn').hide();
            $('#submitShippingBtn').hide();
            $('#shipmentTypeContainer').hide();
            $('#dhlAwbContainer').hide();

            window.isDataCompleteInDb = false;
            currentBoxCount = 0;
        }

        function loadShippingData(id_gatepass) {
            $.ajax({
                url: '@Url.Action("GetShippingData")',
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function(data) {
                    if (data.shipping_plant) {
                        $('#plantSelect').val(data.shipping_plant);
                        $('#plantSelect').prop('disabled', true);
                    } else if (data.plant) {
                        $('#plantSelect').val(data.plant);
                        $('#plantSelect').prop('disabled', false);
                    }

                    if (data.shipment_date) {
                        const date = new Date(data.shipment_date);
                        $('#shipmentDate').val(date.toISOString().split('T')[0]);
                    }

                    $('#shipmentTypeContainer').show();
                    $('#dhlAwbContainer').show();

                    if (data.shipment_type) {
                        $('#shipmentTypeInput').val(data.shipment_type);
                    }

                    if (data.dhl_awb) {
                        $('#dhlAwbInput').val(data.dhl_awb);
                    }

                    window.isDataCompleteInDb = data.is_data_complete_in_db || false;

                    loadCombinedBoxes(id_gatepass);

                    loadShippingAssets(id_gatepass);

                    checkAllAssetsAssigned();
                },
                error: function(xhr, status, error) {
                    console.error('Error loading shipping data:', error);
                }
            });
        }

        function loadCombinedBoxes(id_gatepass) {
            $.ajax({
                url: '@Url.Action("GetCombinedBoxes")',
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function(data) {
                    let html = '';
                    currentBoxCount = 0;
                    let hasSavedBoxes = false;
                    let hasTempBoxes = false;

                    if (data.saved_boxes && data.saved_boxes.length > 0) {
                        hasSavedBoxes = true;

                        data.saved_boxes.sort((a, b) => {
                            let aNum = parseInt(a.box_no.replace('Box ', '')) || 0;
                            let bNum = parseInt(b.box_no.replace('Box ', '')) || 0;
                            return aNum - bNum;
                        });

                        data.saved_boxes.forEach(function(box) {
                            currentBoxCount++;
                            let assetDisplay = box.asset_count + ' assets';
                            html += `
                                <tr>
                                    <td>${box.box_no}</td>
                                    <td>${assetDisplay}</td>
                                    <td class="text-center">${box.length_cm}×${box.width_cm}×${box.height_cm}</td>
                                    <td class="text-right">${box.gross_weight_kg}</td>
                                    <td class="text-right">${box.net_weight_kg}</td>
                                    <td class="text-center">
                                        <span class="badge badge-success ml-2">Saved</span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-danger" onclick="deleteSavedBox(${box.id_box})">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            `;
                        });
                    }

                    if (data.temp_boxes && data.temp_boxes.length > 0) {
                        hasTempBoxes = true;

                        data.temp_boxes.sort((a, b) => {
                            let aNum = parseInt(a.box_no.replace('Box ', '')) || 0;
                            let bNum = parseInt(b.box_no.replace('Box ', '')) || 0;
                            return aNum - bNum;
                        });

                        data.temp_boxes.forEach(function(box) {
                            currentBoxCount++;
                            let assetDisplay = box.asset_list ? box.asset_list.split(',').length + ' assets' : '0 assets';
                            html += `
                                <tr>
                                    <td>${box.box_no}</td>
                                    <td>${assetDisplay}</td>
                                    <td class="text-center">${box.length_cm}×${box.width_cm}×${box.height_cm}</td>
                                    <td class="text-right">${box.gross_weight_kg}</td>
                                    <td class="text-right">${box.net_weight_kg}</td>
                                    <td class="text-center">
                                        <span class="badge badge-info ml-2">Temp</span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-danger" onclick="deleteBox(${box.id_temp})">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            `;
                        });
                    }

                    $('#boxTableBody').html(html);

                    $('#createBoxBtn').show();
                    $('#saveShippingBtn').show();

                    checkAllAssetsAssigned();
                },
                error: function(xhr, status, error) {
                    console.error('Error loading combined boxes:', error);
                }
            });
        }

        function loadShippingAssets(id_gatepass) {
            $.ajax({
                url: '@Url.Action("GetShippingAssets")',
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function(data) {
                    let html = '';
                    data.forEach(function(asset) {
                        let isDisabled = asset.is_assigned;
                        let boxStatus = '';
                        let badgeClass = '';

                        if (asset.id_box > 0) {
                            boxStatus = 'Assigned to Box';
                            badgeClass = 'badge-success';
                        } else if (asset.is_assigned) {
                            boxStatus = 'In Temp Box';
                            badgeClass = 'badge-info';
                        } else {
                            boxStatus = 'Not Assigned';
                            badgeClass = 'badge-warning';
                        }

                        let hsCodeValue = asset.hs_code ? asset.hs_code.toString() : '';

                        html += `
                            <tr>
                                <td>
                                    <input type="checkbox" class="asset-checkbox"
                                           data-id="${asset.id_detail}"
                                           data-asset="${asset.asset_no};${asset.asset_subnumber}"
                                           ${isDisabled ? 'disabled' : ''} />
                                </td>
                                <td class="text-right">${asset.asset_no}</td>
                                <td class="text-right">${asset.asset_subnumber}</td>
                                <td>${asset.asset_desc}</td>
                                <td class="text-center">
                                    <input type="text" class="form-control form-control-sm hs-code-input"
                                           style="min-width: 100px;"
                                           value="${hsCodeValue}"
                                           data-asset-id="${asset.id_detail}"
                                           data-asset-no="${asset.asset_no}"
                                           data-asset-subnumber="${asset.asset_subnumber}"
                                           placeholder="Enter HS Code" />
                                </td>
                                <td class="text-center"><span class="badge ${badgeClass}">${boxStatus}</span></td>
                            </tr>
                        `;
                    });
                    $('#assetTableBody').html(html);

                    $('.hs-code-input').on('blur', function() {
                        updateHSCode($(this));
                    });

                    updateCreateBoxButton();
                    checkAllAssetsAssigned();
                },
                error: function(xhr, status, error) {
                    console.error('Error loading assets:', error);
                    Swal.fire('Error!', 'Failed to load assets', 'error');
                }
            });
        }

        function updateCreateBoxButton() {
            let selectedCount = $('#assetTable tbody input[type="checkbox"]:checked:not(:disabled)').length;
            $('#createBoxBtn').prop('disabled', selectedCount === 0);
        }

        function updateSelectAllCheckbox() {
            let totalEnabled = $('#assetTable tbody input[type="checkbox"]:not(:disabled)').length;
            let checkedEnabled = $('#assetTable tbody input[type="checkbox"]:checked:not(:disabled)').length;

            $('#selectAllAssets').prop('checked', totalEnabled > 0 && checkedEnabled === totalEnabled);
        }

        function openCreateBoxModal() {
            let selectedAssets = [];
            $('#assetTable tbody input[type="checkbox"]:checked:not(:disabled)').each(function() {
                let assetInfo = $(this).data('asset');
                selectedAssets.push(assetInfo);
            });

            if (selectedAssets.length === 0) {
                Swal.fire('Warning!', 'Please select at least one asset', 'warning');
                return;
            }

            let assetHtml = selectedAssets.map(asset => `<span class="badge badge-info mr-1">${asset}</span>`).join('');
            $('#selectedAssetsList').html(assetHtml);

            $('#createBoxForm')[0].reset();

            $('#createBoxModal').modal('show');
        }

        function submitBox() {
            if (!$('#createBoxForm')[0].checkValidity()) {
                $('#createBoxForm')[0].reportValidity();
                return;
            }

            let selectedAssetIds = [];
            $('#assetTable tbody input[type="checkbox"]:checked:not(:disabled)').each(function() {
                selectedAssetIds.push($(this).data('id'));
            });

            let nextBoxNumber = getNextAvailableBoxNumber();

            let boxData = {
                id_gatepass: parseInt($('#currentIdGatepass').val()),
                box_no: `Box ${nextBoxNumber}`,
                length_cm: parseFloat($('#boxLength').val()),
                width_cm: parseFloat($('#boxWidth').val()),
                height_cm: parseFloat($('#boxHeight').val()),
                gross_weight_kg: parseFloat($('#grossWeight').val()),
                net_weight_kg: parseFloat($('#netWeight').val()),
                asset_list: selectedAssetIds.join(',')
            };

            $.ajax({
                url: '@Url.Action("CreateTempBox")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(boxData),
                success: function(response) {
                    if (response.success) {
                        Swal.fire('Success!', 'Box created successfully', 'success');
                        $('#createBoxModal').modal('hide');

                        loadShippingAssets($('#currentIdGatepass').val());
                        loadCombinedBoxes($('#currentIdGatepass').val());

                        $('#submitShippingBtn').hide();
                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error creating box:', error);
                    Swal.fire('Error!', 'Failed to create box', 'error');
                }
            });
        }

        function getNextAvailableBoxNumber() {
            let existingBoxNumbers = [];

            $('#boxTableBody tr').each(function() {
                let boxName = $(this).find('td:first').text().trim();
                if (boxName.startsWith('Box ')) {
                    let boxNumber = parseInt(boxName.replace('Box ', ''));
                    if (!isNaN(boxNumber)) {
                        existingBoxNumbers.push(boxNumber);
                    }
                }
            });

            existingBoxNumbers.sort((a, b) => a - b);

            let nextNumber = 1;
            for (let num of existingBoxNumbers) {
                if (num === nextNumber) {
                    nextNumber++;
                } else {
                    break;
                }
            }

            return nextNumber;
        }

        function deleteBox(id_temp) {
            Swal.fire({
                title: 'Are you sure?',
                text: 'This will delete the box and unassign the assets',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteTempBox")',
                        type: 'POST',
                        data: { id_temp: id_temp },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Deleted!', 'Box has been deleted', 'success');

                                loadShippingAssets($('#currentIdGatepass').val());
                                loadCombinedBoxes($('#currentIdGatepass').val());
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error deleting box:', error);
                            Swal.fire('Error!', 'Failed to delete box', 'error');
                        }
                    });
                }
            });
        }

        function deleteSavedBox(id_box) {
            Swal.fire({
                title: 'Are you sure?',
                text: 'This will delete the saved box and unassign the assets. You will need to save again.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteSavedBox")',
                        type: 'POST',
                        data: { id_box: id_box },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Deleted!', 'Saved box has been deleted', 'success');

                                loadShippingAssets($('#currentIdGatepass').val());
                                loadCombinedBoxes($('#currentIdGatepass').val());
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error deleting saved box:', error);
                            Swal.fire('Error!', 'Failed to delete saved box', 'error');
                        }
                    });
                }
            });
        }

        function updateHSCode(inputElement) {
            let hsCode = inputElement.val();
            let assetId = inputElement.data('asset-id');
            let assetNo = inputElement.data('asset-no');
            let assetSubnumber = inputElement.data('asset-subnumber');

            $.ajax({
                url: '@Url.Action("UpdateHSCode")',
                type: 'POST',
                data: {
                    id_detail: assetId,
                    asset_no: assetNo,
                    asset_subnumber: assetSubnumber,
                    hs_code: hsCode
                },
                success: function(response) {
                    if (!response.success) {
                        Swal.fire('Error!', response.message || 'Failed to update HS Code', 'error');
                        inputElement.focus();
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error updating HS Code:', error);
                    Swal.fire('Error!', 'Failed to update HS Code', 'error');
                }
            });
        }

        function saveShipping() {
            if (!$('#plantSelect').val()) {
                Swal.fire('Warning!', 'Please select a plant', 'warning');
                return;
            }

            if (!$('#shipmentDate').val()) {
                Swal.fire('Warning!', 'Please select a shipment date', 'warning');
                return;
            }

            let shippingData = {
                id_gatepass: parseInt($('#currentIdGatepass').val()),
                plant: $('#plantSelect').val(),
                shipment_date: $('#shipmentDate').val(),
                shipment_type: $('#shipmentTypeInput').val(),
                dhl_awb: $('#dhlAwbInput').val()
            };

            $.ajax({
                url: '@Url.Action("SaveShipping")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(shippingData),
                success: function(response) {
                    if (response.success) {
                        Swal.fire('Success!', `Shipping data saved successfully. Proforma No: ${response.proforma_no}`, 'success');

                        $('#shipmentTypeContainer').show();
                        $('#dhlAwbContainer').show();

                        loadShippingData($('#currentIdGatepass').val());

                    } else if (response.requireConfirmation && response.type === 'plant_changed') {
                        Swal.fire({
                            title: 'Plant Changed!',
                            text: response.message + '\n\nExisting shipping boxes will be deleted. Do you want to continue?',
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            confirmButtonText: 'Yes, delete and save!',
                            cancelButtonText: 'Cancel'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                saveShippingForce(shippingData, true);
                            }
                        });
                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error saving shipping:', error);
                    Swal.fire('Error!', 'Failed to save shipping data', 'error');
                }
            });
        }

        function saveShippingForce(shippingData, forceDelete) {
            $.ajax({
                url: '@Url.Action("SaveShippingForce")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    Model: shippingData,
                    ForceDelete: forceDelete
                }),
                success: function(response) {
                    if (response.success) {
                        Swal.fire('Success!', `Shipping data saved successfully. Proforma No: ${response.proforma_no}`, 'success');

                        $('#shipmentTypeContainer').show();
                        $('#dhlAwbContainer').show();

                        loadShippingData($('#currentIdGatepass').val());

                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error force saving shipping:', error);
                    Swal.fire('Error!', 'Failed to save shipping data', 'error');
                }
            });
        }

        function submitShipping() {
            Swal.fire({
                title: 'Are you sure?',
                text: 'This will finalize the shipping and change the gatepass status to Closed',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                confirmButtonText: 'Yes, submit it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("SubmitShipping")',
                        type: 'POST',
                        data: { id_gatepass: $('#currentIdGatepass').val() },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Success!', 'Shipping submitted successfully', 'success').then(() => {
                                    $('#shippingModal').modal('hide');
                                    var currentStatus = $("select[name=status]").val();
                                    if (currentStatus === "OPEN" && openTable) {
                                        openTable.ajax.reload();
                                    } else if (currentStatus === "CLOSE" && closedTable) {
                                        closedTable.ajax.reload();
                                    }
                                });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error submitting shipping:', error);
                            Swal.fire('Error!', 'Failed to submit shipping', 'error');
                        }
                    });
                }
            });
        }

        function exportShippingExcel() {
            let id_gatepass = $('#currentIdGatepass').val();
            let gatepass_no = $('#modalGatepassNo').text();

            Swal.fire({
                title: 'Export Shipping Data',
                text: `Are you sure you want to export shipping data for ${gatepass_no}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#007bff',
                confirmButtonText: 'Yes, Export',
                cancelButtonText: 'Cancel',
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return new Promise((resolve) => {
                        window.location.href = '@Url.Action("ExportShippingData", "Shipping")' + '?id_gatepass=' + id_gatepass;

                        setTimeout(() => {
                            resolve();
                        }, 100);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Export Started',
                        text: 'Your Excel file should download shortly.',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });
        }

        function exportShippingData(id_gatepass, gatepass_no) {
            Swal.fire({
                title: 'Export Shipping Data',
                text: `Are you sure you want to export shipping data for ${gatepass_no}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#007bff',
                confirmButtonText: 'Yes, Export',
                cancelButtonText: 'Cancel',
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return new Promise((resolve) => {
                        window.location.href = '@Url.Action("ExportShippingData", "Shipping")' + '?id_gatepass=' + id_gatepass;

                        setTimeout(() => {
                            resolve();
                        }, 100);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Export Started',
                        text: 'Your Excel file should download shortly.',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });
        }

        function checkAllAssetsAssigned() {
            let totalAssets = $('#assetTable tbody tr').length;
            let assignedAssets = $('#assetTable tbody input[type="checkbox"]:disabled').length;
            let hasSavedBoxes = $('#boxTableBody .badge-success').length > 0;
            let hasTempBoxes = $('#boxTableBody .badge-info').length > 0;

            if (totalAssets > 0 && assignedAssets === totalAssets && hasSavedBoxes && !hasTempBoxes) {
                $('#exportExcelBtn').show();

                if (window.isDataCompleteInDb === true) {
                    $('#submitShippingBtn').show();
                } else {
                    $('#submitShippingBtn').hide();
                }
            } else {
                $('#submitShippingBtn').hide();
                $('#exportExcelBtn').hide();
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById("shipmentDate").setAttribute("min", today);
        });
    </script>
}