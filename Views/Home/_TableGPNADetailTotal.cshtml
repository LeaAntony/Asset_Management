@using System.Globalization;
@using Microsoft.AspNetCore.Http;
@using Asset_Management.Controllers;
@using Asset_Management.Function;
@model List<GPModel>
@{
    string type = ViewBag.type;
}
<style>
    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 12px;
        color: var(--text-light);
    }

    @@media screen and (max-width: 768px) {
        .modal-body {
            padding: 16px;
        }

        .professional-table {
            font-size: 11px;
        }

            .professional-table thead th {
                padding: 12px 8px;
                font-size: 10px;
            }

            .professional-table tbody td {
                padding: 8px;
            }
    }

    @@media screen and (max-width: 576px) {
        .modal-header {
            padding: 16px 20px 12px;
        }

            .modal-header .modal-title {
                font-size: 16px;
            }

        .modal-body {
            padding: 12px;
        }

        .professional-table {
            font-size: 10px;
        }

            .professional-table thead th {
                padding: 8px 6px;
                font-size: 9px;
            }

            .professional-table tbody td {
                padding: 6px;
            }
    }
</style>
<div class="modal-header">
    <h5 class="modal-title"><i class="fas fa-list"></i> Non-Asset Gate Pass List - @type</h5>
    <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
<div class="modal-body">
    <div class="row">
        <div class="col-12">
            <table class="table table-sm professional-table align-center nowrap" id="table_gp_na_total">
                <thead>
                    <tr>
                        <th hidden>ID Gatepass</th>
                        <th>Request ID</th>
                        <th>Category</th>
                        <th>Gate Pass Date</th>
                        <th>Requestor Name</th>
                        <th>Return Date</th>
                        <th>Department</th>
                        <th>Aging Days</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td hidden>@row.id_gatepass</td>
                            <td>@row.gatepass_no</td>
                            <td>@row.category</td>
                            <td>@row.create_date</td>
                            <td>@row.requestor_name</td>
                            <td>@row.return_date</td>
                            <td>@row.department</td>
                            <td>@row.aging_days</td>
                            <td>@row.status_gatepass</td>
                            <td>
                                <button class="btn btn-info btn-sm" title="Open Detail" onclick="open_non_asset_detail('@row.id_gatepass')">
                                    <i class="far fa-list-alt"></i>
                                </button>
                                <button class="btn btn-secondary btn-sm" title="View Image" onclick="show_non_asset_img('@row.id_gatepass')">
                                    <i class="fa fa-image"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
    $(function () {
        const $tbl = $("#table_gp_na_total");

        const dt = $tbl.DataTable({
            ordering: false,
            scrollX: true,
            scrollCollapse: true,
            autoWidth: false,
            deferRender: true
        });

        const $modal = $tbl.closest(".modal");
        $modal.on("shown.bs.modal", function () {
            dt.columns.adjust();
        });

        dt.on("init.dt", function () {
            dt.columns.adjust();
        });
    });
</script>