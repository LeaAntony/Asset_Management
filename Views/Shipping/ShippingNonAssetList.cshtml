                                    <tr>
                                        <th>Box No</th>
                                        <th>Item List</th>
                                        <th>Dimensions (L�W�H cm)</th>
                                        <th>Gross Weight (kg)</th>
                                        <th>Net Weight (kg)</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
