@using Microsoft.AspNetCore.Mvc.Rendering;
@using Microsoft.AspNetCore.Http;
@using Asset_Management.Function;

@{
    string role = ViewBag.role;
    string sesa_id = ViewBag.sesa_id;
}

<style>
    #loadingSpinner {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.5);
    }

        #loadingSpinner img {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    .box_form_input {
        background-color: #fcfcfc;
        border-radius: 5px;
        box-shadow: 1px 2px 8px 2px rgba(152,152,152,0.7);
    }

    .modal {
        overflow: auto !important
    }

    .smaller-input {
        height: 20px;
        padding: 5px;
        font-size: 10px; 
        line-height: 1;
    }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 10pt;
    }

    table#table_asset tr > td {
        padding: 5px;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .asset-list-card {
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        border: 1px solid #e9ecef;
        margin-bottom: 16px;
        transition: box-shadow 0.3s ease;
    }

        .asset-list-card .card-body {
            padding: 16px;
        }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 12px;
        color: var(--text-light);
    }

    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
    }

        .hero .hero-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }

        .hero .hero-body {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        .hero .hero-title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

    .inner {
        height: 70px;
        position: relative;
    }

    .hero .inner {
        background: rgba(0,0,0,0.7);
    }

    .professional-table {
        font-size: 12px;
        border-collapse: separate;
        border-spacing: 0;
        clip-path: inset(0 round 8px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        width: 100%;
    }

        .professional-table thead th {
            background: var(--primary-blue);
            color: white;
            font-weight: 600;
            padding: 16px 12px;
            text-align: center;
            vertical-align: middle;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .professional-table tbody td {
            padding: 12px;
            border: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .professional-table tbody tr:hover {
            background-color: var(--background-gray);
        }

        .professional-table th,
        .professional-table td {
            box-sizing: border-box;
            white-space: nowrap;
        }

    .table-striped > tbody > tr:nth-of-type(odd),
    .table-striped > tbody > tr:nth-of-type(even),
    .dataTable tbody tr.odd,
    .dataTable tbody tr.even {
        background-color: #ffffff !important;
    }

    #table_asset.dataTable tbody tr.odd > td,
    #table_asset.dataTable tbody tr.even > td,
    .DTFC_Cloned tbody tr.odd > td,
    .DTFC_Cloned tbody tr.even > td,
    #table_asset.table-striped > tbody > tr:nth-of-type(odd) > * {
        background-color: #ffffff !important;
        --bs-table-accent-bg: #ffffff !important;
    }

    #table_asset tbody td {
        background-color: #ffffff !important;
    }

    #table_asset thead th,
    #table_asset tbody tr.search-row td {
        border: 0;
        box-shadow: none !important;
    }

    .bg-purple {
        background-color: #6f42c1;
        color: white;
    }

    .bg-teal {
        background-color: #20c997;
        color: white;
    }

    .bg-orange {
        background-color: #fd7e14;
        color: white;
    }

    .bg-pink {
        background-color: #e83e8c;
        color: white;
    }

    .bg-brown {
        background-color: #795548;
        color: white;
    }

    .bg-lime {
        background-color: #cddc39;
        color: black;
    }

    .bg-indigo {
        background-color: #6610f2;
        color: white;
    }

    .bg-cyan {
        background-color: #17a2b8;
        color: white;
    }

    .bg-amber {
        background-color: #ffc107;
        color: black;
    }

    .bg-olive {
        background-color: #3d9970;
        color: white;
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/bg-am.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">

        <div>
        </div>

        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-check-double text-success"></i>
                <b>Asset Transfer Approval List</b>
            </h3>
        </div>

        <div class="ms-auto">
        </div>

    </div>
</section>

<div class="content">
