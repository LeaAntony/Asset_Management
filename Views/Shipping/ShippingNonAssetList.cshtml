            buttonHtml += `<button title="Gate Pass Detail" class="btn btn-info btn-sm me-1" onclick="open_detail_nonasset('${data}')">
                <i class="fa fa-info-circle"></i>
            </button>`;

            if (row.category === "EQUIPMENT NON-FIXED ASSET RETURN") {
                buttonHtml += '<button class="btn btn-sm text-center align-middle btn-secondary me-1" onclick="nonasset_return_img(\'' + data + '\')"><i class="fas fa-image"></i></button>';
            } else {
                buttonHtml += '<button class="btn btn-sm text-center align-middle btn-secondary me-1" onclick="nonasset_transfer_img(\'' + data + '\')"><i class="fas fa-image"></i></button>';
