                        <label for="file_imgs">Add Attachment Images (png/jpg/jpeg)<span class="required">*</span></label><br />
                        <input class="mt-2" type="file" name="asset_imgs" id="asset_imgs" accept=".png, .jpg, .jpeg" required>
                    </div>
                    <div class="col-12 mt-2" id="naming_hide" hidden="hidden">
                        <label>New Location :</label>
                        <input type="text" class="form-control" name="naming_output" id="naming_output" style="width:100%" readonly />
                    </div>

                    <div class="col-12 mt-4 text-end">
                        <button class="btn btn-success" name="btn_select_cat"><i class="fas fa-check"></i> Select</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="pdf-popup-modal" class="modal fade" tabindex="-1" aria-labelledby="filelabel" aria-hidden="true">
    <div id="pdf-popup-content" class="modal-dialog modal-xl">
        <div class="modal-content" style="height:100%">
            <div class="modal-body">
