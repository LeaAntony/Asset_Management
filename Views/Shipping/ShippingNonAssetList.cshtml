            if (status === "OPEN") {
                buttonHtml += `<button title="Create Shipping Data" class="btn btn-primary btn-sm me-1" onclick='createShippingDataNonAsset("${data}", "${row['gatepass_no']}")'>
                    <i class='fa fa-plus'></i>
                </button>`;
            } else {
                buttonHtml += `<button title="Export Data" class="btn btn-primary btn-sm me-1" onclick='exportShippingDataNonAsset("${data}", "${row['gatepass_no']}")'>
                    <i class='fa fa-file-excel'></i>
                </button>`;
            }

            buttonHtml += '</div>';
            return buttonHtml;
        }

