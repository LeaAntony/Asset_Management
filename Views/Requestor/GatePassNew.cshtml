@* @using System.Data; *@
@model List<UserDetailModel>
@using System.Globalization;
@using Microsoft.AspNetCore.Mvc.Rendering;
@using Microsoft.AspNetCore.Http;
@using Asset_Management.Function;

@{
    string assets = ViewBag.assets;
    string todayDate = DateTime.Today.ToString("yyyy-MM-dd");

    List<string> catList = ViewBag.catList;

    var userDetail = Model.First();

    List<LotFamilyModel> lotFamilyList = ViewBag.lotFamilyList;
    List<LotMachineModel> lotMachineList = ViewBag.lotMachineList;
    List<ProductFamilyModel> productFamilyList = ViewBag.productFamilyList;

    var lotList = lotFamilyList.Select(p => p.lot).Distinct();
    var lotFamilyGroup = lotFamilyList.GroupBy(i => i.lot).ToDictionary(g => g.Key, g => g.Select(i => i.family_station_area).ToList());
    var lotMachineGroup = lotMachineList.GroupBy(i => i.lot).ToDictionary(g => g.Key, g => g.Select(i => i.machine_name).ToList());

    var lotFamilyGroupJson = Newtonsoft.Json.JsonConvert.SerializeObject(lotFamilyGroup);
    var lotMachineGroupJson = Newtonsoft.Json.JsonConvert.SerializeObject(lotMachineGroup);
    string invalid_msg = "";
    if (userDetail.email == "")
    {
        invalid_msg = "User does not have Email registered!!";
    }
    else if (userDetail.manager_sesa_id == "")
    {
        invalid_msg = "User does not have Manager registered!!";
    }
    else if (userDetail.manager_email == "")
    {
        invalid_msg = "User Manager does not have Email registered!!";
    }
}

<style>
    .required {
        color: red;
    }

    .box_form_input {
        background-color: #fcfcfc;
        border-radius: 5px;
        box-shadow: 1px 2px 8px 2px rgba(152,152,152,0.7);
    }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 10pt;
    }


    table#table_asset_suggestion tr > td, table#table_asset_suggestion tr > th {
        padding: 5px;
    }

    .asset_suggestion {
        position: absolute;
        background-color: white;
        width: 100%;
        max-height: 200px;
        overflow: auto;
        display: none;
        box-shadow: 0px 7px 20px 1px rgba(0,0,0,0.21);
        z-index: 1000;
    }

    table#table_asset_selected tr > td, table#table_asset_selected tr > th {
        padding: 5px;
    }

    .data-container {
        position: relative;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: bold;
        z-index: 1000;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal {
        overflow: auto !important
    }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 12px;
        color: var(--text-light);
    }

    .dataTables_filter {
        display: none;
    }

    .list-card {
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        border: 1px solid #e9ecef;
        margin-bottom: 16px;
        transition: box-shadow 0.3s ease;
    }

        .list-card .card-body {
            padding: 16px;
        }

    .dataTables_info, .dataTables_paginate, .dataTables_filter {
        font-size: 12px;
        color: var(--text-light);
    }

    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
    }

        .hero .hero-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }

        .hero .hero-body {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        .hero .hero-title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.2px;
        }

    .inner {
        height: 70px;
        position: relative;
    }

    .hero .inner {
        background: rgba(0,0,0,0.7);
    }

    .professional-table {
        width: 100%;
        font-size: 12px;
        border-collapse: separate;
        border-spacing: 0;
        clip-path: inset(0 round 8px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

        .professional-table thead th {
            background: var(--primary-blue);
            color: white;
            font-weight: 600;
            padding: 16px 12px;
            text-align: center;
            vertical-align: middle;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .professional-table tbody td {
            padding: 12px;
            border: 1px solid #f0f0f0;
            vertical-align: middle;
        }

        .professional-table tbody tr:hover {
            background-color: var(--background-gray);
        }

        .professional-table th,
        .professional-table td {
            box-sizing: border-box;
        }

    .table-striped > tbody > tr:nth-of-type(odd),
    .table-striped > tbody > tr:nth-of-type(even),
    .dataTable tbody tr.odd,
    .dataTable tbody tr.even {
        background-color: #ffffff !important;
    }

        .dataTable tbody tr.odd > td,
        .dataTable tbody tr.even > td,
        .DTFC_Cloned tbody tr.odd > td,
        .DTFC_Cloned tbody tr.even > td,
        .table-striped > tbody > tr:nth-of-type(odd) > * {
            background-color: #ffffff !important;
            --bs-table-accent-bg: #ffffff !important;
        }

    #table_asset_selected tbody td {
        background-color: #ffffff !important;
    }

    #table_asset_selected thead th,
    #table_asset_selected tbody tr.search-row td {
        border: 0;
        box-shadow: none !important;
    }

    table.table_form {
        border-collapse: collapse;
    }

        table.table_form td {
            border: 1px solid #ccc;
            padding: 0;
        }

        table.table_form input, table.table_form select {
            border: none;
            width: 100%;
            box-sizing: border-box; 
            outline: none; 
            padding: 5px; 
        }

    #level {
        max-width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    table.table_form input:focus, table.table_form select:focus {
        border: 1px solid #007bff; 
    }

    .select2-container {
        width: 100% !important;
    }

    .select2-selection {
        width: 100% !important;
    }

    .select2-selection__rendered {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .select_family_station_area {
        max-width: 100%;
