<div id="pdf-popup-modal" class="modal fade" tabindex="-1" aria-labelledby="filelabel" aria-hidden="true">
    <div id="pdf-popup-content" class="modal-dialog modal-xl">
        <div class="modal-content" style="height:100%">
            <div class="modal-body">
                <iframe id="pdf-iframe" src="" style="width: 100%; height: 80vh;"></iframe>
                <button class="align-middle btn btn-sm btn-secondary" id="close_pdf_popup_btn" style="width:50%; position:relative; left:25%" onclick="closePDF()">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        var table;
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        const user_role = "@role";
        const user_sesa_id = "@sesa_id";
        const initial_gatepass_no = "@ViewBag.gatepass_no";

        function openPDF(filename) {
            var pdfURL = "../WI/" + filename;
            var iframe = document.getElementById("pdf-iframe");
            if (iframe) {
                $("#pdf-popup-modal").modal("show");
                iframe.src = pdfURL;
            } else {
                console.error("iframe element not found");
            }
        }

        function closePDF() {
            $("#pdf-popup-modal").modal("hide");
            var iframe = document.getElementById("pdf-iframe");
            iframe.src = "";
        }

        $(document).ready(function () {
            var table = $("#table_asset").DataTable({
                "processing": true,
                "serverSide": true,
                "filter": true,
                "scrollX": true,
                "scrollCollapse": true,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("GET_GATEPASS_HEADER")",
                    "type": "POST",
                    "datatype": "json",
                    "data": function (d) {
                        d.status = $("select[name=status]").val();
                    },
                    "error": function (xhr, error, thrown) {
                        console.error("Error in AJAX request:", error, thrown);
                    }
                },
                "columns": [
                    { "data": "id_gatepass", "className": "align-middle", "visible": false },
                    { "data": "gatepass_no", "className": "align-middle" },
                    {
                        "data": "proforma_no",
                        "className": "align-middle",
                        "render": function (data, type, row) {
                            return data ? data : '-';
                        }
                    },
                    {
                        "data": "category",
                        "className": "align-middle text-center",
                        render: function (data, type, row) {
                            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                                return `${data} (${row.type})`;
                            } else {
                                return data;
                            }
                        }
                    },
                    { "data": "requestor_name", "className": "align-middle" },
                    { "data": "create_date", "className": "align-middle" },
                    { "data": "return_date", "className": "align-middle" },
                    {
                        "data": "vendor_name",
                        "className": "align-middle",
                        "render": function (data, type, row) {
                            return data ? data : 'N/A';
                        }
                    },
                    {
                        "data": "status_gatepass",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            var badgeClass;
                            if (data === 'OPEN') {
                                badgeClass = 'bg-lime';
                            } else if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            } else if (data.includes('REJECT')) {
                                badgeClass = 'bg-danger';
                            } else if (data === 'TRANSFER') {
                                badgeClass = 'bg-cyan';
                            } else if (data === 'RETURN APPROVED') {
                                badgeClass = 'bg-secondary';
                            } else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            } else {
                                badgeClass = 'bg-dark';
                            }
                            return '<span class="badge ' + badgeClass + '">' + data + '</span>';
                        }
                    },
                    {
                        "data": "status_remark",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            if (!data) return '<span class="badge bg-secondary">-</span>';

                            var badgeClass;
                            var text = data;

                            if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            }
                            else if (data.includes('Rejected By')) {
                                badgeClass = 'bg-danger';
                            }
                            else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            }
                            else {
                                badgeClass = 'bg-dark';
                            }

                            return '<span class="badge ' + badgeClass + '" style="white-space: normal; word-wrap: break-word; max-width: 200px; display: inline-block;">' + text + '</span>';
                        }
                    },
                    {
                        "data": "id_gatepass",
                        render: function (data, type, row) {
                            let buttonHtml = '<button class="btn btn-info btn-sm" onclick="open_detail(`' + data + '`)"><i class="fas fa-info-circle"></i></button>';

                            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                                buttonHtml += ' <button class="btn btn-secondary btn-sm" onclick="gatepass_img(`' + data + '`)"><i class="fa fa-image"></i></button>';
                            } else if (row.category === "REPAIR TO VENDOR") {
                                buttonHtml += ' <button class="btn btn-secondary btn-sm" onclick="repair_img(`' + data + '`)"><i class="fa fa-image"></i></button>';
                            } else {
                                buttonHtml += ' <button class="btn btn-secondary btn-sm" onclick="show_img(`' + data + '`)"><i class="fa fa-image"></i></button>';
                            }

                            return buttonHtml;
                        }
                    },
                    {
                        "data": "id_gatepass", "class": "text-center",
                        render: function (data, type, row) {
                            let approval_btn = "";
                            let approval_color = "";
                            let status_gatepass = row['status_gatepass'];

                            if (row["can_approve_hod"] && row["approval_hod_status"] !== null) {
                                if (row['approval_hod_status'] == "OPEN" && status_gatepass == "OPEN") {
                                    approval_btn = "<button class='btn btn-sm btn-success' style='width:40%' onclick='update_approval(`" + data + "`,`hod`,`APPROVED`,`" + row['gatepass_no'] + "`)'><i class='fa fa-check'></i></button>" +
                                        "<button class='btn btn-sm btn-danger ml-1' style='width:40%' onclick='update_approval(`" + data + "`,`hod`,`REJECTED`,`" + row['gatepass_no'] + "`)'><i class='fa fa-times'></i></button>";
                                }
                                else {
                                    approval_color = (row['approval_hod_status'] == "APPROVED") ? "bg-success" : "bg-danger";
                                    approval_btn = "<label class='badge " + approval_color + "' style='font-size:12pt'>" + row['approval_hod_status'] + "</label>";
                                }
                            }

                            if (row["can_approve_fbp"] && row["approval_fbp_status"] !== null) {
                                if (row['approval_fbp_status'] == "OPEN" && status_gatepass == "OPEN") {
                                    approval_btn = "<button class='btn btn-sm btn-success' style='width:40%' onclick='update_approval(`" + data + "`,`fbp`,`APPROVED`,`" + row['gatepass_no'] + "`)'><i class='fa fa-check'></i></button>" +
                                        "<button class='btn btn-sm btn-danger ml-1' style='width:40%' onclick='update_approval(`" + data + "`,`fbp`,`REJECTED`,`" + row['gatepass_no'] + "`)'><i class='fa fa-times'></i></button>";
                                }
                                else {
                                    approval_color = (row['approval_fbp_status'] == "APPROVED") ? "bg-success" : "bg-danger";
                                    approval_btn = "<label class='badge " + approval_color + "' style='font-size:12pt'>" + row['approval_fbp_status'] + "</label>";
                                }
                            }

                            if (row["can_approve_ph"] && row["approval_ph_status"] !== null) {
                                if (row['approval_ph_status'] == "OPEN" && status_gatepass == "OPEN") {
                                    approval_btn = "<button class='btn btn-sm btn-success' style='width:40%' onclick='update_approval(`" + data + "`,`ph`,`APPROVED`,`" + row['gatepass_no'] + "`)'><i class='fa fa-check'></i></button>" +
                                        "<button class='btn btn-sm btn-danger ml-1' style='width:40%' onclick='update_approval(`" + data + "`,`ph`,`REJECTED`,`" + row['gatepass_no'] + "`)'><i class='fa fa-times'></i></button>";
                                }
                                else {
                                    approval_color = (row['approval_ph_status'] == "APPROVED") ? "bg-success" : "bg-danger";
                                    approval_btn = "<label class='badge " + approval_color + "' style='font-size:12pt'>" + row['approval_ph_status'] + "</label>";
                                }
                            }

                            if (row["can_confirm_hod"] && row["confirmation_hod_status"] !== null) {
                                if (row['confirmation_hod_status'] == "OPEN" && status_gatepass == "Waiting Confirmation by HOD") {
                                    approval_btn = "<button class='btn btn-sm btn-success' style='width:100%' onclick='confirm(`" + data + "`,`hod`,`APPROVED`,`" + row['gatepass_no'] + "`)'><i class='fa fa-flag'></i> CONFIRM</button>"
                                }
                                else {
                                    approval_color = (row['confirmation_hod_status'] == "APPROVED") ? "bg-success" : "bg-danger";
                                    approval_btn = "<label class='badge " + approval_color + "' style='font-size:12pt'>" + row['confirmation_hod_status'] + "</label>";
                                }
                            }

                            return approval_btn;
                        }
                    }
                ],
                "order": [[1, "desc"]],
                "initComplete": function(settings, json) {
                    var wrapper = $('#table_asset').closest('.dataTables_wrapper');
                    wrapper.css('position', 'relative');
                    $('#statusSelect').appendTo(wrapper).css('display', 'block');

                    $('#statusSelect').select2({
                        width: '150px',
                        minimumResultsForSearch: Infinity
                    });

                    $('#statusSelect').next('.select2-container').css({
                        'position': 'absolute',
                        'top': '0px',
                        'right': '245px'
                    }).attr('id', 'statusSelect2');

                    if (initial_gatepass_no && initial_gatepass_no.trim() !== '') {
                        this.api().search(initial_gatepass_no).draw();

                        $('div.dataTables_filter input').val(initial_gatepass_no);

                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                    }
                }
            });

            $("select[name=status]").change(function () {
                table.ajax.reload(null, false);
            });
        });

        function show_img(id_gatepass) {
            $.ajax({
                url: "@Url.Action("GET_IMG_GATEPASS", "Requestor")",
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function (data) {
                    var tableContent = '';
                    if (data.length > 0) {
                        $('#gatepass_no').text(data[0].gatepass_no);
                        data.forEach(function (item) {
                            tableContent += '<tr>';
                            tableContent += '<td class="align-middle text-center" style="width:15%">' + item.asset_no + '</td>';
                            tableContent += '<td class="align-middle text-center" style="width:15%">' + item.asset_subnumber + '</td>';
                            tableContent += '<td class="align-middle text-center"><img src="../Upload/GatePass/' + item.image_before + '" class="img-fluid" style="max-width: 50%; max-height:50%"></td>';
                            tableContent += '<td class="align-middle text-center"><img src="../Upload/GatePass/' + item.image_after + '" class="img-fluid" style="max-width: 50%; max-height:50%"></td>';
                            tableContent += '</tr>';
                        });
                    }
                    $('#image_table tbody').html(tableContent);
                    $('#modal_image').modal('show');
                    if ($.fn.DataTable.isDataTable('#image_table')) {
                        $('#image_table').DataTable().destroy();
                    }
                    $('#image_table').DataTable({
                        "initComplete": function (settings, json) {
                            $('.dataTables_length').css('margin-left', '-24rem');
                            $('.dataTables_info').css('margin-left', '-18rem');
                        }
                    });
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching images:', error);
                    alert('Failed to load images. Please try again.');
                }
            });
        }

        function repair_img(id_gatepass) {
            $.ajax({
                url: "@Url.Action("GET_IMG_GATEPASS", "Requestor")",
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function (data) {
