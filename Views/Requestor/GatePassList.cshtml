@section Scripts {

    <script>
        var table;
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        var sesa_id = "@user.sesa_id".toUpperCase();
        const initial_gatepass_no = "@ViewBag.gatepass_no";
        var basePath = '@Url.Content("~/")'

        function copyApprovalLink(gatepass_no) {
            const baseUrl = window.location.origin + basePath;
            const approvalLink = `${baseUrl}Redirect/GatePassList?gatepass_no=${encodeURIComponent(gatepass_no)}`;

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(approvalLink).then(() => {
                    Swal.fire({
                        title: 'Link Copied!',
                        text: 'Redirect link has been copied to clipboard',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });
                }).catch(err => {
                    console.error('Failed to copy: ', err);
                    fallbackCopyTextToClipboard(approvalLink);
                });
            } else {
                fallbackCopyTextToClipboard(approvalLink);
            }
        }

        function fallbackCopyTextToClipboard(text) {
            const textArea = document.createElement("textarea");
            textArea.value = text;
            
            textArea.style.top = "0";
            textArea.style.left = "0";
            textArea.style.position = "fixed";
            
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            
            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    Swal.fire({
                        title: 'Link Copied!',
                        text: 'Redirect link has been copied to clipboard',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });
                } else {
                    showLinkModal(text);
                }
            } catch (err) {
                console.error('Fallback: Oops, unable to copy', err);
                showLinkModal(text);
            }
            
            document.body.removeChild(textArea);
        }

        function showLinkModal(link) {
            Swal.fire({
                title: 'Copy Link',
                html: `<div class="form-group">
                        <label>Approval Link:</label>
                        <textarea class="form-control" rows="3" readonly style="font-size: 12px;">${link}</textarea>
                       </div>
                       <small class="text-muted">Please copy the link manually</small>`,
                icon: 'info',
                confirmButtonText: 'Close',
                width: '600px'
            });
        }

        function printGatepass(id_gatepass) {
            const url = `@Url.Action("PRINT_GATEPASS_PDF", "Export")?id_gatepass=${id_gatepass}`;
            window.open(url, '_blank');
        }

        function openPDF(filename) {
            var pdfURL = "../WI/" + filename;
            var iframe = document.getElementById("pdf-iframe");
            if (iframe) {
                $("#pdf-popup-modal").modal("show");
                iframe.src = pdfURL;
            } else {
                console.error("iframe element not found");
            }
        }

        function closePDF() {
            $("#pdf-popup-modal").modal("hide");
            var iframe = document.getElementById("pdf-iframe");
            iframe.src = "";
        }

        function downloadFile(filename, type) {
            if (!filename) {
                alert("File tidak tersedia");
                return;
            }

            let url = '';
            if (type === 'attach') {
                url = `../Upload/Proforma/${filename}`;
            } else if (type === 'support') {
                url = `../Upload/Proforma/${filename}`;
            }

            const fileExtension = filename.toLowerCase().split('.').pop();
            const imageExtensions = ['jpg', 'jpeg', 'png', 'gif', 'bmp'];
            const pdfExtensions = ['pdf'];

            if (imageExtensions.includes(fileExtension) || pdfExtensions.includes(fileExtension)) {
                window.open(url, '_blank');
            } else {
                const link = document.createElement('a');
                link.href = url;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        }

        $(document).ready(function () {
            var table = $("#table_asset").DataTable({
                "orderCellsTop": true,
                "processing": true,
                "serverSide": true,
                "filter": true,
                "scrollX": true,
                "scrollCollapse": true,
                "autoWidth": false,
                "order": [[1, 'desc']],
                "ajax": {
                    "url": "@Url.Action("GET_GATEPASS_LIST")",
                    "type": "POST",
                    "datatype": "json",
                    "data": function (d) {
                        d.status = $("select[name=status]").val();
                    }
                },
                "columns": [
                    {
                        "data": "id_gatepass",
                        "className": "align-middle",
                        "visible": false
                    },
                    { "data": "gatepass_no", "className": "align-middle" },
                    {
                        "data": "proforma_no",
                        "className": "align-middle",
                        "render": function (data, type, row) {
                            return data ? data : '<div class="text-center">-</div>';
                        }
                    },
                    {
                        "data": "category",
                        "className": "align-middle",
                        render: function (data, type, row) {
                            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                                return `${data} (${row.type})`;
                            } else {
                                return data;
                            }
                        }
                    },
                    { "data": "return_date", "className": "align-middle text-center" },
                    {
                        "data": "vendor_code",
                        "className": "align-middle text-center",
                        render: function (data, type, row) {
                            if (row.category === "TRANSFER PLANT TO PLANT" || row.category === "FA SALES - WITHOUT DISMANTLING") {
                                return 'N/A' + " <a href='javascript:void(0);' onclick='show_detail(`" + row['id_gatepass'] + "`)'><i class='text-secondary fas fa-info-circle'></i></a>";
                            } else if (row.category === "TRANSFER INSIDE PLANT") {
                                return 'N/A';
                            } else {
                                return data + " <a href='javascript:void(0);' onclick='show_detail(`" + row['id_gatepass'] + "`)'><i class='text-secondary fas fa-info-circle'></i></a>";
                            }
                        }
                    },
                    {
                        "data": "vendor_name",
                        "className": "align-middle",
                        render: function (data, type, row) {
                            if (data === null) {
                                return '<div class="text-center">N/A</div>';
                            } else {
                                return data;
                            }
                        }
                    },
                    { "data": "create_date", "className": "align-middle text-center" },
                    {
                        "data": "status_gatepass",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            var badgeClass;
                            if (data === 'OPEN') {
                                badgeClass = 'bg-lime';
                            } else if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            } else if (data.includes('REJECT')) {
                                badgeClass = 'bg-danger';
                            } else if (data === 'TRANSFER') {
                                badgeClass = 'bg-cyan';
                            } else if (data === 'RETURN APPROVED') {
                                badgeClass = 'bg-secondary';
                            } else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            } else {
                                badgeClass = 'bg-dark';
                            }
                            return '<span class="badge ' + badgeClass + '">' + data + '</span>';
                        }
                    },
                    {
                        "data": "status_remark",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            if (!data) return '<span class="badge bg-secondary">-</span>';

                            var badgeClass;
                            var text = data;

                            if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            }
                            else if (data.includes('Rejected By')) {
                                badgeClass = 'bg-danger';
                            }
                            else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            }
                            else {
                                badgeClass = 'bg-dark';
                            }

                            return '<span class="badge ' + badgeClass + '" style="white-space: normal; word-wrap: break-word; max-width: 200px; display: inline-block;">' + text + '</span>';
                        }
                    },
                    {
                        "data": "id_gatepass",
                        "className": "align-middle text-center",
                        "orderable": false,
                        "render": function (data, type, row) {
                            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                                return '<button class="btn btn-sm text-center align-middle btn-secondary mr-2" onclick="gatepass_img(\'' + data + '\')"><i class="fas fa-image"></i></button>';
                            } else if (row.category === "REPAIR TO VENDOR") {
                                return '<button class="btn btn-sm repair-img-btn text-center align-middle btn-secondary mr-2" data-id="' + data + '"><i class="fas fa-image"></i></button>';
                            } else {
                                return '<button class="btn btn-sm info-btn text-center align-middle btn-secondary mr-2" data-id="' + data + '"><i class="fas fa-image"></i></button>';
                            }
                        }
                    },
                    {
                        "data": "id_gatepass",
                        "className": "align-middle text-center",
                        "orderable": false,
                        "render": (data, type, row) => {
                            let buttons = '<div class="btn-group" role="group">';
                            buttons += `<button title="Gatepass Detail" class="btn btn-sm detail-btn text-center align-middle btn-info me-1" data-id="${data}"><i class="fas fa-info-circle"></i></button>`;

                            buttons += `<button class="btn btn-sm text-center align-middle btn-secondary me-1" onclick="copyApprovalLink('${row.gatepass_no}')" title="Copy Redirect Link">
                                        <i class="fas fa-link"></i></button>`;

                            if (row.category == "REPAIR TO VENDOR" && row.status_gatepass.toUpperCase() != "COMPLETE" && row.status_gatepass != "Waiting Confirmation by FIN SS" && row.status_gatepass != "Waiting Confirmation by HOD") {
                                buttons += `<button title="Edit" class="btn btn-sm text-center align-middle btn-secondary me-1" onclick="edit_gatepass('${data}','${row.category}')"><i class="fas fa-edit"></i></button>`;
                            }

                            if ((row.category !== "TRANSFER PLANT TO PLANT" && row.category !== "TRANSFER INSIDE PLANT") && row.image_after == null && row.status_gatepass === "TRANSFER") {
                                let text_confirm = (row.category == "REPAIR TO VENDOR") ? "Return" : "Complete"
                                buttons += `<button title="Confirm (${text_confirm})" class="btn btn-sm edit-btn text-center align-middle btn-primary me-1" onclick='update_gp_img("${data}", "${row['gatepass_no']}")'><i class="fas fa-upload"></i></button>`;
                            }

                            if ((row.category !== "TRANSFER INSIDE PLANT") && row.status_gatepass === "Waiting Security Validation") {
                                buttons += `<button class="btn btn-sm print-btn text-center align-middle btn-primary me-1" onclick='printGatepass(${data})'><i class="fas fa-print"></i></button>`;
                            }

                            if (row.status_gatepass === "OPEN") {
                                buttons += `<button title="Cancel Gatepass" class="btn btn-sm text-center align-middle btn-danger me-1" onclick="cancelGatepass('${data}', '${row.gatepass_no}')"><i class="fas fa-times-circle"></i></button>`;
                            }

                            buttons += '</div>';
                            return buttons;
                        }
                    }
                ],
                "initComplete": function(settings, json) {
                    var wrapper = $('#table_asset').closest('.dataTables_wrapper');
                    wrapper.css('position', 'relative');
                    $('#statusSelect').appendTo(wrapper).css('display', 'block');

                    $('#statusSelect').select2({
                        width: '150px',
                        minimumResultsForSearch: Infinity
                    });

                    $('#statusSelect').next('.select2-container').css({
                        'position': 'absolute',
                        'top': '0px',
                        'right': '0px'
                    }).attr('id', 'statusSelect2');

                    if (initial_gatepass_no && initial_gatepass_no.trim() !== '') {
                        table.column(1).search(initial_gatepass_no).draw();
                        $('input.filter_table[target="1"]').val(initial_gatepass_no);
                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                    }
                }
            });

            $('#statusSelect').change(function () {
                table.ajax.reload();
            });

            $('input.filter_table', this).on('keyup change', function () {
                let trgt = $(this).attr('target');
                if (table.column(trgt).search() !== this.value) {
                    table
                        .column(trgt)
                        .search(this.value)
                        .draw();
                }
            });

        });

