@section Scripts {

    <script>
        var table;
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        const user_role = "@role";
        const user_sesa_id = "@sesa_id";
        let currentGatepassId = 0;
        let uploadedFileTypes = [];
        let currentPebGatepassId = 0;
        let hasPebFile = false;
        const initial_gatepass_no = "@ViewBag.gatepass_no";

        function gatepass_img(id_gatepass) {
            $.ajax({
                url: "@Url.Action("GET_IMG_GATEPASS", "Requestor")",
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function (data) {
                    var tableContent = '';
                    $('#gatepass_no1').text(data[0].gatepass_no);
                    data.forEach(function (item) {
                        tableContent += '<tr>';
                        tableContent += '<td class="align-middle text-center" style="width:15%">' + item.asset_no + '</td>';
                        tableContent += '<td class="align-middle text-center" style="width:15%">' + item.asset_subnumber + '</td>';
                        tableContent += '<td class="align-middle text-center"><img src="../Upload/GatePass/' + item.image_before + '" class="img-fluid" style="max-width: 50%; max-height:50%"></td>';
                        tableContent += '</tr>';
                    });

                    if ($.fn.DataTable.isDataTable('#image_table1')) {
                        $('#image_table1').DataTable().destroy();
                    }

                    $('#image_table1 tbody').html(tableContent);

                    $('#image_table1').DataTable({
                        "initComplete": function (settings, json) {
                            $('#image_table1_length').css('margin-left', '-24rem');
                            $('#image_table1_info').css('margin-left', '-18rem');
                        }
                    });

                    $('#modal_image1').modal('show');
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching images:', error);
                    alert('Failed to load images. Please try again.');
                }
            });
        }

        $(document).ready(function () {
            var table = $("#table_asset").DataTable({
                "orderCellsTop": true,
                "processing": true,
                "serverSide": true,
                "filter": true,
                "scrollX": true,
                "scrollCollapse": true,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("GET_GATEPASS_HEADER")",
                    "type": "POST",
                    "datatype": "json",
                    "data": function (d) {
                        d.status = $("select[name=status]").val();
                    },
                    "error": function (xhr, error, thrown) {
                        console.error("Error in AJAX request:", error, thrown);
                    }
                },
                "columns": [
                    { "data": "id_gatepass", "className": "align-middle", "visible": false },
                    { "data": "gatepass_no", "className": "align-middle" },
                    {
                        "data": "proforma_no",
                        "className": "align-middle",
                        "render": function (data, type, row) {
                            return data ? data : '<div class="text-center">-</div>';
                        }
                    },
                    {
                        "data": "category",
                        "className": "align-middle",
                        render: function (data, type, row) {
                            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                                return `${data} (${row.type})`;
                            } else {
                                return data;
                            }
                        }
                    },
                    { "data": "requestor_name", "className": "align-middle" },
                    { "data": "create_date", "className": "align-middle text-center" },
                    { "data": "return_date", "className": "align-middle text-center" },
                    { "data": "vendor_name", "className": "align-middle" },
                    {
                        "data": "status_gatepass",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            var badgeClass;
                            if (data === 'OPEN') {
                                badgeClass = 'bg-lime';
                            } else if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            } else if (data.includes('REJECT')) {
                                badgeClass = 'bg-danger';
                            } else if (data === 'TRANSFER') {
                                badgeClass = 'bg-cyan';
                            } else if (data === 'RETURN APPROVED') {
                                badgeClass = 'bg-secondary';
                            } else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            } else {
                                badgeClass = 'bg-dark';
                            }
                            return '<span class="badge ' + badgeClass + '">' + data + '</span>';
                        }
                    },
                    {
                        "data": "status_remark",
                        "className": "align-middle text-center",
                        "render": function (data, type, row) {
                            if (!data) return '<span class="badge bg-secondary">-</span>';

                            var badgeClass;
                            var text = data;

                            if (data.includes('Waiting')) {
                                badgeClass = 'bg-warning text-dark';
                            }
                            else if (data.includes('Rejected By')) {
                                badgeClass = 'bg-danger';
                            }
                            else if (data === 'COMPLETED') {
                                badgeClass = 'bg-success';
                            }
                            else {
                                badgeClass = 'bg-dark';
                            }

                            return '<span class="badge ' + badgeClass + '" style="white-space: normal; word-wrap: break-word; max-width: 200px; display: inline-block;">' + text + '</span>';
                        }
                    },
                    {
                        "data": "id_gatepass",
                        "className": "align-middle text-center",
                        render: function (data, type, row) {
                            let buttonHtml = '<div class="btn-group" role="group">';
                            buttonHtml += `<button title="Open Details" class="btn btn-info btn-sm me-1" onclick="open_detail(\`${data}\`)"><i class="fa fa-info-circle"></i></button>`;

                            if (row.category === "FA SALES - WITHOUT DISMANTLING") {
                                buttonHtml += `<button title="View Images" class="btn btn-secondary btn-sm me-1" onclick="gatepass_img(\`${data}\`)"><i class="fa fa-image"></i></button>`;
                            } else if (row.category === "REPAIR TO VENDOR") {
                                buttonHtml += `<button title="View Images" class="btn btn-secondary btn-sm me-1" onclick="repair_img(\`${data}\`)"><i class="fa fa-image"></i></button>`;
                            } else {
                                buttonHtml += `<button title="View Images" class="btn btn-secondary btn-sm me-1" onclick="show_img(\`${data}\`)"><i class="fa fa-image"></i></button>`;
                            }

                            if (row.proforma_fin_status === 'OPEN') {
                                buttonHtml += `<button title="Upload Proforma Documents" class="btn btn-primary btn-sm me-1" onclick="openProformaUpload(\`${data}\`, \`${row.gatepass_no}\`)"><i class="fa fa-file-export"></i></button>`;
                            }

                            if (row.shipping_status === 'CLOSED' && row.proforma_fin_status === 'SHIPPING') {
                                buttonHtml += `<button title="Upload PEB Document" class="btn btn-primary btn-sm me-1" onclick="openPebUpload(\`${data}\`, \`${row.gatepass_no}\`)"><i class="fa fa-file-upload"></i></button>`;
                            }

                            buttonHtml += '</div>';
                            return buttonHtml;
                        }
                    },
                    {
                        "data": "id_gatepass",
                        "class": "text-center align-middle",
                        render: function (data, type, row) {
                            let approval_btn = "";
                            let approval_color = "";
                            let status_gatepass = row['status_gatepass'];
                            let approval_finance_status = row['approval_finance_status'];
                            let image_after = row['image_after'];

                            if (status_gatepass === "Waiting Confirmation by FIN SS" && image_after !== null) {
                                approval_btn = `
                                    <div class="btn-group" role="group" aria-label="Approval actions">
                                        <button title="Approve" class='btn btn-sm btn-success me-1' onclick='update_approval("${data}", "APPROVED", "${row['gatepass_no']}")'>
                                            <i class='fa fa-check'></i>
                                        </button>
                                        <button title="Reject" class='btn btn-sm btn-danger me-1' onclick='update_approval("${data}", "REJECTED", "${row['gatepass_no']}")'>
                                            <i class='fa fa-times'></i>
                                        </button>
                                    </div>
                                `;
                            } else if (status_gatepass !== "Waiting Confirmation by FIN SS" && status_gatepass !== "COMPLETED" || row['category'] === 'FA SALES - WITHOUT DISMANTLING') {
                                approval_btn = "N/A";
                            } else {
                                approval_color = (approval_finance_status === "APPROVED") ? "bg-success" : "bg-danger";
                                approval_btn = `<label class='badge ${approval_color}' title='${approval_finance_status}' style='font-size:12pt'>${approval_finance_status}</label>`;
                            }

                            return approval_btn;
                        }
                    }
                ],
                "order": [[8, "desc"]],
                "initComplete": function(settings, json) {
                    var wrapper = $('#table_asset').closest('.dataTables_wrapper');
                    wrapper.css('position', 'relative');
                    $('#statusSelect').appendTo(wrapper).css('display', 'block');

                    $('#statusSelect').select2({
                        width: '150px',
                        minimumResultsForSearch: Infinity
                    });

                    $('#statusSelect').next('.select2-container').css({
                        'position': 'absolute',
                        'top': '0px',
                        'right': '0px'
                    }).attr('id', 'statusSelect2');

                    if (initial_gatepass_no && initial_gatepass_no.trim() !== '') {
                        table.column(1).search(initial_gatepass_no).draw();
                        $('input.filter_table[target="1"]').val(initial_gatepass_no);
                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                    }
                }
            });

            $('input.filter_table').on('keyup change', function () {
                let trgt = $(this).attr('target');
                if (table.column(trgt).search() !== this.value) {
                    table.column(trgt).search(this.value).draw();
                }
            });

            $('#statusSelect').change(function () {
                table.ajax.reload();
            });

        });

