            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteTempNonAssetBox")',
                        type: 'POST',
                        data: { id_temp: id_temp },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Deleted!', 'Box has been deleted', 'success');

                                loadShippingItemsNonAsset($('#currentIdGatepassNonAsset').val());
                                loadCombinedBoxesNonAsset($('#currentIdGatepassNonAsset').val());
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error deleting non-asset box:', error);
                            Swal.fire('Error!', 'Failed to delete box', 'error');
                        }
                    });
                }
            });
        }

