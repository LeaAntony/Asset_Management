        function update_approval(id_gatepass, approval_status, gatepass_no) {
            let text_status = (approval_status == "APPROVED") ? "CONFIRM" : "REJECT";
            Swal.fire({
                title: 'Confirmation',
                html: `
                <div>
                    Are you sure you want to ${text_status}?<br>${gatepass_no}<br>
                    <textarea class="form-control mt-3" id="approval_remark" rows="3" style="width: 100%; margin-top:1rem" placeholder="Type Remark..."></textarea>
                </div>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes!',
                cancelButtonText: 'No!',
                showLoaderOnConfirm: true,
                preConfirm: function () {
                    let approval_remark = $("#approval_remark").val().trim();

                    if (!approval_remark) {
                        Swal.showValidationMessage('Remark is required! Please provide a remark before proceeding.');
                        return false;
                    }

                    return new Promise(function (resolve, reject) {
                        $.ajax({
                            type: "POST",
                            url: "@Url.Action("UPDATE_FINANCE_GATEPASS")",
                            data: {
                                id_gatepass: id_gatepass,
                                approval_status: approval_status,
                                approval_remark: approval_remark
                            }
                        }).done(function (res) {
                            let arr = res.split(";");
                            if (arr[0] == "success") {
                                let email_remark = "";
                                if (arr[1] != "success") {
                                    email_remark = "<br>Failed to Send Email Approval Update: " + arr[1];
                                }
                                resolve();
                                Swal.fire("Success", "Approval updated!!" + email_remark, "success").then(function () {
                                    location.reload();
                                });
                            } else {
                                reject(res);
                                Swal.fire("Error!", res, "error");
                            }
                        }).fail(function (err) {
                            console.error("AJAX error: ", err);
                            reject(err.responseText);
                            Swal.fire("Action Error!", err.responseText, "error");
                        });
                    });
                },
                allowOutsideClick: () => !Swal.isLoading(),
            });

        }

        function openProformaUpload(id_gatepass, gatepass_no) {
            currentGatepassId = id_gatepass;
            $('#proforma_gatepass_no').text(gatepass_no);
            loadProformaFiles(id_gatepass);
            $('#modal_proforma_upload').modal('show');
        }

        function loadProformaFiles(id_gatepass) {
            $.ajax({
                url: "@Url.Action("GET_PROFORMA_FIN_FILES")",
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function (data) {
                    uploadedFileTypes = [];
                    let filesHtml = '';
                    if (data && data.length > 0) {
                        data.forEach(function (file, index) {
                            uploadedFileTypes.push(file.document_type);
                            filesHtml += `
                                <div class="row mb-2 p-2" style="background-color: #fff; border: 1px solid #dee2e6; border-radius: 3px;">
                                    <div class="col-md-3 align-middle">${file.filename}</div>
                                    <div class="col-md-3 align-middle">${file.document_type}</div>
                                    <div class="col-md-3 text-center align-middle">
                                        <a href="/Upload/Proforma_Finance/${file.filename}" target="_blank" class="btn btn-sm btn-info">
                                            <i class="fa fa-eye"></i> View
                                        </a>
                                    </div>
                                    <div class="col-md-3 text-center align-middle">
                                        <span class="badge bg-success">Uploaded</span>
                                        <button class="btn btn-sm btn-danger ml-2" onclick="deleteProformaFile(${file.id_file}, '${file.document_type}')">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            `;
                        });
                    } else {
                        filesHtml = '<div class="text-center text-muted">No files uploaded yet</div>';
                    }
                    $('#proforma_files_container').html(filesHtml);

                    updateFileTypeDropdown();
                },
                error: function (xhr, status, error) {
                    console.error('Error loading files:', error);
                    $('#proforma_files_container').html('<div class="text-center text-danger">Error loading files</div>');
                }
            });
        }

        function updateFileTypeDropdown() {
            let dropdown = $('#file_type_select');
            let allOptions = [
                { value: "PPE", text: "PPE" },
                { value: "Proforma Invoice", text: "Proforma Invoice" },
                { value: "Export Explanation", text: "Export Explanation" },
                { value: "Purchase Order", text: "Purchase Order" },
                { value: "Buyer Statement", text: "Buyer Statement" },
                { value: "Bill of Lading", text: "Bill of Lading" },
                { value: "Others", text: "Others" }
            ];

            dropdown.empty();
            dropdown.append('<option value="">-- Select Type --</option>');

            allOptions.forEach(function(option) {
                if (!uploadedFileTypes.includes(option.value)) {
                    dropdown.append(`<option value="${option.value}">${option.text}</option>`);
                }
            });

            if (uploadedFileTypes.length >= allOptions.length) {
                dropdown.append('<option value="" disabled>All document types have been uploaded</option>');
            }
        }

        function uploadProformaFile() {
            let fileType = $('#file_type_select').val();
            let fileInput = $('#file_upload_input')[0];

            if (!fileType) {
                Swal.fire('Error', 'Please select document type first', 'error');
                return;
            }

            if (!fileInput.files || fileInput.files.length === 0) {
                Swal.fire('Error', 'Please select a file first', 'error');
                return;
            }

            if (uploadedFileTypes.includes(fileType)) {
                Swal.fire('Error', `A file for document type "${fileType}" has already been uploaded. Please delete the existing file first or choose a different document type.`, 'error');
                return;
            }

            let formData = new FormData();
            formData.append('file', fileInput.files[0]);
            formData.append('id_gatepass', currentGatepassId);
            formData.append('file_type', fileType);

            $.ajax({
                url: "@Url.Action("UPLOAD_PROFORMA_FIN_FILES")",
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    if (response === 'success') {
                        Swal.fire('Success', 'File uploaded successfully', 'success');
                        loadProformaFiles(currentGatepassId);
                        clearUploadForm();
                    } else {
                        Swal.fire('Error', response, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    Swal.fire('Error', 'Failed to upload file', 'error');
                }
            });
        }

        function deleteProformaFile(fileId, documentType) {
            Swal.fire({
                title: 'Confirmation',
                text: `Are you sure you want to delete this ${documentType} file?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "@Url.Action("DELETE_PROFORMA_FIN_FILE")",
                        type: 'POST',
                        data: {
                            id_file: fileId,
                            id_gatepass: currentGatepassId
                        },
                        success: function (response) {
                            if (response === 'success') {
                                Swal.fire('Success', 'File deleted successfully', 'success');
                                loadProformaFiles(currentGatepassId);
                            } else {
                                Swal.fire('Error', response, 'error');
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire('Error', 'Failed to delete file', 'error');
                        }
                    });
                }
            });
        }

        function clearUploadForm() {
            $('#file_type_select').val('');
            $('#file_upload_input').val('');
        }

        function completeProformaUpload() {
            Swal.fire({
                title: 'Confirmation',
                text: 'Are you sure you want to complete the upload process? Proforma status will be changed to Closed.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes, Complete',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "@Url.Action("COMPLETE_PROFORMA_FIN_UPLOAD")",
                        type: 'POST',
                        data: { id_gatepass: currentGatepassId },
                        success: function (response) {
                            if (response === 'success') {
                                Swal.fire('Success', 'Upload process completed. Proforma status has been changed to Closed.', 'success').then(() => {
                                    $('#modal_proforma_upload').modal('hide');
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error', response, 'error');
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire('Error', 'Failed to complete upload process', 'error');
                        }
                    });
                }
            });
        }

        function openOrDownloadFile(filename) {
            if (!filename) {
                alert("Files not available");
                return;
            }

            let url = `/Upload/Proforma_Finance/${filename}`;
            const fileExtension = filename.toLowerCase().split('.').pop();
            const imageExtensions = ['jpg', 'jpeg', 'png', 'gif', 'bmp'];
            const pdfExtensions = ['pdf'];

            if (imageExtensions.includes(fileExtension) || pdfExtensions.includes(fileExtension)) {
                window.open(url, '_blank');
            } else {
                const link = document.createElement('a');
                link.href = url;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        }

        function openPebUpload(id_gatepass, gatepass_no) {
            currentPebGatepassId = id_gatepass;
            $('#peb_gatepass_no').text(gatepass_no);
            loadPebFile(id_gatepass);
            $('#modal_peb_upload').modal('show');
        }

        function loadPebFile(id_gatepass) {
            $.ajax({
                url: "@Url.Action("GET_PEB_FILE")",
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function (data) {
                    let fileHtml = '';
                    hasPebFile = false;

                    if (data && data.filename) {
                        hasPebFile = true;
                        let filenames = data.filename.split(';');

                        fileHtml = '<div class="alert alert-light"><strong>Current PEB Files:</strong><br>';

                        filenames.forEach(function(filename, index) {
                            if (filename.trim()) {
                                fileHtml += `
                                    <div class="row mb-2">
                                        <div class="col-md-6">
                                            ${filename}<br>
                                        </div>
                                        <div class="col-md-6 text-right">
                                            <button class="btn btn-sm btn-info" onclick="viewPebFile('${filename}')">
                                                <i class="fa fa-eye"></i> View
                                            </button>
                                            <button class="btn btn-sm btn-danger ml-2" onclick="deletePebFile('${filename}')">
                                                <i class="fa fa-trash"></i> Delete
                                            </button>
                                        </div>
                                    </div>
                                `;
                            }
                        });
                        fileHtml += '</div>';
                    } else {
                        fileHtml = '<div class="alert alert-warning">No PEB documents uploaded yet.</div>';
                    }

                    $('#peb_file_container').html(fileHtml);
                },
                error: function (xhr, status, error) {
                    console.error('Error loading PEB files:', error);
                    $('#peb_file_container').html('<div class="alert alert-danger">Error loading PEB files</div>');
                }
            });
        }

        function uploadPebFile() {
            let fileInput = $('#peb_upload_input')[0];

            if (!fileInput.files || fileInput.files.length === 0) {
                Swal.fire('Error', 'Please select at least one file', 'error');
                return;
            }

            let formData = new FormData();

            for (let i = 0; i < fileInput.files.length; i++) {
                formData.append('files', fileInput.files[i]);
            }
            formData.append('id_gatepass', currentPebGatepassId);

            $.ajax({
                url: "@Url.Action("UPLOAD_PEB_FILE")",
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    if (response === 'success') {
                        Swal.fire('Success', 'PEB files uploaded successfully', 'success');
                        loadPebFile(currentPebGatepassId);
                        clearPebForm();
                    } else {
                        Swal.fire('Error', response, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    Swal.fire('Error', 'Failed to upload PEB files', 'error');
                }
            });
        }

        function deletePebFile(filename) {
            let confirmText = filename ? `Are you sure you want to delete "${filename}"?` : 'Are you sure you want to delete all PEB documents?';

            Swal.fire({
                title: 'Confirmation',
                text: confirmText,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "@Url.Action("DELETE_PEB_FILE")",
                        type: 'POST',
                        data: {
                            id_gatepass: currentPebGatepassId,
                            filename: filename
                        },
                        success: function (response) {
                            if (response === 'success') {
                                Swal.fire('Success', 'PEB file deleted successfully', 'success');
                                loadPebFile(currentPebGatepassId);
                            } else {
                                Swal.fire('Error', response, 'error');
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire('Error', 'Failed to delete PEB file', 'error');
                        }
                    });
                }
            });
        }

        function completePebUpload() {
            if (!hasPebFile) {
                Swal.fire('Error', 'Please upload at least one PEB document first', 'error');
