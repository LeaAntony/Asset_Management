        function resetShippingFormNonAsset() {
            $('#plantSelectNonAsset').val('');
            $('#shipmentDateNonAsset').val('');
            $('#shipmentTypeInputNonAsset').val('');
            $('#dhlAwbInputNonAsset').val('');
            $('#itemTableBodyNonAsset').empty();
            $('#boxTableBodyNonAsset').empty();
            $('#selectAllItemsNonAsset').prop('checked', false);
            $('#createBoxBtnNonAsset').prop('disabled', true).show();
            $('#saveShippingBtnNonAsset').show();
            $('#exportExcelBtnNonAsset').hide();
            $('#submitShippingBtnNonAsset').hide();
            $('#shipmentTypeContainerNonAsset').hide();
            $('#dhlAwbContainerNonAsset').hide();

            window.isDataCompleteInDbNonAsset = false;
            currentBoxCountNonAsset = 0;
        }

        function loadShippingDataNonAsset(id_gatepass) {
            $.ajax({
                url: '@Url.Action("GetNonAssetShippingData")',
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function(data) {
                    if (data.shipping_plant) {
                        $('#plantSelectNonAsset').val(data.shipping_plant);
                        $('#plantSelectNonAsset').prop('disabled', true);
                    } else if (data.plant) {
                        $('#plantSelectNonAsset').val(data.plant);
                        $('#plantSelectNonAsset').prop('disabled', false);
                    }

                    if (data.shipment_date) {
                        const date = new Date(data.shipment_date);
                        $('#shipmentDateNonAsset').val(date.toISOString().split('T')[0]);
                    }

                    $('#shipmentTypeContainerNonAsset').show();
                    $('#dhlAwbContainerNonAsset').show();

                    if (data.shipment_type) {
                        $('#shipmentTypeInputNonAsset').val(data.shipment_type);
                    }

                    if (data.dhl_awb) {
                        $('#dhlAwbInputNonAsset').val(data.dhl_awb);
                    }

                    window.isDataCompleteInDbNonAsset = data.is_data_complete_in_db || false;

                    loadCombinedBoxesNonAsset(id_gatepass);

                    loadShippingItemsNonAsset(id_gatepass);

                    checkAllItemsAssignedNonAsset();
                },
                error: function(xhr, status, error) {
                    console.error('Error loading non-asset shipping data:', error);
                }
            });
        }

        function loadCombinedBoxesNonAsset(id_gatepass) {
            $.ajax({
                url: '@Url.Action("GetCombinedNonAssetBoxes")',
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function(data) {
                    let html = '';
                    currentBoxCountNonAsset = 0;
                    let hasSavedBoxes = false;
                    let hasTempBoxes = false;

                    if (data.saved_boxes && data.saved_boxes.length > 0) {
                        hasSavedBoxes = true;

                        data.saved_boxes.sort((a, b) => {
                            let aNum = parseInt(a.box_no.replace('Box ', '')) || 0;
                            let bNum = parseInt(b.box_no.replace('Box ', '')) || 0;
                            return aNum - bNum;
                        });

                        data.saved_boxes.forEach(function(box) {
                            currentBoxCountNonAsset++;
                            let itemDisplay = box.item_count + ' items';
                            html += `
                                <tr>
                                    <td>${box.box_no}</td>
                                    <td>${itemDisplay}</td>
                                    <td>${box.length_cm}�${box.width_cm}�${box.height_cm}</td>
                                    <td>${box.gross_weight_kg}</td>
                                    <td>${box.net_weight_kg}</td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" onclick="deleteSavedBoxNonAsset(${box.id_box})">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        <span class="badge badge-success ml-2">Saved</span>
                                    </td>
                                </tr>
                            `;
                        });
                    }

                    if (data.temp_boxes && data.temp_boxes.length > 0) {
                        hasTempBoxes = true;

                        data.temp_boxes.sort((a, b) => {
                            let aNum = parseInt(a.box_no.replace('Box ', '')) || 0;
                            let bNum = parseInt(b.box_no.replace('Box ', '')) || 0;
                            return aNum - bNum;
                        });

                        data.temp_boxes.forEach(function(box) {
                            currentBoxCountNonAsset++;
                            let itemDisplay = box.item_list ? box.item_list.split(',').length + ' items' : '0 items';
                            html += `
                                <tr>
                                    <td>${box.box_no}</td>
                                    <td>${itemDisplay}</td>
                                    <td>${box.length_cm}�${box.width_cm}�${box.height_cm}</td>
                                    <td>${box.gross_weight_kg}</td>
                                    <td>${box.net_weight_kg}</td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" onclick="deleteBoxNonAsset(${box.id_temp})">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        <span class="badge badge-info ml-2">Temp</span>
                                    </td>
                                </tr>
                            `;
                        });
                    }

                    $('#boxTableBodyNonAsset').html(html);

                    $('#createBoxBtnNonAsset').show();
                    $('#saveShippingBtnNonAsset').show();

                    checkAllItemsAssignedNonAsset();
                },
                error: function(xhr, status, error) {
                    console.error('Error loading combined non-asset boxes:', error);
                }
            });
        }

        function loadShippingItemsNonAsset(id_gatepass) {
            $.ajax({
                url: '@Url.Action("GetShippingNonAssets")',
                type: 'GET',
                data: { id_gatepass: id_gatepass },
                success: function(data) {
                    let html = '';
                    data.forEach(function(item) {
                        let isDisabled = item.is_assigned;
                        let boxStatus = '';
                        let badgeClass = '';

                        if (item.id_box > 0) {
                            boxStatus = 'Assigned to Box';
                            badgeClass = 'badge-success';
                        } else if (item.is_assigned) {
                            boxStatus = 'In Temp Box';
                            badgeClass = 'badge-info';
                        } else {
                            boxStatus = 'Not Assigned';
                            badgeClass = 'badge-warning';
                        }

                        let hsCodeValue = item.hs_code ? item.hs_code.toString() : '';

                        html += `
                            <tr>
                                <td>
                                    <input type="checkbox" class="item-checkbox"
                                           data-id="${item.id_detail}"
                                           data-item="${item.po_or_asset_no}"
                                           ${isDisabled ? 'disabled' : ''} />
                                </td>
                                <td>${item.po_or_asset_no}</td>
                                <td>${item.description}</td>
                                <td>${item.qty}</td>
                                <td>${item.uom}</td>
                                <td>${item.price_value}</td>
                                <td class="text-center">
                                    <input type="text" class="form-control form-control-sm hs-code-input-nonasset"
                                           style="min-width: 100px;"
                                           value="${hsCodeValue}"
                                           data-item-id="${item.id_detail}"
                                           data-po-item="${item.po_or_asset_no}"
                                           placeholder="Enter HS Code" />
                                </td>
                                <td><span class="badge ${badgeClass}">${boxStatus}</span></td>
                            </tr>
                        `;
                    });
                    $('#itemTableBodyNonAsset').html(html);

                    $('.hs-code-input-nonasset').on('blur', function() {
                        updateHSCodeNonAsset($(this));
                    });

                    updateCreateBoxButtonNonAsset();
                    checkAllItemsAssignedNonAsset();
                },
                error: function(xhr, status, error) {
                    console.error('Error loading non-asset items:', error);
                    Swal.fire('Error!', 'Failed to load items', 'error');
                }
            });
        }

        function updateCreateBoxButtonNonAsset() {
            let selectedCount = $('#itemTableNonAsset tbody input[type="checkbox"]:checked:not(:disabled)').length;
            $('#createBoxBtnNonAsset').prop('disabled', selectedCount === 0);
        }

        function updateSelectAllCheckboxNonAsset() {
            let totalEnabled = $('#itemTableNonAsset tbody input[type="checkbox"]:not(:disabled)').length;
            let checkedEnabled = $('#itemTableNonAsset tbody input[type="checkbox"]:checked:not(:disabled)').length;

            $('#selectAllItemsNonAsset').prop('checked', totalEnabled > 0 && checkedEnabled === totalEnabled);
        }

        function openCreateBoxModalNonAsset() {
            let selectedItems = [];
            $('#itemTableNonAsset tbody input[type="checkbox"]:checked:not(:disabled)').each(function() {
                let itemInfo = $(this).data('item');
                selectedItems.push(itemInfo);
            });

            if (selectedItems.length === 0) {
                Swal.fire('Warning!', 'Please select at least one item', 'warning');
                return;
            }

            let itemHtml = selectedItems.map(item => `<span class="badge badge-info mr-1">${item}</span>`).join('');
            $('#selectedItemsListNonAsset').html(itemHtml);

            $('#createBoxFormNonAsset')[0].reset();

            $('#createBoxModalNonAsset').modal('show');
        }

        function submitBoxNonAsset() {
            if (!$('#createBoxFormNonAsset')[0].checkValidity()) {
                $('#createBoxFormNonAsset')[0].reportValidity();
                return;
            }

            let selectedItemIds = [];
            $('#itemTableNonAsset tbody input[type="checkbox"]:checked:not(:disabled)').each(function() {
                selectedItemIds.push($(this).data('id'));
            });

            let nextBoxNumber = getNextAvailableBoxNumberNonAsset();

            let boxData = {
                id_gatepass: parseInt($('#currentIdGatepassNonAsset').val()),
                box_no: `Box ${nextBoxNumber}`,
                length_cm: parseFloat($('#boxLengthNonAsset').val()),
                width_cm: parseFloat($('#boxWidthNonAsset').val()),
                height_cm: parseFloat($('#boxHeightNonAsset').val()),
                gross_weight_kg: parseFloat($('#grossWeightNonAsset').val()),
                net_weight_kg: parseFloat($('#netWeightNonAsset').val()),
                item_list: selectedItemIds.join(',')
            };

            $.ajax({
                url: '@Url.Action("CreateTempNonAssetBox")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(boxData),
                success: function(response) {
                    if (response.success) {
                        Swal.fire('Success!', 'Box created successfully', 'success');
                        $('#createBoxModalNonAsset').modal('hide');

                        loadShippingItemsNonAsset($('#currentIdGatepassNonAsset').val());
                        loadCombinedBoxesNonAsset($('#currentIdGatepassNonAsset').val());

                        $('#submitShippingBtnNonAsset').hide();
                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error creating non-asset box:', error);
                    Swal.fire('Error!', 'Failed to create box', 'error');
                }
            });
        }

        function getNextAvailableBoxNumberNonAsset() {
            let existingBoxNumbers = [];

            $('#boxTableBodyNonAsset tr').each(function() {
                let boxName = $(this).find('td:first').text().trim();
                if (boxName.startsWith('Box ')) {
                    let boxNumber = parseInt(boxName.replace('Box ', ''));
                    if (!isNaN(boxNumber)) {
                        existingBoxNumbers.push(boxNumber);
                    }
                }
            });

            existingBoxNumbers.sort((a, b) => a - b);

            let nextNumber = 1;
            for (let num of existingBoxNumbers) {
                if (num === nextNumber) {
                    nextNumber++;
                } else {
                    break;
                }
            }

            return nextNumber;
        }

