                                                    <th>Request ID</th>
                                                    <th>Category</th>
                                                    <th>Request By</th>
                                                    <th>Request Date</th>
                                                    <th>Return Date</th>
                                                    <th>Vendor Name</th>
                                                    <th>Status</th>
                                                    <th>Status Remark</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="row table-container" id="closedTableContainer">
                                    <div class="col-12">
                                        <table class="table professional-table align-center nowrap" id="table_shipping_closed" style="font-size:8pt; width:100%">
                                            <thead class="align-middle text-center" style="background: var(--primary-blue); color: white; font-weight: 600;">
                                                <tr>
                                                    <th>Request ID</th>
                                                    <th>Proforma No</th>
                                                    <th>Category</th>
                                                    <th>Request By</th>
                                                    <th>Request Date</th>
                                                    <th>Return Date</th>
                                                    <th>Vendor Name</th>
                                                    <th>Status</th>
                                                    <th>Status Remark</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div id="loadingSpinner" style="display: none;">
                <span class="spinner-border spinner-border" role="status" aria-hidden="true"></span>
            </div>
        </div>
    </div>
</div>

<select class="form-select" name="status" id="statusSelect" style="width: auto; display: none;">
    <option value="OPEN">SHIPPING OPEN</option>
    <option value="CLOSE">SHIPPING CLOSED</option>
</select>

<div class="modal fade" id="shippingModal" tabindex="-1" role="dialog" aria-labelledby="shippingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5><i class="fas fa-ship mr-2"></i>Create Shipping Data - <span id="modalGatepassNo"></span></h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="currentIdGatepass" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="plantSelect">Select Plant <span class="text-danger">*</span></label>
                        <select class="form-control" id="plantSelect" required>
                            <option value="">-- Select Plant --</option>
                            <option value="JHO">JHO</option>
                            <option value="BMS 1">BMS 1</option>
                            <option value="BMS 2">BMS 2</option>
                            <option value="SDH">SDH</option>
                            <option value="BRC">BRC</option>
                            <option value="MRO">MRO</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="shipmentDate">Shipment Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="shipmentDate" required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6" id="shipmentTypeContainer" style="display: none;">
                        <label for="shipmentTypeInput">Shipment Type <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="shipmentTypeInput" readonly />
                    </div>
                    <div class="col-md-6" id="dhlAwbContainer" style="display: none;">
                        <label for="dhlAwbInput">DHL AWB</label>
                        <input type="text" class="form-control" id="dhlAwbInput" placeholder="Enter DHL AWB number" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-12">
                        <h6><i class="fas fa-boxes mr-2"></i>Asset Selection</h6>
                        <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                            <table class="table professional-table" id="assetTable">
                                <thead class="bg-info">
                                    <tr>
                                        <th width="5%">
                                            <input type="checkbox" id="selectAllAssets" />
                                        </th>
                                        <th>Asset No</th>
                                        <th>Asset Subnumber</th>
                                        <th>Asset Description</th>
                                        <th>HS Code</th>
                                        <th>Box Status</th>
                                    </tr>
                                </thead>
                                <tbody id="assetTableBody">
                                </tbody>
                            </table>
                        </div>
                        <button type="button" class="btn btn-primary mt-2" id="createBoxBtn" disabled>
                            <i class="fas fa-plus mr-2"></i>Create Box
                        </button>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-12">
                        <h6><i class="fas fa-archive mr-2"></i>Shipping Boxes</h6>
                        <div class="table-responsive">
                            <table class="table professional-table" id="boxTable">
                                <thead class="bg-info">
                                    <tr>
                                        <th>Box No</th>
                                        <th>Asset List</th>
                                        <th>Dimensions (L×W×H cm)</th>
                                        <th>Gross Weight (kg)</th>
                                        <th>Net Weight (kg)</th>
                                        <th>Box Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="boxTableBody">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" id="saveShippingBtn">
                    <i class="fas fa-save mr-2"></i>Save
                </button>
                <button type="button" class="btn btn-primary" id="exportExcelBtn" style="display: none;">
                    <i class="fas fa-file-excel mr-2"></i>Export Excel
                </button>
                <button type="button" class="btn btn-success" id="submitShippingBtn" style="display: none;">
                    <i class="fas fa-check mr-2"></i>Submit Shipping
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createBoxModal" tabindex="-1" role="dialog" aria-labelledby="createBoxModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-cube mr-2"></i>Create New Box</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="createBoxForm">
                    <div class="row">
                        <div class="col-md-4">
                            <label for="boxLength">Length (cm) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="boxLength" step="0.01" required />
                        </div>
                        <div class="col-md-4">
                            <label for="boxWidth">Width (cm) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="boxWidth" step="0.01" required />
                        </div>
                        <div class="col-md-4">
                            <label for="boxHeight">Height (cm) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="boxHeight" step="0.01" required />
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label for="grossWeight">Gross Weight (kg) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="grossWeight" step="0.01" required />
                        </div>
                        <div class="col-md-6">
                            <label for="netWeight">Net Weight (kg) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="netWeight" step="0.01" required />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label>Selected Assets:</label>
                        <div id="selectedAssetsList" class="border p-2 bg-light">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" id="submitBoxBtn">
                    <i class="fas fa-check mr-2"></i>Submit Box
                </button>
            </div>
        </div>
    </div>
</div>

