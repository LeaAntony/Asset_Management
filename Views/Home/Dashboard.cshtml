@section Scripts {
    <script src="~/lib/adminlte/plugins/chart.js/Chart.min.js"></script>
    <script src="~/lib/adminlte/plugins/chart.js/chartjs-plugin-datalabels.js"></script>
    <script src="~/lib/highchart/highcharts.js"></script>
    <script src="~/lib/adminlte/plugins/select2/js/select2.full.min.js"></script>
    <script>
        var table;
        var loading = "<div class='text-center p-4'><i class='fas fa-spinner fa-spin fa-2x text-primary'></i><p class='mt-2 text-muted'>Loading data...</p></div>";

        const chartColors = {
            primary: ['#1f4e79', '#4a90b8', '#7bb3d9', '#acd5ea'],
            success: ['#3DCD58', '#36C156', '#50CC6D', '#67DC82', '#83F39D'],
            warning: ['#ffd100', '#ffd54f', '#ffeb3b', '#fff176'],
            danger: ['#B10043', '#FF5C52', '#FF796F', '#FF9F99', '#FFC5C2'],
            neutral: ['#595959', '#757575', '#9e9e9e', '#e0e0e0']
        };

        function hexToRgb(hex) {
            hex = hex.replace('#','');
            if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
            const int = parseInt(hex, 16);
            return { r: (int >> 16) & 255, g: (int >> 8) & 255, b: int & 255 };
        }

        function rgbToHex(r, g, b) {
            return '#' + [r, g, b].map(x => x.toString(16).padStart(2, '0')).join('');
        }

        function lerp(a, b, t) { return a + (b - a) * t; }

        function buildGradientColors(count, ...stops) {
            if (!stops || stops.length === 0) return [];
            if (stops.length === 1 || count <= 1) return [stops[0]];

            const rgbs = stops.map(hexToRgb);
            const segments = stops.length - 1;
            const result = [];

            for (let i = 0; i < count; i++) {
                const t = i / (count - 1);
                const segPos = t * segments;
                const segIdx = Math.min(Math.floor(segPos), segments - 1);
                const localT = segPos - segIdx;

                const s = rgbs[segIdx], e = rgbs[segIdx + 1];
                const r = Math.round(lerp(s.r, e.r, localT));
                const g = Math.round(lerp(s.g, e.g, localT));
                const b = Math.round(lerp(s.b, e.b, localT));
                result.push(rgbToHex(r, g, b));
            }
            return result;
        }

        const defaultChartConfig = {
            credits: { enabled: false },
            chart: {
                style: {
                    fontFamily: "'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif"
                },
                backgroundColor: 'transparent'
            },
            title: {
                style: {
                    fontSize: '16px',
