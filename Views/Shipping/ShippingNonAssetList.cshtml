@section Scripts {

    <script>
        var openTableNonAsset, closedTableNonAsset;
        var loading = "<div class='text-center'><i class='fa fa-4x fa-spinner fa-spin'></i></div>";
        const user_role = "@role";
        const user_sesa_id = "@sesa_id";
        let currentBoxCountNonAsset = 0;
        const initial_gatepass_nonasset_no = "@ViewBag.gatepass_no";

        function copyApprovalLink(gatepass_no) {
            const baseUrl = window.location.protocol + "//" + window.location.host;
            const approvalLink = `${baseUrl}/Redirect/GatePassList?gatepass_no=${encodeURIComponent(gatepass_no)}`;

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(approvalLink).then(() => {
                    Swal.fire({
                        title: 'Link Copied!',
                        text: 'Redirect link has been copied to clipboard',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });
                }).catch(err => {
                    console.error('Failed to copy: ', err);
                    fallbackCopyTextToClipboard(approvalLink);
                });
            } else {
                fallbackCopyTextToClipboard(approvalLink);
            }
        }

        function fallbackCopyTextToClipboard(text) {
            const textArea = document.createElement("textarea");
            textArea.value = text;

            textArea.style.top = "0";
            textArea.style.left = "0";
            textArea.style.position = "fixed";

            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();

            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    Swal.fire({
                        title: 'Link Copied!',
                        text: 'Redirect link has been copied to clipboard',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false,
                        toast: true,
                        position: 'top-end'
                    });
                } else {
                    showLinkModal(text);
                }
            } catch (err) {
                console.error('Fallback: Oops, unable to copy', err);
                showLinkModal(text);
            }

            document.body.removeChild(textArea);
        }

        function showLinkModal(link) {
            Swal.fire({
                title: 'Copy Link',
                html: `<div class="form-group">
                        <label>Approval Link:</label>
                        <textarea class="form-control" rows="3" readonly style="font-size: 12px;">${link}</textarea>
                       </div>
                       <small class="text-muted">Please copy the link manually</small>`,
                icon: 'info',
                confirmButtonText: 'Close',
                width: '600px'
            });
        }

        function printGatepass(id_gatepass) {
            const url = `@Url.Action("PRINT_GATEPASS_PDF", "Export")?id_gatepass=${id_gatepass}`;
            window.open(url, '_blank');
        }

        function openPDF(filename) {
            var pdfURL = "../WI/" + filename;
            var iframe = document.getElementById("pdf-iframe");
            if (iframe) {
                $("#pdf-popup-modal").modal("show");
                iframe.src = pdfURL;
            } else {
                console.error("iframe element not found");
            }
        }

        function closePDF() {
            $("#pdf-popup-modal").modal("hide");
            var iframe = document.getElementById("pdf-iframe");
            iframe.src = "";
        }

        function downloadFile(filename, type) {
            if (!filename) {
                alert("File tidak tersedia");
                return;
            }

            let url = '';
            if (type === 'attach') {
                url = `../Upload/Proforma/${filename}`;
            } else if (type === 'support') {
                url = `../Upload/Proforma/${filename}`;
            }

            const fileExtension = filename.toLowerCase().split('.').pop();
            const imageExtensions = ['jpg', 'jpeg', 'png', 'gif', 'bmp'];
            const pdfExtensions = ['pdf'];

            if (imageExtensions.includes(fileExtension) || pdfExtensions.includes(fileExtension)) {
                window.open(url, '_blank');
            } else {
                const link = document.createElement('a');
                link.href = url;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                link.remove();
            }
        }

        $(document).ready(function () {
            initializeDataTablesNonAsset();
            initializeShippingModalNonAsset();
        });

        function initializeDataTablesNonAsset() {
            var status = $("select[name=status]").val();

            if (status === "OPEN") {
                $('#openTableContainer').addClass('active').show();
                $('#closedTableContainer').removeClass('active').hide();
                initializeOpenTableNonAsset();
            } else {
                $('#openTableContainer').removeClass('active').hide();
                $('#closedTableContainer').addClass('active').show();
                initializeClosedTableNonAsset();
            }

            $("select[name=status]").off('change').on('change', function () {
                initializeDataTablesNonAsset();
            });
        }

        function initializeOpenTableNonAsset() {
            if (openTableNonAsset) {
                openTableNonAsset.destroy();
            }

            var openColumns = [
                {
                    "data": "gatepass_no",
                    "className": "align-middle",
                    "title": "Request ID"
                },
                {
                    "data": "category",
                    "className": "align-middle text-center",
                    "title": "Category"
                },
                { "data": "requestor_name", "className": "align-middle", "title": "Request By" },
                { "data": "create_date", "className": "align-middle", "title": "Request Date" },
                { "data": "return_date", "className": "align-middle", "title": "Return Date" },
                { "data": "vendor_name", "className": "align-middle", "title": "Vendor Name" },
                {
                    "data": "status_gatepass",
                    "className": "align-middle text-center",
                    "title": "Status",
                    "render": function (data, type, row) {
                        var badgeClass = getStatusBadgeClass(data);
                        return '<span class="badge ' + badgeClass + '">' + data + '</span>';
                    }
                },
                {
                    "data": "status_remark",
                    "className": "align-middle text-center",
                    "render": function (data, type, row) {
                        if (!data) return '<span class="badge bg-secondary">-</span>';

                        var badgeClass;
                        var text = data;

                        if (data.includes('Waiting')) {
                            badgeClass = 'bg-warning text-dark';
                        }
                        else if (data.includes('Rejected By')) {
                            badgeClass = 'bg-danger';
                        }
                        else if (data === 'COMPLETED') {
                            badgeClass = 'bg-success';
                        }
                        else {
                            badgeClass = 'bg-dark';
                        }

                        return '<span class="badge ' + badgeClass + '" style="white-space: normal; word-wrap: break-word; max-width: 200px; display: inline-block;">' + text + '</span>';
                    }
                },
                {
                    "data": "id_gatepass",
                    "title": "Action",
                    "orderable": false,
                    render: function (data, type, row) {
                        return generateActionButtonsNonAsset(data, row, "OPEN");
                    }
                }
            ];

            openTableNonAsset = $("#table_shipping_nonasset_open").DataTable({
                "processing": true,
                "serverSide": true,
                "filter": true,
                "destroy": true,
                "scrollX": true,
                "scrollCollapse": true,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("GET_SHIPPING_NONASSET_LIST")",
                    "type": "POST",
                    "datatype": "json",
                    "data": function (d) {
                        d.status = "OPEN";
                    },
                    "error": function (xhr, error, thrown) {
                        console.error("Error in AJAX request:", error, thrown);
                    }
                },
                "columns": openColumns,
                "order": [[6, "desc"]],
                "columnDefs": [
                    { "orderable": false, "targets": -1 }
                ],
                "initComplete": function(settings, json) {
                    var wrapper = $('#table_shipping_nonasset_open').closest('.dataTables_wrapper');
                    wrapper.css('position', 'relative');
                    $('#statusSelect').appendTo(wrapper).css('display', 'block');

                    $('#statusSelect').select2({
                        width: '150px',
                        minimumResultsForSearch: Infinity
                    });

                    $('#statusSelect').next('.select2-container').css({
                        'position': 'absolute',
                        'top': '0px',
                        'right': '0px'
                    }).attr('id', 'statusSelect2');

                    if (initial_gatepass_nonasset_no && initial_gatepass_nonasset_no.trim() !== '') {
                        this.api().search(initial_gatepass_nonasset_no).draw();

                        $('div.dataTables_filter input').val(initial_gatepass_nonasset_no);

                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                    }
                }
            });
        }

        function initializeClosedTableNonAsset() {
            if (closedTableNonAsset) {
                closedTableNonAsset.destroy();
            }

            var closedColumns = [
                {
                    "data": "gatepass_no",
                    "className": "align-middle",
                    "title": "Request ID"
                },
                {
                    "data": "proforma_no",
                    "className": "align-middle",
                    "title": "Proforma No",
                    "render": function (data, type, row) {
                        return data ? data : '-';
                    }
                },
                {
                    "data": "category",
                    "className": "align-middle text-center",
                    "title": "Category"
                },
                { "data": "requestor_name", "className": "align-middle", "title": "Request By" },
                { "data": "create_date", "className": "align-middle", "title": "Request Date" },
                { "data": "return_date", "className": "align-middle", "title": "Return Date" },
                { "data": "vendor_name", "className": "align-middle", "title": "Vendor Name" },
                {
                    "data": "status_gatepass",
